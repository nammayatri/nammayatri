<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only AndroidManifest overlay generated by the launcher. Two jobs:
    1. Inject a valid AdMob APPLICATION_ID so MobileAdsInitProvider does
       not crash on startup with "Invalid application ID".
    2. Disable every Firebase auto-init switch we know about. Our
       placeholder google-services.json has a non-functional api_key;
       Firebase Installations / Crashlytics / Analytics / Messaging /
       Performance / Remote-Config will throw on a worker thread when
       they try to use it, killing the whole process. Disabling auto-
       init keeps the app alive at the cost of those features being
       no-ops in dev (which the user asked for).

  Used as a debug-source overlay (`android/app/src/debug/AndroidManifest.xml`)
  rather than via app.json / gradle props because gradle always re-merges
  debug manifests; app.json is read at configure time and incremental
  builds may skip reconfigure.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
  <application>
    <!-- AdMob: required so MobileAdsInitProvider can initialize. Test ID. -->
    <meta-data
      android:name="com.google.android.gms.ads.APPLICATION_ID"
      android:value="ca-app-pub-3940256099942544~3347511713"
      tools:replace="android:value" />

    <!-- Firebase: disable every auto-init switch. The placeholder
         google-services.json has a non-functional api_key; without these
         flags Firebase background workers crash the process. -->
    <meta-data
      android:name="firebase_analytics_collection_enabled"
      android:value="false"
      tools:replace="android:value" />
    <meta-data
      android:name="firebase_analytics_collection_deactivated"
      android:value="true"
      tools:replace="android:value" />
    <meta-data
      android:name="google_analytics_adid_collection_enabled"
      android:value="false"
      tools:replace="android:value" />
    <meta-data
      android:name="firebase_crashlytics_collection_enabled"
      android:value="false"
      tools:replace="android:value" />
    <meta-data
      android:name="firebase_performance_collection_enabled"
      android:value="false"
      tools:replace="android:value" />
    <meta-data
      android:name="firebase_performance_collection_deactivated"
      android:value="true"
      tools:replace="android:value" />
    <meta-data
      android:name="firebase_messaging_auto_init_enabled"
      android:value="false"
      tools:replace="android:value" />
    <meta-data
      android:name="firebase_inapp_messaging_auto_data_collection_enabled"
      android:value="false"
      tools:replace="android:value" />
  </application>
</manifest>
