{
  "_comment": "DB connections per environment. Master uses _v2 suffix databases. db_schema overrides Postgres schema name when it differs from config key.",

  "master": {
    "default": {
      "host": "application-db.XXXX.ap-south-1.rds.amazonaws.com",
      "port": 5432,
      "user": "atlas_ro",
      "password": "",
      "database": "atlas_app_v2"
    },
    "schemas": {
      "atlas_app":               { "database": "atlas_app_v2" },
      "atlas_driver_offer_bpp":  { "database": "atlas_driver_offer_bpp_v2" },
      "atlas_bap_dashboard":     { "database": "atlas_bap_dashboard_v2" },
      "atlas_bpp_dashboard":     { "database": "atlas_bpp_dashboard_v2" },
      "atlas_safety_dashboard":  { "database": "atlas_safety_dashboard_v2" },
      "atlas_registry":          { "database": "atlas_mock_registry_v2", "db_schema": "atlas_mock_registry" },
      "atlas_special_zone":      { "database": "atlas_driver_offer_bpp_v2" }
    }
  },

  "local": {
    "default": {
      "host": "localhost",
      "port": 5434,
      "user": "postgres",
      "password": "",
      "database": "atlas_dev"
    },
    "schemas": {}
  },

  "prod": {
    "default": {
      "host": "prod-db.internal.example.com",
      "port": 5432,
      "user": "readonly_user",
      "password": "",
      "database": "atlas_prod"
    },
    "schemas": {
      "atlas_app":               { "host": "prod-rider-db.internal.example.com" },
      "atlas_driver_offer_bpp":  { "host": "prod-driver-db.internal.example.com" },
      "atlas_bap_dashboard":     { "host": "prod-dashboard-db.internal.example.com" },
      "atlas_bpp_dashboard":     { "host": "prod-dashboard-db.internal.example.com" },
      "atlas_safety_dashboard":  { "host": "prod-safety-db.internal.example.com" },
      "atlas_registry":          { "host": "prod-registry-db.internal.example.com" }
    }
  },

  "env": {
    "default": {
      "host": "env-db.internal.example.com",
      "port": 5432,
      "user": "atlas_user",
      "password": "",
      "database": "atlas_env"
    },
    "schemas": {}
  }
}
