{
  "info": {
    "name": "Student Pass Purchase Flow",
    "description": "Tests PR #13586 (Student Pass). Flow: register PassOrganization (dashboard) \u2192 student submits PassDetails with CSV-derived routeDetails \u2192 admin verifies CLG_VERIFIED then MTC_VERIFIED \u2192 student lists Available Passes (verificationStatus=MTC_VERIFIED enables tier pricing) \u2192 student purchases the StudentPass via /multimodal/pass/v2/{passId}/select \u2192 mock Juspay CHARGED \u2192 verify in /multimodal/pass/list.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Auto-skip mock-server requests when envType is not Local.",
          "// Set envType=Local in Local env files; omit / set to 'Master' otherwise.",
          "(function () {",
          "  var envType = pm.environment.get('envType') || 'Local';",
          "  if (envType === 'Local') return;",
          "  var raw = (pm.request && pm.request.url && pm.request.url.toString()) || '';",
          "  if (raw.indexOf('mockServerUrl') !== -1 || raw.indexOf('mock_fcm_url') !== -1) {",
          "    console.log('[skip] mock-only request on envType=' + envType + ': ' + (pm.info && pm.info.requestName));",
          "    if (pm.execution && typeof pm.execution.skipRequest === 'function') {",
          "      pm.execution.skipRequest();",
          "    }",
          "  }",
          "})();",
          "",
          "if (!pm.collectionVariables.get('_test_admin_number')) {",
          "    var aNum = '8' + Math.floor(100000000 + Math.random() * 899999999);",
          "    pm.collectionVariables.set('_test_admin_number', aNum);",
          "    console.log('Test admin:', aNum);",
          "}",
          "if (!pm.collectionVariables.get('_test_student_number')) {",
          "    var sNum = '7' + Math.floor(100000000 + Math.random() * 899999999);",
          "    pm.collectionVariables.set('_test_student_number', sNum);",
          "    console.log('Test student:', sNum);",
          "}",
          "// Defensive: derive baseUrl_dashboard from baseUrl_app if env missing it.",
          "// Avoids 'Failed to construct URL' when only the collection (not the env) is imported.",
          "if (!pm.environment.get('baseUrl_dashboard') && !pm.variables.get('baseUrl_dashboard')) {",
          "    var app = pm.environment.get('baseUrl_app') || pm.variables.get('baseUrl_app') || 'http://localhost:8013/v2';",
          "    var dash = app.replace(/\\/v2\\/?$/, '/dashboard');",
          "    pm.environment.set('baseUrl_dashboard', dash);",
          "    console.log('Derived baseUrl_dashboard:', dash);",
          "}",
          "if (!pm.environment.get('bap_short_id') && !pm.variables.get('bap_short_id')) {",
          "    pm.environment.set('bap_short_id', 'NAMMA_YATRI');",
          "}",
          "if (!pm.environment.get('city') && !pm.variables.get('city')) {",
          "    pm.environment.set('city', 'Chennai');",
          "}",
          "if (!pm.environment.get('dashboard_token') && !pm.variables.get('dashboard_token')) {",
          "    pm.environment.set('dashboard_token', 'some-secret-dashboard-token-for-rider-app');",
          "}",
          "if (!pm.environment.get('pass_enum') && !pm.variables.get('pass_enum')) {",
          "    pm.environment.set('pass_enum', 'StudentPass');",
          "}",
          "if (!pm.environment.get('login_otp') && !pm.variables.get('login_otp')) {",
          "    pm.environment.set('login_otp', '7891');",
          "}",
          "if (!pm.environment.get('mockServerUrl') && !pm.variables.get('mockServerUrl')) {",
          "    pm.environment.set('mockServerUrl', 'http://localhost:8080');",
          "}",
          "if (!pm.environment.get('student_pass_code') && !pm.variables.get('student_pass_code')) {",
          "    pm.environment.set('student_pass_code', 'STUDENTPASS');",
          "}",
          "if (!pm.environment.get('org_name') && !pm.variables.get('org_name')) {",
          "    pm.environment.set('org_name', 'MTC Test School');",
          "}",
          "if (!pm.environment.get('org_address') && !pm.variables.get('org_address')) {",
          "    pm.environment.set('org_address', 'Anna Salai, Chennai');",
          "}",
          "// Route stop seeds (CSV-derived, route 102, Chennai)",
          "var routeDefaults = {",
          "    route1_src_id: 'ceb46e7bbf', route1_src_name: 'ADYAR B.T',",
          "    route1_dest_id: 'abdf0ebe40', route1_dest_name: 'SHOLINGANALLUR P.U.OFFICE',",
          "    route2_src_id: '4210b6bd61', route2_src_name: 'KANDANCHAVADI',",
          "    route2_dest_id: '0f463e18c6', route2_dest_name: 'KELAMBAKKAM'",
          "};",
          "Object.keys(routeDefaults).forEach(function (k) {",
          "    if (!pm.environment.get(k) && !pm.variables.get(k)) pm.environment.set(k, routeDefaults[k]);",
          "});"
        ],
        "type": "text/javascript"
      }
    }
  ],
