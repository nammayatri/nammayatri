    {
      "name": "Verify Purchased Pass",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// The verify endpoint validates pass ownership/activation, then runs the StudentPass match logic.",
              "// With studentPassVerifyConfig = {distanceThresholdMeters:2000, minMatchingStops:0} on this MOC, any vehicle whose route stops are within 2km of the user's RoutePair stops is PARTIALLY_VERIFIED.",
              "// In a real run, vehicleNumber must be a bus that Nandi knows is currently on a tracked route. Without that, the server typically responds with PassInvalidVehicle (400) or PassVerificationFailed (400).",
              "// We accept any of: 200 (verified), or a known business 4xx that proves the request was parsed and dispatched to the verify pipeline.",
              "var ok = [200, 400, 404].indexOf(pm.response.code) >= 0;",
              "pm.test('Verify endpoint reachable + parsed request', function () { pm.expect(ok).to.eql(true); });",
              "console.log('Verify status:', pm.response.code, 'body:', pm.response.text());"
            ],
            "type": "text/javascript"
          }
        }
