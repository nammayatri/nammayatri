              "        console.log('Pool empty (attempt', attempt + 1, ') — retrying...');",
              "        var t0 = Date.now(); while (Date.now() - t0 < 5000) {}",
              "        pm.collectionVariables.set('_nearby_attempt', String(attempt + 1));",
              "        pm.execution.setNextRequest(pm.info.requestName);",
