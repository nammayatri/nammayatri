    {
      "name": "Create User Cancellation Dues Logic (BPP)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json();",
              "console.log('UserCancellationDues logic version:', d.version, 'updated:', d.isRuleUpdated);",
              "if (d.version) { pm.environment.set('cancellation_logic_version', d.version); }",
              "pm.test('Logic created', function () { pm.response.to.have.status(200); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{dashboard_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"domain\":{\"tag\":\"USER_CANCELLATION_DUES\"},\"shouldUpdateRule\":true,\"updatePassword\":\"98979\",\"description\":\"Helsinki rider 3-min cancellation charge\",\"inputData\":[{\"cancelledBy\":\"CancellationByCustomer\",\"timeOfDriverCancellation\":0,\"timeOfCustomerCancellation\":200,\"isArrivedAtPickup\":false,\"driverWaitingTime\":0,\"callAttemptByDriver\":false,\"actualCoveredDistance\":0,\"expectedCoveredDistance\":0,\"cancellationDues\":0,\"cancelledRides\":0,\"totalBookings\":0,\"estimatedBookingFare\":25,\"completedRides\":0,\"validCancellations\":0,\"cancellationDueRides\":0,\"serviceTier\":\"COMFY\",\"tripCategory\":{\"tag\":\"OneWay\",\"contents\":\"OneWayOnDemandDynamicOffer\"},\"cancellationReasonSelected\":null,\"userSdkVersion\":null,\"isCashPayment\":false,\"timeSinceBooking\":200}],\"rules\":[{\"cat\":[{\"var\":\"\"},{\"cancellationCharges\":{\"if\":[{\"and\":[{\"==\":[{\"var\":\"cancelledBy\"},\"CancellationByCustomer\"]},{\">=\" :[{\"var\":\"timeSinceBooking\"},180]}]},3,0]}}]},{\"cat\":[{\"var\":\"\"},{\"cancellationChargesTax\":{\"if\":[{\"and\":[{\"==\":[{\"var\":\"cancelledBy\"},\"CancellationByCustomer\"]},{\">=\" :[{\"var\":\"timeSinceBooking\"},180]}]},0.72,0]}}]}]}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/nammaTag/appDynamicLogic/verify",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "nammaTag", "appDynamicLogic", "verify"]
        }
      },
      "response": []
    },
    {
      "name": "Rollout User Cancellation Dues Logic (BPP)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const start = Date.now(); while (Date.now() - start < 2000) {}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Rollout success', function () { pm.response.to.have.status(200); });"
