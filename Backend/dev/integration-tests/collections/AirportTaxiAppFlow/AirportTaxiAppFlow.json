      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{driver_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"specialZoneOtpCode\": \"{{sz_otp}}\", \"point\": {\"lat\": {{sz_origin_lat}}, \"lon\": {{sz_origin_lon}}}}"
        },
        "url": {
          "raw": "{{baseURL_namma_P}}/driver/otpRide/start",
          "host": ["{{baseURL_namma_P}}"],
          "path": ["driver", "otpRide", "start"]
        }
      }
    },
    {
      "name": "End Ride",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const start = Date.now();",
              "while (Date.now() - start < 1000) { /* busy wait */ }"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "console.log('Ride ended!');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{driver_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"point\": {\"lat\": {{dest_lat}}, \"lon\": {{dest_lon}}}}"
        },
        "url": {
          "raw": "{{baseURL_namma_P}}/driver/ride/{{driver_ride_id}}/end",
          "host": ["{{baseURL_namma_P}}"],
          "path": ["driver", "ride", "{{driver_ride_id}}", "end"]
        }
      }
    },
    {
      "name": "Verify Booking Completed (Rider)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const start = Date.now();",
              "while (Date.now() - start < 3000) { /* busy wait */ }"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json();",
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Booking status is COMPLETED', function () {",
              "    pm.expect(d.bookingStatus).to.equal('COMPLETED');",
              "});",
              "pm.test('Ride status is COMPLETED', function () {",
              "    pm.expect(d.rideStatus).to.equal('COMPLETED');",
              "});",
              "console.log('Airport Taxi App Flow completed! Booking:', d.bookingStatus, 'Ride:', d.rideStatus);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "token", "value": "{{rider_token}}" }
        ],
        "url": {
          "raw": "{{baseUrl_app}}/rideBooking/v2/{{customer_bookingId}}",
          "host": ["{{baseUrl_app}}"],
          "path": ["rideBooking", "v2", "{{customer_bookingId}}"]
        }
      }
    }
  ]
}
