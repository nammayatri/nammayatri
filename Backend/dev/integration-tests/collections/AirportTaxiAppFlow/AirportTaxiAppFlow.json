    {
      "name": "Get Booking (Extract Airport Queue OTP)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const start = Date.now();",
              "while (Date.now() - start < 3000) { /* busy wait */ }"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json();",
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "",
              "if (d.list && d.list.length > 0) {",
              "    var booking = d.list[0];",
              "    pm.environment.set('customer_bookingId', booking.id);",
              "    var szOtp = null;",
              "    if (booking.bookingDetails && booking.bookingDetails.contents && booking.bookingDetails.contents.otpCode) {",
              "        szOtp = booking.bookingDetails.contents.otpCode;",
              "    }",
              "    pm.environment.set('sz_otp', szOtp || '');",
              "    console.log('Booking:', booking.id, 'Status:', booking.status, 'OTP:', szOtp, 'tripCategory:', JSON.stringify(booking.tripCategory));",
              "    pm.test('Booking status is NEW or CONFIRMED', function () {",
              "        pm.expect(booking.status).to.be.oneOf(['NEW', 'CONFIRMED']);",
              "    });",
              "}",
              "pm.test('Has airport queue OTP', function () {",
              "    pm.expect(pm.environment.get('sz_otp')).to.be.a('string').that.is.not.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
