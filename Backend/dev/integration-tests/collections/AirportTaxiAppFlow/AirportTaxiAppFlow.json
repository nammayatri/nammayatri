{
  "info": {
    "name": "Airport Taxi App Flow (Special Zone)",
    "description": "Real app-level airport taxi flow: fresh driver + rider onboard through the actual apps (not the dashboard booth proxy), search from an airport special zone, get a queue-based quote+OTP (no upfront driver assignment), and whichever driver enters the rider's OTP claims the ride -> starts -> ends.\n\nThis mirrors how a real airport taxi rank queue works: the rider books and receives an OTP; the driver at the front of the physical queue enters that OTP to claim the ride at ride-start time.\n\nPrerequisites:\n- Special zone geometry must be seeded for the pickup point (see AirportTaxiFlow collection notes for common geometry issues)\n- A fare_product with trip_category='OneWay_OneWayRideOtp' must exist for the special zone's pickup area\n- Environment must have sz_origin_lat/sz_origin_lon within an enabled airport special zone\n- If no special zone is configured / geom_geo_json is stale, this will fail at the 'Has quotes for special zone' assertion with empty quotes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Auto-skip mock-server requests when envType is not Local.",
          "(function () {",
          "  var envType = pm.environment.get('envType') || 'Local';",
          "  if (envType === 'Local') return;",
          "  var raw = (pm.request && pm.request.url && pm.request.url.toString()) || '';",
          "  if (raw.indexOf('mockServerUrl') !== -1 || raw.indexOf('mock_fcm_url') !== -1) {",
          "    console.log('[skip] mock-only request on envType=' + envType + ': ' + (pm.info && pm.info.requestName));",
          "    if (pm.execution && typeof pm.execution.skipRequest === 'function') {",
          "      pm.execution.skipRequest();",
          "    }",
          "  }",
          "})();",
          "",
          "// Generate random values ONCE per collection run",
          "if (!pm.collectionVariables.get('_test_driver_number')) {",
          "    var dNum = '9' + Math.floor(100000000 + Math.random() * 899999999);",
          "    var rNum = '8' + Math.floor(100000000 + Math.random() * 899999999);",
          "    var regNo = 'KA' + String(Math.floor(10 + Math.random() * 89)) + String.fromCharCode(65 + Math.floor(Math.random() * 26)) + String.fromCharCode(65 + Math.floor(Math.random() * 26)) + String(Math.floor(1000 + Math.random() * 8999));",
          "    pm.collectionVariables.set('_test_driver_number', dNum);",
          "    pm.collectionVariables.set('_test_rider_number', rNum);",
          "    pm.collectionVariables.set('_test_reg_no', regNo);",
          "    console.log('Test driver:', dNum, 'rider:', rNum, 'reg:', regNo);",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
