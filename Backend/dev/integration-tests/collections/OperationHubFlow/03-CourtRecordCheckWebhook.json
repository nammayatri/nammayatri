          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('overwrite webhook 200', function(){ pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "{{crc_webhook_secret}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"action\":\"a\",\"completed_at\":\"2026-06-13T10:00:00Z\",\"created_at\":\"2026-06-13T09:59:00Z\",\"group_id\":\"{{crc_test_driver}}\",\"request_id\":\"crc-newman-4\",\"status\":\"completed\",\"task_id\":\"crc-newman-4-t\",\"type\":\"ind_court_record\",\"result\":{\"source_output\":{\"number_of_cases\":0,\"risk_type\":\"low\",\"risk_summary\":\"no cases\",\"status\":\"clear\"}}}"
        },
        "url": {
          "raw": "{{driverAppWebhookBase}}/{{dashboard_merchant_id}}/{{city}}/service/idfy/verification",
          "host": [
            "{{driverAppWebhookBase}}"
          ],
          "path": [
            "{{dashboard_merchant_id}}",
            "{{city}}",
            "service",
            "idfy",
            "verification"
          ]
        }
      }
    },
    {
      "name": "05 - court_record overwritten (risk_type=low) (poll)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if(!pm.collectionVariables.get('_p5')) pm.collectionVariables.set('_p5','0');",
              "var a=parseInt(pm.collectionVariables.get('_p5'))||0; var w=a===0?3000:2000; var t=Date.now(); while(Date.now()-t<w){}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json(); var a=parseInt(pm.collectionVariables.get('_p5'))||0;",
              "var cr=(d.rows&&d.rows[0])?d.rows[0].court_record:null; if(typeof cr==='string'){try{cr=JSON.parse(cr);}catch(e){}}",
              "var res=(cr&&cr.result)?cr.result:null;",
              "if (res && res.risk_type==='low') { pm.collectionVariables.set('_p5','0'); pm.test('court_record overwritten high->low', function(){ pm.expect(res.risk_type).to.eql('low'); }); }",
              "else if (a<8) { pm.collectionVariables.set('_p5',String(a+1)); postman.setNextRequest(pm.info.requestName); }",
              "else { pm.collectionVariables.set('_p5','0'); pm.test('court_record overwritten within retries', function(){ pm.expect(res && res.risk_type).to.eql('low'); }); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"db_name\":\"atlas_dev\",\"db_schema\":\"atlas_driver_offer_bpp\",\"table_name\":\"driver_identity_info\",\"select\":[\"court_record\"],\"where_clause\":[{\"column_name\":\"driver_id\",\"val\":\"{{crc_test_driver}}\",\"op\":\"=\"}],\"limit\":1}"
        },
        "url": {
          "raw": "{{mockServerUrl}}/mock/sql/select",
          "host": [
            "{{mockServerUrl}}"
          ],
          "path": [
            "mock",
            "sql",
            "select"
          ]
        }
      }
    },
