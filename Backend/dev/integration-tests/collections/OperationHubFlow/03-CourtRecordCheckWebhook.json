          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('wrong Authorization rejected (400)', function(){ pm.response.to.have.status(400); });",
              "pm.test('INVALID_AUTHORIZATION_HEADER', function(){ pm.expect(pm.response.text()).to.include('INVALID_AUTHORIZATION_HEADER'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "WRONG-secret"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"action\":\"a\",\"completed_at\":\"2026-06-13T10:00:00Z\",\"created_at\":\"2026-06-13T09:59:00Z\",\"group_id\":\"{{crc_test_driver}}\",\"request_id\":\"crc-newman-3\",\"status\":\"completed\",\"task_id\":\"crc-newman-3-t\",\"type\":\"ind_court_record\",\"result\":{\"source_output\":{\"number_of_cases\":0,\"status\":\"completed\"}}}"
        },
        "url": {
          "raw": "{{driverAppWebhookBase}}/{{dashboard_merchant_id}}/{{city}}/service/idfy/verification",
          "host": [
            "{{driverAppWebhookBase}}"
          ],
          "path": [
            "{{dashboard_merchant_id}}",
            "{{city}}",
            "service",
            "idfy",
            "verification"
          ]
        }
      }
    },
    {
      "name": "04 - Overwrite (high -> low) -> 200",
      "event": [
