    {
      "name": "13 - Verify Pending Challan Count on our VRC (poll DB via mock SQL)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.collectionVariables.get('_12_attempt')) pm.collectionVariables.set('_12_attempt', '0');",
              "var attempt = parseInt(pm.collectionVariables.get('_12_attempt')) || 0;",
              "// Wait for the forked background challan-search task to complete",
              "var wait = attempt === 0 ? 3000 : 2000;",
              "var t0 = Date.now(); while (Date.now() - t0 < wait) {}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('SQL select returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "var attempt = parseInt(pm.collectionVariables.get('_12_attempt')) || 0;",
              "",
              "console.log('Step 12 attempt', attempt + 1, ': rows:', d.count, JSON.stringify(d.rows));",
              "",
              "// We query our exact VRC by unencrypted_certificate_number, so rows[0] is ours.",
              "var vrc = (d.rows && d.rows.length > 0) ? d.rows[0] : null;",
              "pm.test('Our VRC exists in DB', function () { pm.expect(vrc).to.not.be.null; });",
              "",
              "var pc = vrc ? vrc.pending_challan : null;",
              "if (typeof pc === 'string') { try { pc = JSON.parse(pc); } catch (e) {} }",
              "var count = pc ? pc.pendingChallanCount : null;",
              "if (count !== null && count !== undefined) {",
              "  pm.collectionVariables.set('_12_attempt', '0');",
              "  pm.test('Pending challan count is a number', function () {",
              "    pm.expect(count).to.be.a('number');",
              "  });",
              "  pm.test('Pending challan count equals mock value (3)', function () {",
              "    pm.expect(count).to.eql(3);",
              "  });",
              "  pm.test('No fetch error stored', function () {",
              "    pm.expect(pc.errorMessage == null).to.be.true;",
              "  });",
              "  console.log('SUCCESS: VRC', vrc.id, 'pendingChallanCount =', count);",
              "} else if (attempt < 8) {",
              "  pm.collectionVariables.set('_12_attempt', String(attempt + 1));",
              "  postman.setNextRequest(pm.info.requestName);",
              "} else {",
              "  pm.collectionVariables.set('_12_attempt', '0');",
              "  pm.test('Pending challan was updated (after 8 retries)', function () {",
              "    pm.expect(count).to.not.be.null;",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
