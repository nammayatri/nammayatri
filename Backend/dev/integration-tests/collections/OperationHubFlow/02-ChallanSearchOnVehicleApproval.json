    {
      "name": "08 - Verify RC Status (poll until VALID)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.collectionVariables.get('_07_attempt')) pm.collectionVariables.set('_07_attempt', '0');",
              "var attempt = parseInt(pm.collectionVariables.get('_07_attempt')) || 0;",
              "if (attempt > 0) { var t0 = Date.now(); while (Date.now() - t0 < 2000) {} }"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "var attempt = parseInt(pm.collectionVariables.get('_07_attempt')) || 0;",
              "",
              "// Find our RC in the vehicle documents",
              "var rcNumber = pm.collectionVariables.get('_test_rc_number');",
              "var vehicleDocs = d.vehicleDocuments || [];",
              "var ourVehicle = vehicleDocs.find(function(v) { return v.registrationNo === rcNumber; });",
              "",
              "console.log('Step 07 attempt', attempt + 1, ': vehicleDocs count:', vehicleDocs.length, ', found our RC:', !!ourVehicle);",
              "",
              "if (ourVehicle) {",
              "  var rcDoc = (ourVehicle.documents || []).find(function(doc) { return doc.documentType === 'VehicleRegistrationCertificate'; });",
              "  var rcStatus = rcDoc ? rcDoc.verificationStatus : 'NOT_FOUND';",
              "  console.log('RC verification status:', rcStatus);",
              "",
              "  if (rcStatus === 'VALID' || rcStatus === 'MANUAL_VERIFICATION_REQUIRED') {",
              "    pm.collectionVariables.set('_07_attempt', '0');",
              "    pm.test('RC is verified', function () {",
              "      pm.expect(['VALID', 'MANUAL_VERIFICATION_REQUIRED']).to.include(rcStatus);",
              "    });",
              "  } else if (attempt < 5) {",
              "    pm.collectionVariables.set('_07_attempt', String(attempt + 1));",
              "    postman.setNextRequest(pm.info.requestName);",
              "  } else {",
              "    pm.collectionVariables.set('_07_attempt', '0');",
              "    pm.test('RC verified within retries', function () {",
              "      pm.expect(['VALID', 'MANUAL_VERIFICATION_REQUIRED']).to.include(rcStatus);",
              "    });",
              "  }",
              "} else if (attempt < 5) {",
              "  pm.collectionVariables.set('_07_attempt', String(attempt + 1));",
              "  postman.setNextRequest(pm.info.requestName);",
              "} else {",
              "  pm.collectionVariables.set('_07_attempt', '0');",
              "  pm.test('RC found in status response', function () { pm.expect(ourVehicle).to.not.be.undefined; });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{driver_token}}"
