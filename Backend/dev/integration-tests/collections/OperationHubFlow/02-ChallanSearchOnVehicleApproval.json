{
  "info": {
    "name": "Challan Search on Vehicle Inspection Approval",
    "description": "End-to-end test: registers a driver, creates a VRC via register/rc with vehicleDetails (sync path), creates an ONBOARDING_INSPECTION hub request, approves it, and verifies that the Signzy challan search fires and updates pending_challan (json {pendingChallanCount, errorMessage}) on the VRC.\n\nPrerequisites:\n  1. Run setup-challan-search-test.sql to seed ChallanSearch_Signzy config\n  2. Mock server running on localhost:8080 with signzy mock service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "(function () {",
          "  var envType = pm.environment.get('envType') || 'Local';",
          "  if (envType === 'Local') return;",
          "  var raw = (pm.request && pm.request.url && pm.request.url.toString()) || '';",
          "  if (raw.indexOf('mockServerUrl') !== -1) {",
          "    console.log('[skip] mock-only request on envType=' + envType);",
          "    if (pm.execution && typeof pm.execution.skipRequest === 'function') pm.execution.skipRequest();",
          "  }",
          "})();",
          "",
          "if (!pm.collectionVariables.get('_test_driver_number')) {",
          "    var driverNum = '8' + Math.floor(100000000 + Math.random() * 899999999);",
          "    var fleetNum  = '9' + Math.floor(100000000 + Math.random() * 899999999);",
          "    var rcNumber  = 'KA' + String(Math.floor(10 + Math.random() * 89)) + 'CH' + String(Math.floor(1000 + Math.random() * 8999));",
          "    pm.collectionVariables.set('_test_driver_number', driverNum);",
          "    pm.collectionVariables.set('_test_fleet_owner_number', fleetNum);",
          "    pm.collectionVariables.set('_test_rc_number', rcNumber);",
          "    console.log('Test driver:', driverNum, 'fleet owner:', fleetNum, 'RC:', rcNumber);",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
