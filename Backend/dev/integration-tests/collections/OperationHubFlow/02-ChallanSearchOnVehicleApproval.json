    {
      "name": "11 - Fetch Hub Request ID (poll for KV drainer)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.collectionVariables.get('_10_attempt')) pm.collectionVariables.set('_10_attempt', '0');",
              "var attempt = parseInt(pm.collectionVariables.get('_10_attempt')) || 0;",
              "if (attempt > 0) { var t0 = Date.now(); while (Date.now() - t0 < 2000) {} }",
              "else { var t0 = Date.now(); while (Date.now() - t0 < 2000) {} }"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Fetch returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "var attempt = parseInt(pm.collectionVariables.get('_10_attempt')) || 0;",
              "console.log('Step 10 attempt', attempt + 1, ': got', d.requests ? d.requests.length : 0, 'requests');",
              "",
              "var rcNumber = pm.collectionVariables.get('_test_rc_number');",
              "if (d.requests && d.requests.length > 0) {",
              "  var match = d.requests.find(function(r) { return r.registrationNo === rcNumber; });",
              "  if (match) {",
              "    pm.collectionVariables.set('_10_attempt', '0');",
              "    pm.environment.set('hub_request_id', match.id);",
              "    console.log('Hub request ID:', match.id, 'status:', match.requestStatus);",
              "    pm.test('Hub request found for our RC', function () { pm.expect(match).to.not.be.undefined; });",
              "  } else if (attempt < 8) {",
              "    pm.collectionVariables.set('_10_attempt', String(attempt + 1));",
              "    postman.setNextRequest(pm.info.requestName);",
              "  } else {",
              "    pm.collectionVariables.set('_10_attempt', '0');",
              "    pm.test('Hub request found after retries', function () { pm.expect(match).to.not.be.undefined; });",
              "  }",
              "} else if (attempt < 8) {",
              "  pm.collectionVariables.set('_10_attempt', String(attempt + 1));",
              "  postman.setNextRequest(pm.info.requestName);",
              "} else {",
              "  pm.collectionVariables.set('_10_attempt', '0');",
              "  pm.test('At least one request after retries', function () { pm.expect(d.requests.length).to.be.above(0); });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{bpp_dashboard_token}}"
          }
        ],
        "url": {
          "raw": "{{baseURL_BPP_Driver_Direct}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/operator/fetch/hubRequests?mbRegistrationNo={{_test_rc_number}}&mbStatus=\"PENDING\"&mbLimit=10&mbOffset=0",
          "host": [
            "{{baseURL_BPP_Driver_Direct}}"
          ],
          "path": [
            "{{dashboard_merchant_id}}",
            "{{dashboard_city}}",
            "driver",
            "operator",
            "fetch",
            "hubRequests"
          ],
          "query": [
            {
              "key": "mbRegistrationNo",
              "value": "{{_test_rc_number}}"
            },
            {
              "key": "mbStatus",
              "value": "\"PENDING\""
            },
            {
              "key": "mbLimit",
              "value": "10"
            },
            {
              "key": "mbOffset",
              "value": "0"
            }
          ]
        }
