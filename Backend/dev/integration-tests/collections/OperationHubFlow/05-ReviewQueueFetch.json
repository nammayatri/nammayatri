{
	"info": {
		"name": "Review Queue Fetch — CRC (driver) + pendingChallan (vehicle) surfaced to BOT",
		"description": "Single collection that clubs the BOT review-queue READ path for both entity types:\n  - DRIVER  -> entityDetails.courtRecord.result populated (CRC), pendingChallan null\n  - VEHICLE -> entityDetails.pendingChallan.pendingChallanCount populated, courtRecord null\n\nDRIVER is fully self-contained (seed person + driver_information + driver_identity_info via mock SQL, then populate court_record through the real Idfy CRC webhook).\n\nVEHICLE cannot be raw-inserted (vehicle_registration_certificate has a NOT-NULL bytea column the mock insert can't supply), so it picks one pristine seed RC (verified IS NULL, pending_challan IS NULL), promotes it to a qualifying state (pending_challan is now a json column holding {pendingChallanCount, errorMessage}), asserts the queue, then restores it to defaults. Run serially.\n\nIMPORTANT on the `approved` query param (it is overloaded per entity type): DRIVER pending-review uses approved=false because the handler feeds this param into the ENABLED filter (not the approved column) — a genuinely pending driver is verified=true, enabled=false, approved=null (enabled requires approved==Just True, so an enabled driver is already past BOT approval). VEHICLE pending-review also uses approved=false, but there it filters the literal approved column (matches approved=Just False OR NULL), the state after BOT-flow inspection approval. So both pending sets use approved=false, via different columns.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"if (!pm.collectionVariables.get('_rqf_driver_id')) {",
					"  function uuidv4(){return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g,function(c){var r=Math.random()*16|0,v=c==='x'?r:(r&0x3|0x8);return v.toString(16);});}",
					"  pm.collectionVariables.set('_rqf_driver_id', uuidv4());",
					"}"
				]
			}
		}
	],
	"item": [
		{
			"name": "00 - [DRIVER] Seed person (mobile NULL -> no decrypt)",
			"event": [
				{ "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('seed person 200', function(){ pm.response.to.have.status(200); });" ] } }
			],
			"request": {
				"method": "POST",
				"header": [ { "key": "Content-Type", "value": "application/json" } ],
				"body": { "mode": "raw", "raw": "{\"db_name\":\"atlas_dev\",\"db_schema\":\"atlas_driver_offer_bpp\",\"table_name\":\"person\",\"values\":{\"id\":\"{{_rqf_driver_id}}\",\"first_name\":\"RQFDriver\",\"gender\":\"UNKNOWN\",\"identifier_type\":\"MOBILENUMBER\",\"is_new\":false,\"merchant_id\":\"{{driver_merchant_id}}\",\"onboarded_from_dashboard\":false,\"role\":\"DRIVER\",\"total_earned_coins\":0,\"used_coins\":0},\"touch_timestamps\":true,\"on_conflict_do_nothing\":true}" },
				"url": { "raw": "{{mockServerUrl}}/mock/sql/insert", "host": [ "{{mockServerUrl}}" ], "path": [ "mock", "sql", "insert" ] }
			}
		},
		{
			"name": "01 - [DRIVER] Seed driver_information (realistic pending: verified=true, enabled=false, approved=null)",
			"event": [
				{ "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('seed driver_information 200', function(){ pm.response.to.have.status(200); });" ] } }
			],
			"request": {
				"method": "POST",
				"header": [ { "key": "Content-Type", "value": "application/json" } ],
				"body": { "mode": "raw", "raw": "{\"db_name\":\"atlas_dev\",\"db_schema\":\"atlas_driver_offer_bpp\",\"table_name\":\"driver_information\",\"values\":{\"driver_id\":\"{{_rqf_driver_id}}\",\"merchant_operating_city_id\":\"{{crc_opcity_id}}\",\"verified\":true,\"enabled\":false,\"active\":false,\"blocked\":false,\"aadhaar_verified\":false,\"can_downgrade_to_hatchback\":false,\"can_downgrade_to_sedan\":false,\"can_downgrade_to_taxi\":false,\"num_of_locks\":0,\"on_ride\":false,\"payment_pending\":false,\"subscribed\":false,\"ac_restriction_lift_count\":0},\"touch_timestamps\":true,\"on_conflict_do_nothing\":true}" },
				"url": { "raw": "{{mockServerUrl}}/mock/sql/insert", "host": [ "{{mockServerUrl}}" ], "path": [ "mock", "sql", "insert" ] }
			}
		},
		{
			"name": "02 - [DRIVER] Seed driver_identity_info (court_record populated by webhook)",
			"event": [
				{ "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('seed identity row 200', function(){ pm.response.to.have.status(200); });" ] } }
			],
			"request": {
				"method": "POST",
				"header": [ { "key": "Content-Type", "value": "application/json" } ],
				"body": { "mode": "raw", "raw": "{\"db_name\":\"atlas_dev\",\"db_schema\":\"atlas_driver_offer_bpp\",\"table_name\":\"driver_identity_info\",\"values\":{\"driver_id\":\"{{_rqf_driver_id}}\",\"merchant_id\":\"{{driver_merchant_id}}\",\"merchant_operating_city_id\":\"{{crc_opcity_id}}\"},\"touch_timestamps\":true,\"on_conflict_do_nothing\":true}" },
				"url": { "raw": "{{mockServerUrl}}/mock/sql/insert", "host": [ "{{mockServerUrl}}" ], "path": [ "mock", "sql", "insert" ] }
			}
		},
		{
			"name": "03 - [DRIVER] CRC webhook populates court_record (real Idfy path)",
			"event": [
				{ "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('webhook 200', function(){ pm.response.to.have.status(200); });", "pm.test('ACK', function(){ pm.expect(pm.response.text()).to.include('ACK'); });" ] } }
			],
			"request": {
				"method": "POST",
				"header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "{{crc_webhook_secret}}" } ],
				"body": { "mode": "raw", "raw": "{\"action\":\"court_record_check\",\"completed_at\":\"2026-06-13T10:00:00Z\",\"created_at\":\"2026-06-13T09:59:00Z\",\"group_id\":\"{{_rqf_driver_id}}\",\"request_id\":\"rqf-crc-1\",\"status\":\"completed\",\"task_id\":\"rqf-crc-1-t\",\"type\":\"ind_court_record\",\"result\":{\"source_output\":{\"case_details_link\":\"https://example.com/c\",\"number_of_cases\":3,\"report_download_link\":\"https://example.com/r\",\"risk_summary\":\"3 pending cases\",\"risk_type\":\"high\",\"status\":\"completed\"}}}" },
				"url": { "raw": "{{driverAppWebhookBase}}/{{dashboard_merchant_id}}/{{city}}/service/idfy/verification", "host": [ "{{driverAppWebhookBase}}" ], "path": [ "{{dashboard_merchant_id}}", "{{city}}", "service", "idfy", "verification" ] }
			}
		},
		{
			"name": "04 - [DRIVER] Pending-review queue (approved=false) shows courtRecord (poll)",
			"event": [
				{ "listen": "prerequest", "script": { "type": "text/javascript", "exec": [ "if(!pm.collectionVariables.get('_rqf4')) pm.collectionVariables.set('_rqf4','0');", "var a=parseInt(pm.collectionVariables.get('_rqf4'))||0; var w=a===0?3000:2000; var t=Date.now(); while(Date.now()-t<w){}" ] } },
				{ "listen": "test", "script": { "type": "text/javascript", "exec": [
					"pm.test('queue 200', function(){ pm.response.to.have.status(200); });",
					"var d = pm.response.json(); var a = parseInt(pm.collectionVariables.get('_rqf4'))||0;",
					"var id = pm.collectionVariables.get('_rqf_driver_id');",
					"var list = (d && d.reviewQueue) ? d.reviewQueue : [];",
					"var mine = list.find(function(x){ return x.entityDetails && x.entityDetails.entityId === id; });",
					"var cr = mine && mine.entityDetails && mine.entityDetails.courtRecord ? mine.entityDetails.courtRecord.result : null;",
					"console.log('driver attempt', a+1, 'size', list.length, 'mine?', !!mine, 'crc?', !!cr);",
					"if (mine && cr) {",
					"  pm.collectionVariables.set('_rqf4','0');",
					"  pm.test('entityType DRIVER', function(){ pm.expect(mine.entityDetails.entityType).to.eql('DRIVER'); });",
					"  pm.test('courtRecord.result populated', function(){ pm.expect(cr).to.not.be.null; });",
					"  pm.test('courtRecord.errorMessage null on success', function(){ pm.expect(mine.entityDetails.courtRecord.errorMessage == null).to.be.true; });",
					"  pm.test('pendingChallan null for driver', function(){ pm.expect(mine.entityDetails.pendingChallan == null).to.be.true; });",
					"} else if (a < 8) {",
					"  pm.collectionVariables.set('_rqf4', String(a+1)); postman.setNextRequest(pm.info.requestName);",
					"} else {",
					"  pm.collectionVariables.set('_rqf4','0'); pm.test('driver courtRecord surfaced within retries', function(){ pm.expect(mine && cr).to.not.be.null; });",
					"}"
				] } }
			],
			"request": {
				"method": "GET",
				"header": [ { "key": "token", "value": "{{bpp_dashboard_token}}" } ],
				"url": {
					"raw": "{{baseURL_BPP_Driver_Direct}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/review/queue/DRIVER/request/BOT_REVIEW?approved=false&mbPersonId={{_rqf_driver_id}}",
					"host": [ "{{baseURL_BPP_Driver_Direct}}" ],
					"path": [ "{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "review", "queue", "DRIVER", "request", "BOT_REVIEW" ],
					"query": [ { "key": "approved", "value": "false" }, { "key": "mbPersonId", "value": "{{_rqf_driver_id}}" } ]
				}
			}
		},
