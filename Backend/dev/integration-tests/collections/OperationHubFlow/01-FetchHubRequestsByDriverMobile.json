              "var d = pm.response.json();",
              "pm.test('Response has requests array', function () { pm.expect(d).to.have.property('requests'); });",
              "pm.test('No requests returned for non-existent driver mobile', function () {",
              "  pm.expect(d.requests.length).to.eql(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "token", "value": "{{bpp_dashboard_token}}" }
        ],
        "url": {
          "raw": "{{baseURL_BPP_Driver_Direct}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/operator/fetch/hubRequests?mbDriverMobileNumber=0000000000&mbStatus=\"PENDING\"&mbLimit=10&mbOffset=0",
          "host": ["{{baseURL_BPP_Driver_Direct}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "operator", "fetch", "hubRequests"],
          "query": [
            { "key": "mbDriverMobileNumber", "value": "0000000000" },
            { "key": "mbStatus", "value": "\"PENDING\"" },
            { "key": "mbLimit", "value": "10" },
            { "key": "mbOffset", "value": "0" }
          ]
        }
      }
    },
    {
      "name": "09 - Fetch Hub Requests by Creator Mobile Number (Backward Compat)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Fetch hub requests returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "pm.test('Response has requests array', function () { pm.expect(d).to.have.property('requests'); });",
              "pm.test('At least one request returned via creator (fleet owner) mobile', function () {",
              "  pm.expect(d.requests.length).to.be.above(0);",
              "});",
              "",
              "var driverId = pm.environment.get('driver_id');",
              "var match = d.requests.find(function(r) { return r.driverId === driverId; });",
              "pm.test('Our driver request found via creator mobile search', function () {",
              "  pm.expect(match).to.not.be.undefined;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "token", "value": "{{bpp_dashboard_token}}" }
        ],
        "url": {
          "raw": "{{baseURL_BPP_Driver_Direct}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/operator/fetch/hubRequests?mbMobileNumber={{_test_fleet_owner_number}}&mbStatus=\"PENDING\"&mbLimit=10&mbOffset=0",
          "host": ["{{baseURL_BPP_Driver_Direct}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "operator", "fetch", "hubRequests"],
          "query": [
            { "key": "mbMobileNumber", "value": "{{_test_fleet_owner_number}}" },
            { "key": "mbStatus", "value": "\"PENDING\"" },
            { "key": "mbLimit", "value": "10" },
            { "key": "mbOffset", "value": "0" }
          ]
        }
      }
    },
    {
      "name": "10 - Fetch Hub Requests Without Mobile Filters (All Results)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Fetch hub requests returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "pm.test('Response has requests array', function () { pm.expect(d).to.have.property('requests'); });",
              "pm.test('Response has summary', function () { pm.expect(d).to.have.property('summary'); });",
              "pm.test('At least one request returned without mobile filter', function () {",
              "  pm.expect(d.requests.length).to.be.above(0);",
              "});",
              "",
              "// Verify response structure of each request",
              "var req = d.requests[0];",
              "pm.test('Request has id field', function () { pm.expect(req).to.have.property('id'); });",
              "pm.test('Request has operationHubId', function () { pm.expect(req).to.have.property('operationHubId'); });",
              "pm.test('Request has operationHubName', function () { pm.expect(req).to.have.property('operationHubName'); });",
              "pm.test('Request has requestStatus', function () { pm.expect(req).to.have.property('requestStatus'); });",
              "pm.test('Request has requestType', function () { pm.expect(req).to.have.property('requestType'); });",
              "pm.test('Request has requestTime', function () { pm.expect(req).to.have.property('requestTime'); });",
              "pm.test('Request has driverPhoneNo field', function () { pm.expect(req).to.have.property('driverPhoneNo'); });",
              "pm.test('Request has creatorPhoneNo field', function () { pm.expect(req).to.have.property('creatorPhoneNo'); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "token", "value": "{{bpp_dashboard_token}}" }
        ],
        "url": {
          "raw": "{{baseURL_BPP_Driver_Direct}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/operator/fetch/hubRequests?mbStatus=\"PENDING\"&mbLimit=10&mbOffset=0",
          "host": ["{{baseURL_BPP_Driver_Direct}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "operator", "fetch", "hubRequests"],
          "query": [
            { "key": "mbStatus", "value": "\"PENDING\"" },
            { "key": "mbLimit", "value": "10" },
            { "key": "mbOffset", "value": "0" }
          ]
        }
      }
    },
