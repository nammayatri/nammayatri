      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Resend limit returns 400', function () { pm.response.to.have.status(400); });",
              "var d = pm.response.json();",
              "pm.test('Error code is AUTH_BLOCKED', function () {",
              "    pm.expect(d.errorCode).to.eql('AUTH_BLOCKED');",
              "});",
              "pm.test('Message says attempts limit', function () {",
              "    pm.expect(d.errorMessage).to.include('Attempts limit exceed');",
              "});",
              "console.log('Resend limit exceeded response:', JSON.stringify(d));"
            ],
            "type": "text/javascript"
          }
