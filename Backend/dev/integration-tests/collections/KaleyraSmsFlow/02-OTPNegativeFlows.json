              "pm.collectionVariables.set('_authId2', d.authId);",
              "pm.test('Initial attempts is 3', function () { pm.expect(d.attempts).to.eql(3); });",
              "console.log('authId2:', d.authId, 'attempts:', d.attempts);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mobileNumber\": \"{{_phone2}}\",\n  \"mobileCountryCode\": \"+91\",\n  \"merchantId\": \"{{_merchant_id_auth}}\",\n  \"merchantOperatingCity\": \"{{city}}\"\n}"
        },
        "url": {
          "raw": "{{_auth_prefix}}/auth",
          "host": ["{{_auth_prefix}}"],
          "path": ["auth"]
        }
      }
    },
    {
      "name": "07 - Resend OTP (1 of 3, expect attempts=2)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Resend returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "pm.test('Attempts decremented to 2', function () { pm.expect(d.attempts).to.eql(2); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "" },
        "url": {
          "raw": "{{_auth_prefix}}/auth/otp/{{_authId2}}/resend",
          "host": ["{{_auth_prefix}}"],
          "path": ["auth", "otp", "{{_authId2}}", "resend"]
        }
      }
    },
    {
      "name": "08 - Resend OTP (2 of 3, expect attempts=1)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Resend returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "pm.test('Attempts decremented to 1', function () { pm.expect(d.attempts).to.eql(1); });"
