{
  "info": {
    "name": "OTP Negative Flows",
    "description": "Negative flow tests for OTP auth via SMS.\n\nTests: wrong OTP, wrong OTP format, already verified token, resend limit exceeded, invalid phone number.\n\nSkipped (impractical locally): OTP expiry (3 min wait), rate limit (driver=20/sec, rider=8000/sec).\n\nAuto-detects rider (port 8013, /v2/auth) vs driver (port 8016, /ui/auth) from baseUrl_internal.\nRequires: useFakeSms = Some 7891 (default local dev).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "if (!pm.collectionVariables.get('_phone1')) {",
          "    var p1 = '9' + Math.floor(100000000 + Math.random() * 899999999);",
          "    var p2 = '8' + Math.floor(100000000 + Math.random() * 899999999);",
          "    pm.collectionVariables.set('_phone1', p1);",
          "    pm.collectionVariables.set('_phone2', p2);",
          "    console.log('Phone1:', p1, 'Phone2:', p2);",
          "",
          "    // Auto-detect rider vs driver from baseUrl_internal port",
          "    var base = pm.environment.get('baseUrl_internal') || '';",
          "    if (base.indexOf('8016') !== -1) {",
          "        pm.collectionVariables.set('_auth_prefix', base + '/ui');",
          "        pm.collectionVariables.set('_merchant_id_auth', pm.environment.get('driver_merchant_id') || '7f7896dd-787e-4a0b-8675-e9e6fe93bb8f');",
          "        console.log('Detected: driver app (port 8016, /ui/auth)');",
          "    } else {",
          "        pm.collectionVariables.set('_auth_prefix', base + '/v2');",
          "        pm.collectionVariables.set('_merchant_id_auth', pm.environment.get('merchant_short_id') || 'NAMMA_YATRI');",
          "        console.log('Detected: rider app (port 8013, /v2/auth)');",
          "    }",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "01 - Auth (setup)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Auth returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "pm.collectionVariables.set('_authId', d.authId);",
              "console.log('authId:', d.authId);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mobileNumber\": \"{{_phone1}}\",\n  \"mobileCountryCode\": \"+91\",\n  \"merchantId\": \"{{_merchant_id_auth}}\",\n  \"merchantOperatingCity\": \"{{city}}\"\n}"
        },
        "url": {
          "raw": "{{_auth_prefix}}/auth",
          "host": ["{{_auth_prefix}}"],
          "path": ["auth"]
        }
      }
    },
    {
      "name": "02 - Verify with wrong OTP (expect INVALID_AUTH_DATA)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Wrong OTP returns 400', function () { pm.response.to.have.status(400); });",
              "var d = pm.response.json();",
              "pm.test('Error code is INVALID_AUTH_DATA', function () {",
              "    pm.expect(d.errorCode).to.eql('INVALID_AUTH_DATA');",
              "});",
              "console.log('Wrong OTP response:', JSON.stringify(d));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"otp\": \"0000\",\n  \"deviceToken\": \"test-device\"\n}"
        },
        "url": {
          "raw": "{{_auth_prefix}}/auth/{{_authId}}/verify",
          "host": ["{{_auth_prefix}}"],
          "path": ["auth", "{{_authId}}", "verify"]
        }
      }
    },
    {
      "name": "03 - Verify with wrong OTP format (expect INVALID_REQUEST)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Wrong format OTP returns 400', function () { pm.response.to.have.status(400); });",
              "var d = pm.response.json();",
              "pm.test('Error code is INVALID_REQUEST', function () {",
              "    pm.expect(d.errorCode).to.eql('INVALID_REQUEST');",
              "});",
              "console.log('Wrong format OTP response:', JSON.stringify(d));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"otp\": \"12\",\n  \"deviceToken\": \"test-device\"\n}"
        },
        "url": {
          "raw": "{{_auth_prefix}}/auth/{{_authId}}/verify",
          "host": ["{{_auth_prefix}}"],
          "path": ["auth", "{{_authId}}", "verify"]
        }
      }
    },
    {
      "name": "04 - Verify with correct OTP (setup for already-verified test)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Correct OTP returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "pm.test('Response has token', function () { pm.expect(d.token).to.not.be.null; });",
              "console.log('Verified OK, person ID:', d.person && d.person.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"otp\": \"{{login_otp}}\",\n  \"deviceToken\": \"test-device\"\n}"
        },
        "url": {
          "raw": "{{_auth_prefix}}/auth/{{_authId}}/verify",
          "host": ["{{_auth_prefix}}"],
          "path": ["auth", "{{_authId}}", "verify"]
        }
      }
    },
    {
      "name": "05 - Verify already-verified token (expect AUTH_BLOCKED)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Already verified returns 400', function () { pm.response.to.have.status(400); });",
              "var d = pm.response.json();",
              "pm.test('Error code is AUTH_BLOCKED', function () {",
              "    pm.expect(d.errorCode).to.eql('AUTH_BLOCKED');",
              "});",
              "pm.test('Message says Already verified', function () {",
              "    pm.expect(d.errorMessage).to.include('Already verified');",
              "});",
              "console.log('Already verified response:', JSON.stringify(d));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"otp\": \"{{login_otp}}\",\n  \"deviceToken\": \"test-device\"\n}"
        },
        "url": {
          "raw": "{{_auth_prefix}}/auth/{{_authId}}/verify",
          "host": ["{{_auth_prefix}}"],
          "path": ["auth", "{{_authId}}", "verify"]
        }
      }
    },
    {
      "name": "06 - Auth with phone2 (setup for resend tests)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Auth returns 200', function () { pm.response.to.have.status(200); });",
