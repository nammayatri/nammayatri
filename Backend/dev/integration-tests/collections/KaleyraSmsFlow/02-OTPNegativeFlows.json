          "path": ["auth", "otp", "{{_authId2}}", "resend"]
        }
      }
    },
    {
      "name": "09 - Resend OTP (3 of 3, expect attempts=0)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Resend returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "pm.test('Attempts decremented to 0', function () { pm.expect(d.attempts).to.eql(0); });"
            ],
            "type": "text/javascript"
