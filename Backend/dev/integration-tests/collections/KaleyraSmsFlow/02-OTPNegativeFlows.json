      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "" },
        "url": {
          "raw": "{{_auth_prefix}}/auth/otp/{{_authId2}}/resend",
