{
  "info": {
    "name": "PAN-GST Cross-Check Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function r(){ return '9' + Math.floor(100000000 + Math.random()*899999999); }",
          "if(!pm.collectionVariables.get('_test_png')) pm.collectionVariables.set('_test_png','iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==');",
          "['A','B','C'].forEach(function(k){ var key='_test_fleet_'+k; if(!pm.collectionVariables.get(key)) pm.collectionVariables.set(key, r()); });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "A: configure mock Idfy (ABCDE1234F/29ABCDE1234F1Z5)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{mockServerUrl}}/idfy/configure",
          "host": [
            "{{mockServerUrl}}"
          ],
          "path": [
            "idfy",
            "configure"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"panNumber\": \"ABCDE1234F\", \"gstNumber\": \"29ABCDE1234F1Z5\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('mock configured', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "A: Auth sendOTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseURL_namma_P}}/auth",
          "host": [
            "{{baseURL_namma_P}}"
          ],
          "path": [
            "auth"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"mobileNumber\": \"{{_test_fleet_A}}\", \"mobileCountryCode\": \"+91\", \"merchantId\": \"{{merchantId}}\", \"merchantOperatingCity\": \"{{city}}\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('auth sendOTP 200', () => pm.response.to.have.status(200));",
              "pm.collectionVariables.set('authId_A', pm.response.json().authId);"
            ]
          }
        }
      ]
    },
    {
      "name": "A: Auth verify OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseURL_namma_P}}/auth/{{authId_A}}/verify",
          "host": [
            "{{baseURL_namma_P}}"
          ],
          "path": [
            "auth",
            "{{authId_A}}",
            "verify"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"otp\": \"{{login_otp}}\", \"deviceToken\": \"pangst-A\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('verify 200', () => pm.response.to.have.status(200));",
              "var j = pm.response.json();",
              "pm.collectionVariables.set('token_A', j.token);",
              "if (j.person && j.person.id) pm.collectionVariables.set('driverId_A', j.person.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "A: SQL resolve merchant/city",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{mockServerUrl}}/mock/sql/select",
          "host": [
            "{{mockServerUrl}}"
          ],
          "path": [
            "mock",
            "sql",
            "select"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"db_name\": \"atlas_dev\", \"db_schema\": \"atlas_driver_offer_bpp\", \"table_name\": \"person\", \"select\": [\"id\", \"merchant_id\", \"merchant_operating_city_id\", \"role\"], \"where_clause\": [{\"column_name\": \"id\", \"val\": \"{{driverId_A}}\", \"op\": \"=\"}], \"limit\": 1}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('sql select 200', () => pm.response.to.have.status(200));",
              "var rows = (pm.response.json().rows) || [];",
              "pm.test('person row present in PG', () => pm.expect(rows.length).to.be.above(0));",
              "if (rows.length) {",
              "  pm.collectionVariables.set('mid_A', rows[0].merchant_id);",
              "  pm.collectionVariables.set('moc_A', rows[0].merchant_operating_city_id);",
              "}"
            ]
          }
        }
      ]
    },
