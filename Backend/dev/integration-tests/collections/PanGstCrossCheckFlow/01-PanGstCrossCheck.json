          "raw": "{\"db_name\": \"atlas_dev\", \"db_schema\": \"atlas_driver_offer_bpp\", \"table_name\": \"transporter_config\", \"set\": {\"is_gst_pan_link_check_required\": true}, \"touch_updated_at\": true, \"where_clause\": [{\"column_name\": \"merchant_id\", \"val\": \"{{merchantId}}\", \"op\": \"=\"}]}"
