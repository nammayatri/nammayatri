{
	"info": {
		"_postman_id": "helsinki-onboarding-04f-add-vehicle-fleet-probe",
		"name": "Helsinki Onboarding 04F - Add Vehicle (FLEET role probe)",
		"description": "Probes the FLEET-role path: fleet owner calls /fleet/addVehicle with their own token. Informational — captures whether the FLEET role has the AddVehicle permission on this build. Does NOT block the orchestrator on failure.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "01 - FLEET role attempts /fleet/addVehicle",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const code = pm.response.code;",
							"pm.test('Endpoint reachable', () => pm.expect([200, 400, 401, 403, 404, 409]).to.include(code));",
							"console.log('FLEET path /fleet/addVehicle response:', code, pm.response.text().slice(0, 300));",
							"if (code === 200) {",
							"  pm.test('FLEET path works — add-vehicle succeeded as FLEET role', () => true);",
							"} else if (code === 401 || code === 403) {",
							"  console.warn('FLEET role lacks access to /fleet/addVehicle — expected per project notes');",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" },
					{ "key": "token", "value": "{{fleet_owner_token}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\"registrationNo\": \"{{vehicle_reg_no}}-FLEET\", \"vehicleClass\": \"{{vehicle_class}}\", \"colour\": \"Black\", \"model\": \"{{vehicle_model}}\", \"make\": \"{{vehicle_make}}\", \"vehicleCategory\": \"{{vehicle_category}}\"}"
				},
				"url": {
					"raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/fleet/addVehicle?fleetOwnerId={{fleet_owner_id}}",
					"host": ["{{baseURL_BPP_Dashboard_Internal}}"],
					"path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "fleet", "addVehicle"],
					"query": [ { "key": "fleetOwnerId", "value": "{{fleet_owner_id}}" } ]
				}
			}
		}
	]
}
