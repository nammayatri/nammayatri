    {
      "name": "Dashboard: List tolls (verify created)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{dashboard_token}}"
          }
        ],
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/merchant/config/toll/list?limit=200&offset=0",
          "host": [
            "{{baseURL_BPP_Dashboard_Internal}}"
          ],
          "path": [
            "{{dashboard_merchant_id}}",
            "{{dashboard_city}}",
            "merchant",
            "config",
            "toll",
            "list"
          ],
          "query": [
            {
              "key": "limit",
              "value": "200"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var tolls = pm.response.json();",
              "pm.test('List tolls status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('List is array', function () { pm.expect(tolls).to.be.an('array'); });",
              "var name = pm.environment.get('test_toll_name');",
              "var found = tolls.find(function (t) { return t.name === name; });",
              "function classifyGate(g) {",
              "  if (!g || typeof g !== 'object') return 'unknown';",
              "  if (g.type === 'Polygon' && g.coordinates) return 'polygon';",
              "  if (g.type === 'LineString' && g.coordinates) return 'linestring';",
              "  if (g.start && g.end && g.start.lat !== undefined) return 'legacy_linesegment';",
              "  return 'unknown';",
              "}",
              "pm.test('Created toll present', function () { pm.expect(found, 'toll ' + name).to.not.be.undefined; });",
              "if (found) {",
              "  pm.environment.set('test_toll_id', found.id);",
              "  pm.test('Polygon start + LineString end gates', function () {",
              "    pm.expect(found.tollStartGates).to.be.an('array').that.is.not.empty;",
              "    pm.expect(found.tollEndGates).to.be.an('array').that.is.not.empty;",
              "    pm.expect(classifyGate(found.tollStartGates[0])).to.eql('polygon');",
              "    pm.expect(classifyGate(found.tollEndGates[0])).to.eql('linestring');",
              "  });",
              "  console.log('Toll id:', found.id);",
              "}",
              "const _cacheWait = 2000; const _t0 = Date.now(); while (Date.now() - _t0 < _cacheWait) {}"
            ]
          }
        }
      ]
    },
