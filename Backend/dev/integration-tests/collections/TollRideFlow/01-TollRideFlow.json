    {
      "name": "Get Search Results (assert toll)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{rider_token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl_app}}/rideSearch/{{searchId}}/results",
          "host": [
            "{{baseUrl_app}}"
          ],
          "path": [
            "rideSearch",
            "{{searchId}}",
            "results"
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "setTimeout(function(){}, 5000);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json();",
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Has estimates', function () { pm.expect(d.estimates).to.be.an('array').that.is.not.empty; });",
              "var want = pm.environment.get('vehicle_variant') || 'SEDAN';",
              "var tollName = pm.environment.get('test_toll_name');",
              "var cabTiers = ['SEDAN', 'TAXI', 'ECO', 'SUV', 'COMFY', 'SUV_PLUS'];",
              "var withToll = d.estimates.filter(function (e) {",
              "  return e.tollChargesInfo && e.tollChargesInfo.tollNames && e.tollChargesInfo.tollNames.indexOf(tollName) >= 0;",
              "});",
              "console.log('Estimates with tollChargesInfo for', tollName + ':', withToll.map(function (e) { return e.vehicleVariant + '/' + e.serviceTierType; }));",
              "var est = d.estimates.find(function (e) {",
              "  var variantOk = e.vehicleVariant === want || e.vehicleServiceTierType === want;",
              "  var tollOk = e.tollChargesInfo && e.tollChargesInfo.tollNames && e.tollChargesInfo.tollNames.indexOf(tollName) >= 0;",
              "  return variantOk && tollOk;",
              "});",
              "if (!est && withToll.length) {",
              "  est = withToll.find(function (e) { return cabTiers.indexOf(e.vehicleVariant) >= 0 || cabTiers.indexOf(e.vehicleServiceTierType) >= 0; }) || withToll[0];",
              "}",
              "pm.test('Cab estimate includes configured toll', function () {",
              "  pm.expect(withToll.length, 'no estimate had tollChargesInfo for ' + tollName + ' — BPP route likely missed toll gates; check list-toll step and OSRM').to.be.above(0);",
              "  pm.expect(est, want + ' (or other cab) estimate with toll ' + tollName).to.not.be.undefined;",
              "});",
              "if (est) {",
              "  pm.environment.set('estimateId', est.id);",
              "  pm.test('Toll charge amount present', function () {",
              "    pm.expect(est.tollChargesInfo.tollChargesWithCurrency.amount).to.be.at.least(parseFloat(pm.environment.get('toll_test_price')));",
              "  });",
              "  console.log('Estimate with toll:', est.id, est.tollChargesInfo);",
              "}"
            ]
          }
        }
      ]
    },
