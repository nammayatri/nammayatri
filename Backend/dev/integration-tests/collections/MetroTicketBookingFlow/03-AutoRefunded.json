			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Wait for rider-app to create the Juspay payment order",
							"const start = Date.now();",
							"while (Date.now() - start < 3000) { /* busy wait */ }"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"var d = pm.response.json();",
							"console.log('Booking status:', d.status, 'Payment status:', d.payment ? d.payment.status : 'N/A');",
							"if (d.payment && d.payment.paymentOrder) {",
							"    var po = d.payment.paymentOrder;",
							"    pm.environment.set('payment_order_id', po.id || '');",
							"    pm.environment.set('payment_order_short_id', po.order_id || '');",
							"    console.log('Payment order id:', po.id, 'short_id:', po.order_id);",
							"}",
							"pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
							"pm.test('Has payment info', function () {",
							"    pm.expect(d.payment).to.not.be.undefined;",
							"    pm.expect(d.payment.paymentOrder).to.not.be.undefined;",
							"});"
						],
