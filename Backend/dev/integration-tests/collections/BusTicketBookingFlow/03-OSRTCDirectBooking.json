		{
			"name": "Confirm Quote V2",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var ok = pm.response.code >= 200 && pm.response.code < 300;",
							"if (ok) {",
							"    var jsonData = pm.response.json();",
							"    pm.test('Confirm status is 2xx', function () { pm.expect(pm.response.code).to.be.within(200, 299); });",
							"    pm.test('bookingId is a non-empty string', function () { pm.expect(jsonData.bookingId, 'bookingId on FRFSTicketBookingStatusAPIRes').to.be.a('string').and.to.have.lengthOf.above(0); });",
							"    postman.setEnvironmentVariable('frfs_bookingId', jsonData.bookingId);",
							"    console.log('frfs_bookingId saved:', jsonData.bookingId, 'status:', jsonData.status, 'after attempt', pm.environment.get('osrtc_retry_count'));",
							"} else {",
							"    var maxRetries = 5;",
							"    var retryCount = parseInt(pm.environment.get('osrtc_retry_count') || '0', 10);",
							"    var remaining = JSON.parse(pm.environment.get('osrtc_remaining_quotes') || '[]');",
							"    if (retryCount < maxRetries && remaining.length > 0) {",
							"        var next = remaining.shift();",
							"        retryCount += 1;",
							"        console.log('[OSRTC retry ' + retryCount + '] Confirm failed (status=' + pm.response.code + ', body=' + pm.response.text().substring(0, 200) + '). Trying next trip:', next.osrtcTripDetail && next.osrtcTripDetail.intServiceTripDepartureID);",
							"        postman.setEnvironmentVariable('frfs_quoteId', next.quoteId);",
							"        if (next.categories && next.categories.length > 0) postman.setEnvironmentVariable('frfs_quote_category_id', next.categories[0].categoryId);",
							"        var trip = next.osrtcTripDetail;",
							"        if (trip) {",
							"            postman.setEnvironmentVariable('osrtc_service_trip_departure_id', String(trip.intServiceTripDepartureID));",
							"            postman.setEnvironmentVariable('osrtc_from_station_id', String(trip.intFromStationID));",
							"            postman.setEnvironmentVariable('osrtc_to_station_id', String(trip.intToStationID));",
							"            var menFare = (trip.Fare || []).find(function (f) { return f.intTicketCategoryID === 3; });",
							"            var pickedFare = menFare || (trip.Fare && trip.Fare[0]);",
							"            if (pickedFare) {",
							"                postman.setEnvironmentVariable('osrtc_ticket_category_id', String(pickedFare.intTicketCategoryID));",
							"                postman.setEnvironmentVariable('osrtc_seat_type_id', String(pickedFare.intSeatTypeID));",
							"            }",
							"        }",
							"        postman.setEnvironmentVariable('osrtc_remaining_quotes', JSON.stringify(remaining));",
							"        postman.setEnvironmentVariable('osrtc_retry_count', String(retryCount));",
							"        postman.setNextRequest('OSRTC Seat Availability');",
							"    } else {",
							"        var why = remaining.length === 0 ? 'all quotes exhausted' : 'max retries (' + maxRetries + ') hit';",
							"        pm.test('Confirm status is 2xx (after retries)', function () { throw new Error('OSRTC retry loop exhausted (' + why + '). Last status: ' + pm.response.code + ', body: ' + pm.response.text().substring(0, 300)); });",
							"    }",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "token", "value": "{{customer_token}}", "type": "text" }],
				"body": {
					"mode": "raw",
