					"listen": "prerequest",
					"script": {
						"exec": [
							"var t = pm.environment.get('customer_token');",
							"if (!t || t.length === 0) { throw new Error('customer_token is empty — Auth/Verify must succeed before this idempotency test'); }",
							"var bid = pm.environment.get('frfs_bookingId');",
							"if (!bid || bid.length === 0) { throw new Error('frfs_bookingId is empty — Confirm Quote V2 must succeed first, otherwise this test cannot distinguish a 400 from missing booking vs CANCEL_INITIATED'); }"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"var status = pm.environment.get('frfs_booking_status') || '';",
							"pm.test('Second cancel returns 400', function () { pm.response.to.have.status(400); });",
							"var d = pm.response.json();",
							"if (status === 'CONFIRMED') {",
							"    pm.test('Error is INVALID_REQUEST with CANCEL_INITIATED message', function () {",
