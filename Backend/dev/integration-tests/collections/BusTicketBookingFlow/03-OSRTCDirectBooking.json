		{
			"name": "Get Booking Status (Confirmed)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const start = Date.now(); while (Date.now() - start < 1500) {} // small gap between polls",
								"if (!pm.environment.get('frfs_status_poll_count')) { pm.environment.set('frfs_status_poll_count', '0'); }"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"var d = pm.response.json();",
							"pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
							"var status = d.status || '';",
							"var count = parseInt(pm.environment.get('frfs_status_poll_count') || '0', 10);",
							"var pnr = (d.tickets && d.tickets[0] && d.tickets[0].ticketNumber) || d.bppOrderId || '(none yet)';",
							"console.log('Booking status:', status, 'PNR:', pnr, 'poll attempt:', count);",
							"var terminal = ['CONFIRMED', 'FAILED', 'CANCELLED'];",
							"if (terminal.indexOf(status) === -1 && count < 10) {",
							"    pm.environment.set('frfs_status_poll_count', String(count + 1));",
							"    postman.setNextRequest('Get Booking Status (Confirmed)');",
							"} else {",
							"    postman.setEnvironmentVariable('frfs_booking_status', status);",
							"    pm.environment.unset('frfs_status_poll_count');",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
