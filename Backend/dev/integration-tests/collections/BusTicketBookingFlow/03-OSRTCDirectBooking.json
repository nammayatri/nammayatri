{
	"info": {
		"_postman_id": "c7d8e9f0-1234-5678-9abc-def012345678",
		"name": "OSRTC Direct Bus Booking",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"description": "OSRTC (Odisha State RTC) FRFS bus booking flow. Exercises the OSRTC-specific endpoints: stations, seat availability, fare calculation, refund preview, cancel, tracking — wrapped around the standard FRFS search/quote/confirm spine."
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Skip this collection unless paired with the OSRTC env (Bhubaneshwar + PARTNERORG).",
					"// The runner iterates every env in BusTicketBookingFlow/ against every collection;",
					"// without this guard, OSRTC tests run against Chennai / plain Bhubaneshwar envs that",
					"// don't have an OSRTC integratedBPPConfig and fail in confusing ways.",
					"var city = pm.environment.get('city');",
					"var platform = pm.environment.get('platform_type');",
					"if (city !== 'Bhubaneshwar' || platform !== 'PARTNERORG') {",
					"    console.log('[OSRTC] Skipping — env is city=' + city + ' platform=' + platform + ' (need Bhubaneshwar/PARTNERORG)');",
					"    pm.execution.setNextRequest(null);",
					"    return;",
					"}",
					"// Per Rules.md: generate a fresh rider mobile per run at the collection level.",
					"// 10 digits, all numeric — passes the /auth mobileNumber regex /^[0-9]*$/ with length 5–15.",
					"if (!pm.collectionVariables.get('_test_rider_number')) {",
					"    var rNum = '7' + String(Math.floor(100000000 + Math.random() * 899999999));",
					"    pm.collectionVariables.set('_test_rider_number', rNum);",
					"    // OSRTC enforces MOBILE_MISMATCH between rider profile mobile and passenger mobile,",
					"    // so the passenger mobile must equal the mobile we authed with.",
					"    pm.environment.set('osrtc_passenger_mobile', rNum);",
					"    // OSRTC requires an email on the rider profile (EMAIL_REQUIRED_FOR_OSRTC). Use a unique-per-run",
					"    // email so concurrent runs don't collide on the email-uniqueness check in /profile.",
					"    pm.environment.set('osrtc_passenger_email', 'osrtc-test-' + rNum + '@nammayatri.in');",
					"    console.log('[OSRTC] Test rider mobile:', rNum, 'email:', pm.environment.get('osrtc_passenger_email'));",
					"}",
					"// Compute every run (not behind the rider-number guard) so a long-running newman session",
					"// doesn't end up reusing a stale 'tomorrow' that's now 'today'.",
					"// 2 days out at 08:00 UTC — far enough that OSRTC always has trips, close enough to be deterministic.",
					"var jd = new Date();",
					"jd.setUTCDate(jd.getUTCDate() + 2);",
					"jd.setUTCHours(8, 0, 0, 0);",
					"pm.environment.set('osrtc_journey_date', jd.toISOString());",
					"console.log('[OSRTC] Journey date:', jd.toISOString());"
				]
			}
		}
	],
	"item": [
