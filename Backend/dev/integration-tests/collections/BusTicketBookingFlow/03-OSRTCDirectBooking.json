							"pm.test('authId is a non-empty string', function () {",
							"    pm.expect(response.authId, 'authId').to.be.a('string').and.to.have.lengthOf.above(0);",
							"});",
							"postman.setEnvironmentVariable('authId', response.authId);",
							"console.log('authId saved:', response.authId);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
