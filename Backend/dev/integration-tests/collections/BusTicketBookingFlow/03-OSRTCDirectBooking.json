		{
			"name": "OSRTC Get Stations",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"var t = pm.environment.get('customer_token');",
							"if (!t || t.length === 0) { throw new Error('customer_token is empty — Auth/Verify must succeed before OSRTC Get Stations'); }"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
							"var jsonData = pm.response.json();",
							"pm.test('Response is an array with at least 2 stations', function () {",
							"    pm.expect(jsonData).to.be.an('array').and.to.have.lengthOf.above(1);",
							"});",
							"// Coverage check only — start_stop_code / end_stop_code are hardcoded in the env to canonical OSRTC IDs",
							"// (Bhubaneswar=2, Puri=66) per dev/.cursor/docs/19-osrtc-flow.md. Picking 'first/last alphabetical' from",
							"// this list would land on station pairs OSRTC may not service, leading to empty quotes downstream.",
							"console.log('OSRTC stations endpoint returned ' + jsonData.length + ' stations; first=' + jsonData[0].intStationId + ' last=' + jsonData[jsonData.length - 1].intStationId + '. Search will use env-configured ' + pm.environment.get('start_stop_code') + ' → ' + pm.environment.get('end_stop_code') + '.');"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [{ "key": "token", "value": "{{customer_token}}", "type": "text" }],
				"url": {
					"raw": "{{baseUrl_app}}/frfs/osrtc/stations?vehicleType=\"{{vehicle_type}}\"&city={{city}}&platformType=\"{{platform_type}}\"",
					"host": ["{{baseUrl_app}}"],
					"path": ["frfs", "osrtc", "stations"],
					"query": [
						{ "key": "vehicleType", "value": "\"{{vehicle_type}}\"" },
						{ "key": "city", "value": "{{city}}" },
						{ "key": "platformType", "value": "\"{{platform_type}}\"" }
					]
				}
			},
			"response": []
		},
		{
			"name": "FRFS Autocomplete (Select OSRTC Route)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
							"var jsonData = pm.response.json();",
							"// OSRTC is a direct-API integration: routes aren't usually returned here.",
							"// Stations may or may not appear depending on whether the GTFS feed has them under this query.",
							"// We don't depend on this for booking — integrated_bpp_config_id is fixed in the env.",
							"// If a route IS returned, prefer it for route_code (helps cover regression if OSRTC ever gets GTFS routes).",
							"if (jsonData.routes && jsonData.routes.length) {",
							"    postman.setEnvironmentVariable('route_code', jsonData.routes[0].code);",
							"    console.log('OSRTC autocomplete route:', jsonData.routes[0].code);",
							"} else {",
							"    console.log('OSRTC autocomplete returned no routes (expected for direct-API OSRTC); using empty route_code.');",
							"    postman.setEnvironmentVariable('route_code', '');",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [{ "key": "token", "value": "{{customer_token}}", "type": "text" }],
				"url": {
					"raw": "{{baseUrl_app}}/frfs/autocomplete?vehicleType=\"{{vehicle_type}}\"&city={{city}}&location={{origin_lat}},{{origin_lon}}&input=A&limit=10&offset=0&platformType=\"{{platform_type}}\"",
					"host": ["{{baseUrl_app}}"],
					"path": ["frfs", "autocomplete"],
					"query": [
						{ "key": "vehicleType", "value": "\"{{vehicle_type}}\"" },
						{ "key": "city", "value": "{{city}}" },
						{ "key": "location", "value": "{{origin_lat}},{{origin_lon}}" },
						{ "key": "input", "value": "A" },
						{ "key": "limit", "value": "10" },
						{ "key": "offset", "value": "0" },
						{ "key": "platformType", "value": "\"{{platform_type}}\"" }
					]
				}
			},
			"response": []
		},
		{
			"name": "FRFS Search (OSRTC)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.test('searchId returned', function () { pm.expect(jsonData.searchId).to.be.a('string'); });",
							"postman.setEnvironmentVariable('frfs_searchId', jsonData.searchId);",
							"pm.test('At least one OSRTC quote returned', function () { pm.expect(jsonData.quotes, 'quotes').to.be.an('array').and.to.have.lengthOf.above(0); });",
							"function setQuoteEnv(q) {",
							"    postman.setEnvironmentVariable('frfs_quoteId', q.quoteId);",
							"    if (q.categories && q.categories.length > 0) postman.setEnvironmentVariable('frfs_quote_category_id', q.categories[0].categoryId);",
							"    var trip = q.osrtcTripDetail;",
							"    if (!trip) return;",
							"    postman.setEnvironmentVariable('osrtc_service_trip_departure_id', String(trip.intServiceTripDepartureID));",
							"    postman.setEnvironmentVariable('osrtc_from_station_id', String(trip.intFromStationID));",
							"    postman.setEnvironmentVariable('osrtc_to_station_id', String(trip.intToStationID));",
							"    var menFare = (trip.Fare || []).find(function (f) { return f.intTicketCategoryID === 3; });",
							"    var pickedFare = menFare || (trip.Fare && trip.Fare[0]);",
							"    if (pickedFare) {",
							"        postman.setEnvironmentVariable('osrtc_ticket_category_id', String(pickedFare.intTicketCategoryID));",
							"        postman.setEnvironmentVariable('osrtc_seat_type_id', String(pickedFare.intSeatTypeID));",
							"    }",
							"    console.log('OSRTC pick trip:', trip.intServiceTripDepartureID);",
							"}",
							"if (jsonData.quotes && jsonData.quotes.length > 0) {",
							"    var quotes = jsonData.quotes.slice();",
							"    var first = quotes.shift();",
							"    pm.test('first osrtcTripDetail is present', function () { pm.expect(first.osrtcTripDetail, 'osrtcTripDetail').to.be.an('object'); });",
							"    setQuoteEnv(first);",
							"    postman.setEnvironmentVariable('osrtc_remaining_quotes', JSON.stringify(quotes));",
							"    postman.setEnvironmentVariable('osrtc_retry_count', '0');",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "token", "value": "{{customer_token}}", "type": "text" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"fromStationCode\": \"{{start_stop_code}}\",\n    \"toStationCode\": \"{{end_stop_code}}\",\n    \"routeCode\": \"{{route_code}}\",\n    \"quantity\": 1,\n    \"platformType\": \"{{platform_type}}\",\n    \"journeyDate\": \"{{osrtc_journey_date}}\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "{{baseUrl_app}}/frfs/search?vehicleType=\"{{vehicle_type}}\"&city={{city}}",
					"host": ["{{baseUrl_app}}"],
					"path": ["frfs", "search"],
					"query": [
						{ "key": "vehicleType", "value": "\"{{vehicle_type}}\"" },
						{ "key": "city", "value": "{{city}}" }
					]
				}
			},
			"response": []
		},
		{
			"name": "OSRTC Seat Availability",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
							"pm.test('Has availability data', function () {",
							"    pm.expect(jsonData.totalCount).to.be.a('number');",
							"    pm.expect(jsonData.availableCount).to.be.a('number');",
							"});",
							"pm.test('Seat list is a non-empty array', function () { pm.expect(jsonData.seats).to.be.an('array').and.to.have.lengthOf.above(0); });",
							"var passengerSeats = (jsonData.seats || []).filter(function (s) { return s.isAvailable === true && s.layoutComponentID === 3; });",
							"pm.test('At least one bookable passenger seat', function () { pm.expect(passengerSeats, 'no bookable seats from seatAvailability — picked trip has no usable inventory; check backend mkOSRTCQuote vacentSeats filter').to.have.lengthOf.above(0); });",
							"var pick = passengerSeats[0];",
							"postman.setEnvironmentVariable('osrtc_seat_code', pick.seatCode);",
							"postman.setEnvironmentVariable('osrtc_seat_no',   pick.seatSrNo);",
							"postman.setEnvironmentVariable('osrtc_seat_type_id',  String(pick.seatTypeID));",
							"postman.setEnvironmentVariable('osrtc_berth_type_id', String(pick.berthTypeID));",
							"console.log('Picked OSRTC seat: code=' + pick.seatCode + ' srNo=' + pick.seatSrNo + ' typeID=' + pick.seatTypeID + ' berthID=' + pick.berthTypeID);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "token", "value": "{{customer_token}}", "type": "text" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"serviceTripDepartureId\": {{osrtc_service_trip_departure_id}},\n    \"fromStationId\": {{osrtc_from_station_id}},\n    \"toStationId\": {{osrtc_to_station_id}}\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "{{baseUrl_app}}/frfs/osrtc/:searchId/seatAvailability",
					"host": ["{{baseUrl_app}}"],
					"path": ["frfs", "osrtc", ":searchId", "seatAvailability"],
					"variable": [{ "key": "searchId", "value": "{{frfs_searchId}}" }]
				}
			},
			"response": []
		},
		{
			"name": "OSRTC Fare Calculation",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
							"pm.test('Fare totals present and numeric', function () {",
							"    pm.expect(jsonData.totalFinalAmount).to.be.a('number').and.to.be.above(0);",
							"    pm.expect(jsonData.totalBaseFare).to.be.a('number').and.to.be.above(0);",
							"    pm.expect(jsonData.totalDiscount).to.be.a('number');",
							"});",
							"// OSRTC fareBreakdown is multi-component (base + tolls + ...). Don't assert a 2-term equation;",
							"// just verify the breakdown rows sum to totalFinalAmount minus any discount.",
							"pm.test('Fare breakdown sums to totalFinalAmount', function () {",
							"    var rows = jsonData.fareBreakdown || [];",
							"    var sum = rows.reduce(function (acc, r) { return acc + Number(r.decComponentWiseTotalFare || 0); }, 0);",
							"    var expected = Number(jsonData.totalFinalAmount) + Number(jsonData.totalDiscount || 0);",
							"    pm.expect(Math.abs(sum - expected)).to.be.lessThan(0.01);",
							"});",
							"console.log('OSRTC fare:', jsonData.totalFinalAmount);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "token", "value": "{{customer_token}}", "type": "text" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"serviceTripDepartureId\": {{osrtc_service_trip_departure_id}},\n    \"fromStationId\": {{osrtc_from_station_id}},\n    \"toStationId\": {{osrtc_to_station_id}},\n    \"passengerName\": \"{{osrtc_passenger_name}}\",\n    \"email\": \"{{osrtc_passenger_email}}\",\n    \"mobileNo\": \"{{osrtc_passenger_mobile}}\",\n    \"seats\": [\n        {\n            \"srNo\": 1,\n            \"selectedSeatCode\": \"{{osrtc_seat_code}}\",\n            \"selectedSeatNo\": \"{{osrtc_seat_no}}\",\n            \"seatTypeId\": {{osrtc_seat_type_id}},\n            \"ticketCategoryId\": {{osrtc_ticket_category_id}}\n        }\n    ],\n    \"perSeatPassengers\": [\n        {\n            \"srNo\": 1,\n            \"selectedSeatCode\": \"{{osrtc_seat_code}}\",\n            \"selectedSeatNo\": \"{{osrtc_seat_no}}\",\n            \"seatTypeId\": {{osrtc_seat_type_id}},\n            \"berthTypeId\": {{osrtc_berth_type_id}},\n            \"ticketCategoryId\": {{osrtc_ticket_category_id}},\n            \"passengerName\": \"{{osrtc_passenger_name}}\",\n            \"age\": 30,\n            \"gender\": 1,\n            \"mobileNo\": \"{{osrtc_passenger_mobile}}\"\n        }\n    ]\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "{{baseUrl_app}}/frfs/osrtc/:searchId/fareCalculation",
					"host": ["{{baseUrl_app}}"],
					"path": ["frfs", "osrtc", ":searchId", "fareCalculation"],
					"variable": [{ "key": "searchId", "value": "{{frfs_searchId}}" }]
				}
			},
			"response": []
		},
		{
			"name": "OSRTC Fare Calc Validation: > 8 seats rejected",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"var t = pm.environment.get('customer_token');",
							"if (!t || t.length === 0) { throw new Error('customer_token is empty — Auth/Verify must succeed before this negative test'); }",
							"var sid = pm.environment.get('frfs_searchId');",
							"if (!sid || sid.length === 0) { throw new Error('frfs_searchId is empty — FRFS Search must succeed first, otherwise this test cannot distinguish a 400 from missing context vs > 8 seats'); }"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Returns 400 when more than 8 seats requested', function () {",
							"    pm.response.to.have.status(400);",
							"});",
							"var d = pm.response.json();",
							"pm.test('Error is INVALID_REQUEST with > 8 seats message', function () {",
							"    pm.expect(d.errorCode).to.equal('INVALID_REQUEST');",
							"    pm.expect(String(d.errorMessage || '')).to.include('Maximum 8 seats');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "token", "value": "{{customer_token}}", "type": "text" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"serviceTripDepartureId\": {{osrtc_service_trip_departure_id}},\n    \"fromStationId\": {{osrtc_from_station_id}},\n    \"toStationId\": {{osrtc_to_station_id}},\n    \"passengerName\": \"{{osrtc_passenger_name}}\",\n    \"email\": \"{{osrtc_passenger_email}}\",\n    \"mobileNo\": \"{{osrtc_passenger_mobile}}\",\n    \"seats\":             [{\"srNo\":1,\"selectedSeatCode\":\"S1\",\"selectedSeatNo\":\"1\",\"seatTypeId\":1,\"ticketCategoryId\":1},{\"srNo\":2,\"selectedSeatCode\":\"S2\",\"selectedSeatNo\":\"2\",\"seatTypeId\":1,\"ticketCategoryId\":1},{\"srNo\":3,\"selectedSeatCode\":\"S3\",\"selectedSeatNo\":\"3\",\"seatTypeId\":1,\"ticketCategoryId\":1},{\"srNo\":4,\"selectedSeatCode\":\"S4\",\"selectedSeatNo\":\"4\",\"seatTypeId\":1,\"ticketCategoryId\":1},{\"srNo\":5,\"selectedSeatCode\":\"S5\",\"selectedSeatNo\":\"5\",\"seatTypeId\":1,\"ticketCategoryId\":1},{\"srNo\":6,\"selectedSeatCode\":\"S6\",\"selectedSeatNo\":\"6\",\"seatTypeId\":1,\"ticketCategoryId\":1},{\"srNo\":7,\"selectedSeatCode\":\"S7\",\"selectedSeatNo\":\"7\",\"seatTypeId\":1,\"ticketCategoryId\":1},{\"srNo\":8,\"selectedSeatCode\":\"S8\",\"selectedSeatNo\":\"8\",\"seatTypeId\":1,\"ticketCategoryId\":1},{\"srNo\":9,\"selectedSeatCode\":\"S9\",\"selectedSeatNo\":\"9\",\"seatTypeId\":1,\"ticketCategoryId\":1}],\n    \"perSeatPassengers\": [{\"srNo\":1,\"selectedSeatCode\":\"S1\",\"selectedSeatNo\":\"1\",\"seatTypeId\":1,\"berthTypeId\":1,\"ticketCategoryId\":1,\"passengerName\":\"P1\",\"age\":30,\"gender\":1,\"mobileNo\":\"{{osrtc_passenger_mobile}}\"},{\"srNo\":2,\"selectedSeatCode\":\"S2\",\"selectedSeatNo\":\"2\",\"seatTypeId\":1,\"berthTypeId\":1,\"ticketCategoryId\":1,\"passengerName\":\"P2\",\"age\":30,\"gender\":1,\"mobileNo\":\"{{osrtc_passenger_mobile}}\"},{\"srNo\":3,\"selectedSeatCode\":\"S3\",\"selectedSeatNo\":\"3\",\"seatTypeId\":1,\"berthTypeId\":1,\"ticketCategoryId\":1,\"passengerName\":\"P3\",\"age\":30,\"gender\":1,\"mobileNo\":\"{{osrtc_passenger_mobile}}\"},