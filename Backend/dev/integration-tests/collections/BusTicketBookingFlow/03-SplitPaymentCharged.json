    {
      "name": "Override Juspay Status (CHARGED + split txn_list)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Build a CHARGED Juspay order_status override carrying TWO txn_list entries:",
              "//   1. UPI / UPI_PAY (effective_amount 5)",
              "//   2. REWARD / LOYALTYOS7 (effective_amount 8)",
              "// mirroring the real split-payment response (Rs 5 paid via UPI + Rs 8 redeemed in loyalty points = Rs 13).",
              "// Per-txn fields (payment_method, payment_method_type, txn_uuid) live ONLY inside txn_list — this proves the iteration uses per-txn fields, not the top-level order fields.",
              "if (!pm.collectionVariables.get('_test_txn_uuid_upi')) {",
              "    pm.collectionVariables.set('_test_txn_uuid_upi', 'splitUPI-' + Math.random().toString(36).slice(2, 12));",
              "    pm.collectionVariables.set('_test_txn_uuid_reward', 'splitREW-' + Math.random().toString(36).slice(2, 12));",
              "}",
              "var nowIso = new Date().toISOString();",
              "var paymentShort = pm.environment.get('payment_order_short_id') || '';",
              "var paymentId = pm.environment.get('payment_order_id') || '';",
              "var body = {",
              "    service: 'juspay',",
              "    id: [paymentShort, paymentId],",
              "    status: 'CHARGED',",
              "    data: {",
              "        amount: 13.0,",
              "        effective_amount: 13.0,",
              "        currency: 'INR',",
              "        payment_method_type: 'UPI',",
              "        payment_method: 'UPI_PAY',",
              "        date_created: nowIso,",
              "        last_updated: nowIso,",
              "        txn_uuid: pm.collectionVariables.get('_test_txn_uuid_upi'),",
              "        txn_id: 'CUMTA-' + paymentShort + '-1-1',",
              "        txn_list: [",
              "            {",
              "                txn_id: 'CUMTA-' + paymentShort + '-1-1',",
              "                payment_method_type: 'UPI',",
              "                payment_method: 'UPI_PAY',",
              "                refunded: false,",
              "                effective_amount: 5,",
              "                resp_code: null,",
              "                resp_message: null,",
              "                bank_error_code: '',",
              "                bank_error_message: '',",
              "                txn_uuid: pm.collectionVariables.get('_test_txn_uuid_upi'),",
              "                txn_detail: {",
              "                    txn_id: 'CUMTA-' + paymentShort + '-1-1',",
              "                    order_id: paymentShort,",
              "                    status: 'CHARGED',",
              "                    net_amount: 13,",
              "                    txn_amount: 5,",
              "                    gateway: 'DUMMY',",
              "                    gateway_id: 100,",
              "                    surcharge_amount: null,",
              "                    tax_amount: null,",
              "                    currency: 'INR',",
              "                    txn_flow_type: 'INTENT',",
              "                    created: nowIso,",
              "                    last_updated: nowIso,",
              "                    txn_uuid: pm.collectionVariables.get('_test_txn_uuid_upi')",
              "                },",
              "                payment_gateway_response: {",
              "                    resp_code: null,",
              "                    resp_message: null,",
              "                    created: nowIso,",
              "                    epg_txn_id: 'DUMMY-CUMTA-' + paymentShort + '-1-1',",
              "                    auth_id_code: '795460',",
              "                    txn_id: null,",
              "                    rrn: null",
              "                },",
              "                gateway_id: 100,",
              "                gateway_reference_id: null,",
              "                payer_app_name: 'tez://upi/pay',",
              "                status: 'CHARGED',",
              "                offers: []",
              "            },",
              "            {",
              "                txn_id: 'CUMTA-' + paymentShort + '-1-2',",
              "                payment_method_type: 'REWARD',",
              "                payment_method: 'LOYALTYOS7',",
              "                refunded: false,",
              "                effective_amount: 8,",
              "                resp_code: null,",
              "                resp_message: null,",
              "                bank_error_code: '',",
              "                bank_error_message: '',",
              "                txn_uuid: pm.collectionVariables.get('_test_txn_uuid_reward'),",
              "                txn_detail: {",
              "                    txn_id: 'CUMTA-' + paymentShort + '-1-2',",
              "                    order_id: paymentShort,",
              "                    status: 'CHARGED',",
              "                    net_amount: 13,",
              "                    txn_amount: 8,",
              "                    gateway: 'LOYALTY_OS',",
              "                    gateway_id: 1207,",
              "                    surcharge_amount: null,",
              "                    tax_amount: null,",
              "                    currency: 'INR',",
              "                    txn_flow_type: 'DIRECT_DEBIT',",
              "                    created: nowIso,",
              "                    last_updated: nowIso,",
              "                    txn_uuid: pm.collectionVariables.get('_test_txn_uuid_reward')",
              "                },",
              "                payment_gateway_response: {",
              "                    resp_code: 'SUCCESS',",
              "                    resp_message: 'Reward redemption successful',",
              "                    created: nowIso,",
              "                    epg_txn_id: null,",
              "                    auth_id_code: null,",
              "                    txn_id: 'CUMTA-' + paymentShort + '-1-2',",
              "                    rrn: null",
              "                },",
              "                gateway_id: 1207,",
              "                gateway_reference_id: null,",
              "                status: 'CHARGED',",
              "                offers: []",
              "            }",
              "        ]",
              "    }",
              "};",
              "pm.environment.set('_mock_status_body', JSON.stringify(body));"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json();",
              "pm.test('Mock override accepted', function () {",
              "    pm.response.to.have.status(200);",
              "    pm.expect(d.ok).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{{_mock_status_body}}" },
        "url": {
          "raw": "{{mockServerUrl}}/mock/status",
          "host": ["{{mockServerUrl}}"],
          "path": ["mock", "status"]
        }
      },
      "response": []
    },
    {
      "name": "Trigger Payment Status (orderStatusService)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const s = Date.now(); while (Date.now() - s < 1500) { /* settle override */ }"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json();",
              "console.log('Payment status:', d.status, 'orderId:', d.orderId);",
              "// d.orderId is the internal payment_order UUID — the foreign key used by payment_transaction.order_id.",
              "// (d.payment.paymentOrder.id captured earlier is the Juspay service order id, NOT this.)",
              "if (d.orderId) pm.environment.set('test_payment_order_uuid', d.orderId);",
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Payment is CHARGED', function () { pm.expect(d.status).to.eql('CHARGED'); });",
              "pm.test('Internal payment_order UUID captured', function () { pm.expect(d.orderId).to.be.a('string'); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "token", "value": "{{customer_token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl_app}}/payment/:orderId/status",
          "host": ["{{baseUrl_app}}"],
          "path": ["payment", ":orderId", "status"],
          "variable": [{ "key": "orderId", "value": "{{payment_order_short_id}}" }]
        }
      },
      "response": []
    },
