    {
      "name": "Booking Status (Confirmed + Ticket)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const s = Date.now(); while (Date.now() - s < 5000) { /* wait for BPP confirm */ }"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json();",
              "console.log('Booking status:', d.status, 'Tickets:', d.tickets ? d.tickets.length : 0);",
              "if (d.tickets && d.tickets[0]) pm.environment.set('ticket_qr_data', d.tickets[0].qrData);",
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Booking is CONFIRMED', function () { pm.expect(d.status).to.equal('CONFIRMED'); });",
              "pm.test('Has tickets', function () { pm.expect(d.tickets).to.be.an('array').that.is.not.empty; });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "token", "value": "{{customer_token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl_app}}/frfs/booking/:bookingId/status",
          "host": ["{{baseUrl_app}}"],
          "path": ["frfs", "booking", ":bookingId", "status"],
          "variable": [{ "key": "bookingId", "value": "{{frfs_bookingId}}" }]
        }
      },
      "response": []
    },
    {
      "name": "Verify payment_transaction Rows (Split txns persisted)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const s = Date.now(); while (Date.now() - s < 2000) { /* settle KV drainer */ }"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "var rows = d.rows || [];",
              "var uuids = rows.map(function (r) { return r.txn_uuid; });",
              "console.log('Found txn_uuids:', JSON.stringify(uuids));",
              "var txnUpi = pm.collectionVariables.get('_test_txn_uuid_upi');",
              "var txnRew = pm.collectionVariables.get('_test_txn_uuid_reward');",
              "pm.test('Two rows inserted (one per txn_list entry)', function () {",
              "    pm.expect(d.count, 'row count').to.eql(2);",
              "});",
              "pm.test('UPI txn_uuid present', function () { pm.expect(uuids).to.include(txnUpi); });",
              "pm.test('Reward txn_uuid present', function () { pm.expect(uuids).to.include(txnRew); });",
              "pm.test('Per-txn payment_method preserved (not top-level)', function () {",
              "    var byUuid = {};",
              "    rows.forEach(function (r) { byUuid[r.txn_uuid] = r; });",
              "    pm.expect(byUuid[txnUpi].payment_method).to.eql('UPI_PAY');",
              "    pm.expect(byUuid[txnUpi].payment_method_type).to.eql('UPI');",
              "    pm.expect(byUuid[txnRew].payment_method).to.eql('LOYALTYOS7');",
              "    pm.expect(byUuid[txnRew].payment_method_type).to.eql('REWARD');",
              "});",
              "pm.test('Per-txn effective amounts preserved (5 + 8)', function () {",
              "    var byUuid = {};",
              "    rows.forEach(function (r) { byUuid[r.txn_uuid] = r; });",
              "    pm.expect(Number(byUuid[txnUpi].amount)).to.eql(5);",
              "    pm.expect(Number(byUuid[txnRew].amount)).to.eql(8);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"db_name\": \"atlas_dev\",\n  \"db_schema\": \"atlas_app\",\n  \"table_name\": \"payment_transaction\",\n  \"select\": [\"txn_uuid\", \"txn_id\", \"status\", \"payment_method\", \"payment_method_type\", \"amount\"],\n  \"where_clause\": [\n    {\"column_name\": \"order_id\", \"val\": \"{{test_payment_order_uuid}}\", \"op\": \"=\"},\n    {\"column_name\": \"status\", \"val\": \"CHARGED\", \"op\": \"=\"}\n  ]\n}"
        },
        "url": {
          "raw": "{{mockServerUrl}}/mock/sql/select",
          "host": ["{{mockServerUrl}}"],
          "path": ["mock", "sql", "select"]
        }
      },
      "response": []
    },
    {
      "name": "Verify Ticket",
      "request": {
        "method": "POST",
        "header": [
          { "key": "token", "value": "{{customer_token}}", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"qrData\": \"{{ticket_qr_data}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl_app}}/frfs/ticket/verify?vehicleType=\"BUS\"&city={{city}}&platformType=\"{{platform_type}}\"",
          "host": ["{{baseUrl_app}}"],
          "path": ["frfs", "ticket", "verify"],
          "query": [
            { "key": "vehicleType", "value": "\"BUS\"" },
            { "key": "city", "value": "{{city}}" },
            { "key": "platformType", "value": "\"{{platform_type}}\"" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Verify Ticket Status",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const s = Date.now(); while (Date.now() - s < 2000) {}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json();",
              "console.log('Booking status:', d.status);",
              "if (d.tickets && d.tickets.length > 0) console.log('Ticket status:', d.tickets[0].status);",
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Ticket is USED', function () {",
              "    pm.expect(d.tickets).to.be.an('array').that.is.not.empty;",
              "    pm.expect(d.tickets[0].status).to.equal('USED');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "token", "value": "{{customer_token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl_app}}/frfs/booking/:bookingId/status",
          "host": ["{{baseUrl_app}}"],
          "path": ["frfs", "booking", ":bookingId", "status"],
          "variable": [{ "key": "bookingId", "value": "{{frfs_bookingId}}" }]
        }
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "exec": [
          "// Auto-skip mock-server requests when envType is not Local.",
          "(function () {",
          "  var envType = pm.environment.get('envType') || 'Local';",
          "  if (envType === 'Local') return;",
          "  var raw = (pm.request && pm.request.url && pm.request.url.toString()) || '';",
          "  if (raw.indexOf('mockServerUrl') !== -1 || raw.indexOf('mock_fcm_url') !== -1) {",
          "    console.log('[skip] mock-only request on envType=' + envType + ': ' + (pm.info && pm.info.requestName));",
          "    if (pm.execution && typeof pm.execution.skipRequest === 'function') {",
          "      pm.execution.skipRequest();",
          "    }",
          "  }",
          "})();",
          "",
          "if (!pm.collectionVariables.get('_test_rider_number')) {",
          "    var rNum = '7' + String(Math.floor(100000000 + Math.random() * 899999999));",
          "    pm.collectionVariables.set('_test_rider_number', rNum);",
          "    console.log('Test rider:', rNum);",
          "}"
        ]
      }
