{
  "info": {
    "_postman_id": "driver-onboarding-flow-ny-bangalore",
    "name": "Driver Onboarding Flow",
    "description": "End-to-end driver onboarding: auth, DL upload/register, RC upload/register, vehicle add, and driver enable. Covers the standard (non-BOT) onboarding path via the provider dashboard. Uses a randomly generated mobile number each run.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "if (!pm.environment.get('_driver_mobile')) {",
          "  const r = Math.floor(Math.random() * 900000000) + 100000000;",
          "  pm.environment.set('_driver_mobile', String(r));",
          "  const alpha = 'abcdefghijklmnopqrstuvwxyz';",
          "  let suffix = '';",
          "  for (let i = 0; i < 6; i++) suffix += alpha[Math.floor(Math.random() * 26)];",
          "  pm.environment.set('_driver_reg_no', 'KA01NY' + String(Math.floor(Math.random() * 9000) + 1000));",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "01 - Driver Auth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "pm.expect(d.authId).to.be.a('string');",
              "pm.environment.set('driver_authId', d.authId);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"mobileNumber\": \"{{_driver_mobile}}\", \"mobileCountryCode\": \"+91\", \"merchantId\": \"{{driver_merchant_id}}\", \"merchantOperatingCity\": \"{{city}}\"}"
        },
        "url": {
          "raw": "{{baseURL_namma_P}}/auth",
          "host": ["{{baseURL_namma_P}}"],
          "path": ["auth"]
        }
      }
    },
    {
      "name": "02 - Driver OTP Verify",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "pm.expect(d.token).to.be.a('string');",
              "pm.environment.set('driver_token', d.token);",
              "pm.environment.set('driver_id', d.person.id);",
              "console.log('Driver ID:', d.person.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"otp\": \"{{login_otp}}\", \"deviceToken\": \"test-onboarding-device\"}"
        },
        "url": {
          "raw": "{{baseURL_namma_P}}/auth/{{driver_authId}}/verify",
          "host": ["{{baseURL_namma_P}}"],
          "path": ["auth", "{{driver_authId}}", "verify"]
        }
      }
    },
    {
      "name": "03 - Get Onboarding Configs",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "console.log('Onboarding configs:', JSON.stringify(d));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{driver_token}}"
          }
        ],
        "url": {
          "raw": "{{baseURL_namma_P}}/onboarding/configs",
          "host": ["{{baseURL_namma_P}}"],
          "path": ["onboarding", "configs"]
        }
      }
    },
    {
      "name": "04 - Upload DL Image (Dashboard)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Upload DL returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "pm.expect(d.imageId).to.be.a('string');",
              "pm.environment.set('dl_image_id', d.imageId);",
              "console.log('DL image ID:', d.imageId);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{dashboard_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"imageBase64\": \"{{doc_image_base64}}\", \"imageType\": \"DriverLicense\", \"fileExtension\": \"png\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{driver_id}}/document/upload",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{driver_id}}", "document", "upload"]
        }
      }
    },
    {
      "name": "05 - Register Driver License (Dashboard)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Register DL returns 200', function () { pm.response.to.have.status(200); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{dashboard_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"driverLicenseNumber\": \"KA0120240001234\", \"operatingCity\": \"{{dashboard_city}}\", \"imageId1\": \"{{dl_image_id}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{driver_id}}/register/dl",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{driver_id}}", "register", "dl"]
        }
      }
    },
    {
      "name": "06 - Approve Driver License (Dashboard)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Approve DL returns 200', function () { pm.response.to.have.status(200); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{dashboard_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"imageId\": \"{{dl_image_id}}\", \"documentType\": \"DriverLicense\", \"validationStatus\": \"APPROVED\", \"reason\": null}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/documents/update",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "documents", "update"]
        }
      }
    },
    {
      "name": "07 - Upload RC Image (Dashboard)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Upload RC returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "pm.expect(d.imageId).to.be.a('string');",
              "pm.environment.set('rc_image_id', d.imageId);",
              "console.log('RC image ID:', d.imageId);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{dashboard_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"imageBase64\": \"{{doc_image_base64}}\", \"imageType\": \"VehicleRegistrationCertificate\", \"rcNumber\": \"{{_driver_reg_no}}\", \"fileExtension\": \"png\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{driver_id}}/document/upload",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{driver_id}}", "document", "upload"]
        }
      }
    },
    {
      "name": "08 - Register Vehicle RC (Dashboard)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Register RC returns 200', function () { pm.response.to.have.status(200); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{dashboard_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"vehicleRegistrationCertNumber\": \"{{_driver_reg_no}}\", \"imageId\": \"{{rc_image_id}}\", \"operatingCity\": \"{{dashboard_city}}\", \"airConditioned\": null, \"vehicleCategory\": \"{{vehicle_category}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{driver_id}}/register/rc",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{driver_id}}", "register", "rc"]
        }
      }
    },
    {
      "name": "09 - Approve Vehicle RC (Dashboard)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Approve RC returns 200', function () { pm.response.to.have.status(200); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{dashboard_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"rcId\": \"{{rc_image_id}}\", \"documentType\": \"VehicleRegistrationCertificate\", \"validationStatus\": \"APPROVED\", \"reason\": null}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/documents/update",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "documents", "update"]
        }
      }
    },
    {
      "name": "10 - Add Vehicle (Dashboard)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Add vehicle returns 200', function () { pm.response.to.have.status(200); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{dashboard_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"registrationNo\": \"{{_driver_reg_no}}\", \"vehicleClass\": \"{{vehicle_class}}\", \"colour\": \"White\", \"model\": \"{{vehicle_model}}\", \"make\": \"{{vehicle_make}}\", \"vehicleCategory\": \"{{vehicle_category}}\", \"variant\": \"{{vehicle_variant}}\", \"category\": \"{{vehicle_category}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{driver_id}}/addVehicle",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{driver_id}}", "addVehicle"]
        }
      }
    },
    {
      "name": "11 - Enable Driver (Dashboard)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Enable driver returns 200', function () { pm.response.to.have.status(200); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{dashboard_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{driver_id}}/enable",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{driver_id}}", "enable"]
        }
      }
    },
    {
      "name": "12 - Get Driver Document Status",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Document status returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "console.log('Driver verification statuses:', JSON.stringify(d.verificationStatuses || d));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{dashboard_token}}"
          }
        ],
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{driver_id}}/documents/info",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{driver_id}}", "documents", "info"]
        }
      }
    }
  ]
}
