{
  "info": {
    "_postman_id": "driver-bot-approval-flow-ny-bangalore",
    "name": "Driver BOT Approval Flow",
    "description": "Tests the BOT-gated onboarding path (enableBotFlow = true in transporter config). After a driver completes document uploads, a BOT reviewer approves via /submit/review/request. Requires the driver_id and rc_image_id set from a prior 01-DriverOnboardingFlow run.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Get BOT Review Queue (Drivers)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Review queue returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "console.log('Pending BOT reviews:', d.count || (d.reviewQueue && d.reviewQueue.length) || 0);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{bpp_dashboard_token}}"
          }
        ],
        "url": {
          "raw": "{{baseURL_BPP_Driver_Direct}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/review/queue/DRIVER/request/BOT_REVIEW",
          "host": ["{{baseURL_BPP_Driver_Direct}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "review", "queue", "DRIVER", "request", "BOT_REVIEW"]
        }
      }
    },
    {
      "name": "02 - Get BOT Review Queue (Vehicles)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Vehicle review queue returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "console.log('Pending vehicle BOT reviews:', d.count || (d.reviewQueue && d.reviewQueue.length) || 0);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{bpp_dashboard_token}}"
          }
        ],
        "url": {
          "raw": "{{baseURL_BPP_Driver_Direct}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/review/queue/VEHICLE/request/BOT_REVIEW",
          "host": ["{{baseURL_BPP_Driver_Direct}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "review", "queue", "VEHICLE", "request", "BOT_REVIEW"]
        }
      }
    },
    {
      "name": "03 - BOT Approve Driver",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('BOT driver approval returns 200', function () { pm.response.to.have.status(200); });",
              "console.log('BOT approved driver:', pm.environment.get('driver_id'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{bpp_dashboard_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"entityType\": \"DRIVER\", \"entityId\": \"{{driver_id}}\", \"rejectDocumentUpdateReq\": []}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Driver_Direct}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{driver_id}}/submit/review/request",
          "host": ["{{baseURL_BPP_Driver_Direct}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{driver_id}}", "submit", "review", "request"]
        }
      }
    },
    {
      "name": "04 - BOT Approve Vehicle (RC)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('BOT vehicle approval returns 200', function () { pm.response.to.have.status(200); });",
              "console.log('BOT approved vehicle RC for driver:', pm.environment.get('driver_id'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{bpp_dashboard_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"entityType\": \"VEHICLE\", \"entityId\": \"{{rc_image_id}}\", \"rejectDocumentUpdateReq\": []}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Driver_Direct}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{driver_id}}/submit/review/request",
          "host": ["{{baseURL_BPP_Driver_Direct}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{driver_id}}", "submit", "review", "request"]
        }
      }
    },
    {
      "name": "05 - BOT Reject Driver (Document Issue)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('BOT reject returns 200', function () { pm.response.to.have.status(200); });",
              "console.log('BOT rejected driver with document issue');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{bpp_dashboard_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"entityType\": \"DRIVER\", \"entityId\": \"{{driver_id}}\", \"rejectDocumentUpdateReq\": [{\"documentType\": \"DriverLicense\", \"documentDescription\": null, \"rejectedReason\": \"Image not clear\", \"remarks\": null, \"imageId\": \"{{dl_image_id}}\", \"mediaId\": null}]}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Driver_Direct}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{driver_id}}/submit/review/request",
          "host": ["{{baseURL_BPP_Driver_Direct}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{driver_id}}", "submit", "review", "request"]
        }
      }
    },
    {
      "name": "06 - Get Review History (Driver)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Review history returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "console.log('Review history count:', d.reviewHistory ? d.reviewHistory.length : 0);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{bpp_dashboard_token}}"
          }
        ],
        "url": {
          "raw": "{{baseURL_BPP_Driver_Direct}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/DRIVER/request/BOT_REVIEW/review/history?mbPersonId={{driver_id}}",
          "host": ["{{baseURL_BPP_Driver_Direct}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "DRIVER", "request", "BOT_REVIEW", "review", "history"],
          "query": [
            {
              "key": "mbPersonId",
              "value": "{{driver_id}}"
            }
          ]
        }
      }
    },
    {
      "name": "07 - Get Driver Documents Info (Post-Approval)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Documents info returns 200', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "console.log('Driver documents info:', JSON.stringify(d));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{dashboard_token}}"
          }
        ],
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{driver_id}}/documents/info",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{driver_id}}", "documents", "info"]
        }
      }
    }
  ]
}
