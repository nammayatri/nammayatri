{
  "info": {
    "name": "Issue Lifecycle Flow (BAP + BPP)",
    "description": "End-to-end Issue/IssueCategory lifecycle across rider-app (BAP) and dynamic-offer-driver-app (BPP). Exercises dashboard CRUD (category/option/message/translation), UI consumption from rider and driver, in-app chat (UI + dashboard sides), and config-update PATCH semantics (regression for the merchantName/supportEmail drop bug).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-skip mock-server requests when envType is not Local.",
          "(function () {",
          "  var envType = pm.environment.get('envType') || 'Local';",
          "  if (envType === 'Local') return;",
          "  var raw = (pm.request && pm.request.url && pm.request.url.toString()) || '';",
          "  if (raw.indexOf('mockServerUrl') !== -1 || raw.indexOf('mock_fcm_url') !== -1) {",
          "    if (pm.execution && typeof pm.execution.skipRequest === 'function') pm.execution.skipRequest();",
          "  }",
          "})();",
          "",
          "// Generate a fresh rider phone number ONCE per collection run.",
          "if (!pm.collectionVariables.get('_test_rider_number')) {",
          "    var rNum = '8' + Math.floor(100000000 + Math.random() * 899999999);",
          "    pm.collectionVariables.set('_test_rider_number', rNum);",
          "    console.log('[issue-flow] generated rider number ' + rNum);",
          "}",
          "// Per-run suffix used in test artefacts so concurrent runs don't collide.",
          "if (!pm.collectionVariables.get('_test_run_suffix')) {",
          "    pm.collectionVariables.set('_test_run_suffix', Math.floor(Math.random() * 1000000).toString());",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Rider Auth (sendOTP)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"mobileNumber\": \"{{_test_rider_number}}\",\n    \"mobileCountryCode\": \"+91\",\n    \"merchantId\": \"{{rider_merchant_id}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl_app}}/auth",
          "host": ["{{baseUrl_app}}"],
          "path": ["auth"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json();",
              "pm.environment.set('rider_authId', d.authId);",
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('authId present', function () { pm.expect(d.authId).to.be.a('string'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Rider Auth Verify",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"otp\": \"{{login_otp}}\",\n    \"deviceToken\": \"issue-flow-rider-device\",\n    \"whatsappNotificationEnroll\": \"OPT_OUT\"\n}"
        },
        "url": {
          "raw": "{{baseUrl_app}}/auth/{{rider_authId}}/verify",
          "host": ["{{baseUrl_app}}"],
          "path": ["auth", "{{rider_authId}}", "verify"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json();",
              "pm.environment.set('rider_token', d.token);",
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('rider token present', function () { pm.expect(d.token).to.be.a('string'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "BAP Dashboard: Create IssueCategory",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{rider_dashboard_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"category\": \"IssueFlowTest_{{_test_run_suffix}}\",\n    \"logoUrl\": \"https://example.com/logo.png\",\n    \"priority\": 999,\n    \"categoryType\": \"Category\",\n    \"isRideRequired\": false,\n    \"isTicketRequired\": false,\n    \"isActive\": true,\n    \"translations\": [\n      { \"language\": \"ENGLISH\", \"translation\": \"IssueFlow Test Category\" }\n    ],\n    \"messages\": [\n      {\n        \"message\": \"Welcome message for IssueFlow test\",\n        \"messageTitle\": \"Welcome\",\n        \"priority\": 1,\n        \"messageTranslations\": [ { \"language\": \"ENGLISH\", \"translation\": \"Welcome\" } ],\n        \"titleTranslations\": [],\n        \"actionTranslations\": [],\n        \"options\": [],\n        \"isActive\": true\n      }\n    ],\n    \"label\": \"ISSUE_FLOW_TEST_{{_test_run_suffix}}\",\n    \"enableKapture\": false,\n    \"showInDefault\": true\n}"
        },
        "url": {
          "raw": "{{bap_dashboard_url}}/bap/{{bap_merchant_short_id}}/{{city}}/issueV2/category/create",
          "host": ["{{bap_dashboard_url}}"],
          "path": ["bap", "{{bap_merchant_short_id}}", "{{city}}", "issueV2", "category", "create"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json();",
              "console.log('Create category resp:', JSON.stringify(d));",
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('categoryId returned', function () { pm.expect(d.categoryId).to.be.a('string'); });",
              "pm.environment.set('issue_category_id', d.categoryId);"
            ]
          }
        }
      ]
    },
    {
      "name": "BAP Dashboard: Get IssueCategory Detail (capture messageId)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "token", "value": "{{rider_dashboard_token}}" }
        ],
        "url": {
          "raw": "{{bap_dashboard_url}}/bap/{{bap_merchant_short_id}}/{{city}}/issueV2/category/{{issue_category_id}}/detail",
          "host": ["{{bap_dashboard_url}}"],
          "path": ["bap", "{{bap_merchant_short_id}}", "{{city}}", "issueV2", "category", "{{issue_category_id}}", "detail"],
          "query": []
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json();",
              "console.log('Category detail resp:', JSON.stringify(d));",
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Has nested category', function () { pm.expect(d.category).to.be.an('object'); });",
              "pm.test('Inline message created', function () { pm.expect(d.messages).to.be.an('array').and.to.have.length.at.least(1); });",
              "if (d.messages && d.messages.length) {",
              "    pm.environment.set('issue_message_id', d.messages[0].messageId || d.messages[0].issueMessageId);",
              "    console.log('captured messageId=' + pm.environment.get('issue_message_id'));",
              "}"
            ]
          }
        }
      ]
    },
