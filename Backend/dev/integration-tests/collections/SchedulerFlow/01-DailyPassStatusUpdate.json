		{
			"name": "Wait for Pass A to be Expired",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Poll Pass A status; retry every POLL_INTERVAL_MS up to MAX_ATTEMPTS, exit early on 'Expired'.",
							"var MAX_ATTEMPTS = 5;",
							"var POLL_INTERVAL_MS = 5000;",
							"var targetId = pm.collectionVariables.get('_pass_a_id');",
							"var mockUrl = pm.environment.get('mockServerUrl');",
							"var attempt = 0;",
							"var lastStatus = null;",
							"",
							"function poll() {",
							"  attempt++;",
							"  pm.sendRequest({",
							"    url: mockUrl + '/mock/sql/select',",
							"    method: 'POST',",
							"    header: { 'Content-Type': 'application/json' },",
							"    body: { mode: 'raw', raw: JSON.stringify({ db_name: 'atlas_dev', db_schema: 'atlas_app', table_name: 'purchased_pass', select: ['id','status'], where_clause: [{ column_name: 'id', val: targetId, op: '=' }] }) }",
							"  }, function (err, res) {",
							"    if (err) {",
							"      console.log('Wait for Pass A to be Expired attempt', attempt, 'error:', err.message || err);",
							"    } else {",
							"      var row = ((res.json().rows) || [])[0] || {};",
							"      lastStatus = row.status;",
							"      console.log('Wait for Pass A to be Expired attempt', attempt, 'status:', lastStatus);",
							"    }",
							"    var done = lastStatus === 'Expired' || attempt >= MAX_ATTEMPTS;",
							"    if (done) {",
							"      pm.test('Pass A (ULLA1DAY, expired endDate) is now Expired', function () {",
							"        pm.expect(lastStatus).to.eql('Expired');",
							"      });",
							"    } else {",
							"      setTimeout(poll, POLL_INTERVAL_MS);",
							"    }",
							"  });",
							"}",
							"poll();"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{mockServerUrl}}/health",
					"host": [
						"{{mockServerUrl}}"
					],
					"path": [
						"health"
					]
				}
			}
		},
		{
			"name": "Wait for Pass B to be Active",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Poll Pass B status; retry every POLL_INTERVAL_MS up to MAX_ATTEMPTS, exit early on 'Active'.",
							"var MAX_ATTEMPTS = 5;",
							"var POLL_INTERVAL_MS = 5000;",
							"var targetId = pm.collectionVariables.get('_pass_b_id');",
							"var mockUrl = pm.environment.get('mockServerUrl');",
							"var attempt = 0;",
							"var lastStatus = null;",
							"",
							"function poll() {",
							"  attempt++;",
							"  pm.sendRequest({",
							"    url: mockUrl + '/mock/sql/select',",
							"    method: 'POST',",
							"    header: { 'Content-Type': 'application/json' },",
							"    body: { mode: 'raw', raw: JSON.stringify({ db_name: 'atlas_dev', db_schema: 'atlas_app', table_name: 'purchased_pass', select: ['id','status'], where_clause: [{ column_name: 'id', val: targetId, op: '=' }] }) }",
							"  }, function (err, res) {",
							"    if (err) {",
							"      console.log('Wait for Pass B to be Active attempt', attempt, 'error:', err.message || err);",
							"    } else {",
							"      var row = ((res.json().rows) || [])[0] || {};",
							"      lastStatus = row.status;",
							"      console.log('Wait for Pass B to be Active attempt', attempt, 'status:', lastStatus);",
							"    }",
							"    var done = lastStatus === 'Active' || attempt >= MAX_ATTEMPTS;",
							"    if (done) {",
							"      pm.test('Pass B (GOLD1000, PreBooked->Active) is now Active', function () {",
							"        pm.expect(lastStatus).to.eql('Active');",
							"      });",
							"    } else {",
							"      setTimeout(poll, POLL_INTERVAL_MS);",
							"    }",
							"  });",
							"}",
							"poll();"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{mockServerUrl}}/health",
					"host": [
						"{{mockServerUrl}}"
					],
					"path": [
						"health"
					]
				}
			}
		},
		{
			"name": "Verify Chain Scheduled Tomorrow 01:00",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Peek OK', function () { pm.response.to.have.status(200); });",
							"var d = pm.response.json();",
							"var mocId = pm.environment.get('bap_merchant_operating_city_id');",
							"var pending = (d.jobs || []).filter(function (j) { return j.merchantOperatingCityId === mocId; });",
							"console.log('Pending DailyPassStatusUpdate jobs for moc:', pending.length);",
							"pending.forEach(function (j) { console.log(' - scheduledAt=', j.scheduledAt, 'jobData=', JSON.stringify(j.jobData)); });",
							"pm.test('Exactly one DailyPassStatusUpdate pending for this moc', function () { pm.expect(pending.length).to.eql(1); });",
							"var job = pending[0] || {};",
							"var scoreMs = job.scoreMs || 0;",
							"var hoursFromNow = (scoreMs - Date.now()) / 3600000;",
							"console.log('Next run in', hoursFromNow.toFixed(2), 'hours');",
							"pm.test('Next run is in the future (chain terminated via scheduleTomorrow)', function () { pm.expect(hoursFromNow).to.be.above(0); });",
							"pm.test('Next run <= 25h from now (tomorrow 01:00 local, not a mis-enqueued delay=0)', function () { pm.expect(hoursFromNow).to.be.below(25); });",
							"pm.test('Rescheduled job has autoSchedule=true', function () { pm.expect(job.jobData && job.jobData.autoSchedule).to.eql(true); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\"jobType\": \"{{scheduler_job_type}}\", \"target\": \"rider\"}"
				},
				"url": {
					"raw": "{{mockServerUrl}}/mock/scheduler/peek",
					"host": [
						"{{mockServerUrl}}"
					],
					"path": [
						"mock",
						"scheduler",
						"peek"
					]
				}
			}
		},
		{
			"name": "Restore BatchSize",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"var prev = pm.collectionVariables.get('_prev_batch_size');",
							"var setVal = (prev === '' || prev === undefined || prev === null) ? 'null' : String(parseInt(prev, 10));",
							"var mocId = pm.environment.get('bap_merchant_operating_city_id');",
							"var payload = {",
							"  db_name: 'atlas_dev', db_schema: 'atlas_app', table_name: 'rider_config',",
							"  set: { pass_status_update_batch_size: setVal === 'null' ? null : parseInt(setVal, 10) },",
							"  touch_updated_at: true,",
							"  where_clause: [{ column_name: 'merchant_operating_city_id', val: mocId, op: '=' }]",
							"};",
							"pm.collectionVariables.set('_restore_payload', JSON.stringify(payload));",
							"console.log('Restoring batch size to:', setVal);"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Restore OK', function () { pm.response.to.have.status(200); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{{_restore_payload}}"
				},
				"url": {
					"raw": "{{mockServerUrl}}/mock/sql/update",
					"host": [
						"{{mockServerUrl}}"
					],
					"path": [
						"mock",
						"sql",
						"update"
					]
				}
			}
		}
	]
