	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"exec": [
					"if (!pm.collectionVariables.get('_pos_rider_number')) {",
					"    pm.collectionVariables.set('_pos_rider_number', '8' + Math.floor(100000000 + Math.random() * 899999999));",
					"}",
					"if (!pm.collectionVariables.get('_neg_rider_number')) {",
					"    pm.collectionVariables.set('_neg_rider_number', '8' + Math.floor(100000000 + Math.random() * 899999999));",
					"}",
					"if (!pm.collectionVariables.get('_pos_device_token')) {",
					"    pm.collectionVariables.set('_pos_device_token', 'test-pass-expiry-pos-' + Date.now());",
					"}",
					"if (!pm.collectionVariables.get('_neg_device_token')) {",
					"    pm.collectionVariables.set('_neg_device_token', 'test-pass-expiry-neg-' + Date.now());",
					"}",
					"console.log('Positive rider:', pm.collectionVariables.get('_pos_rider_number'), 'token:', pm.collectionVariables.get('_pos_device_token'));",
					"console.log('Negative rider:', pm.collectionVariables.get('_neg_rider_number'), 'token:', pm.collectionVariables.get('_neg_device_token'));"
				],
				"type": "text/javascript"
			}
		}
	],
