		{
			"name": "Wait for Positive Rider FCM",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Poll mock-fcm /read/<token> until a PASS_EXPIRY_REMINDER notification arrives.",
							"var MAX_ATTEMPTS = 5;",
							"var POLL_INTERVAL_MS = 5000;",
							"var fcmUrl = pm.environment.get('mock_fcm_url');",
							"var token = pm.collectionVariables.get('_pos_device_token');",
							"var n = parseInt(pm.collectionVariables.get('_reminder_days'), 10) || 3;",
							"var attempt = 0;",
							"var received = [];",
							"",
							"function poll() {",
							"  attempt++;",
							"  pm.sendRequest({",
							"    url: fcmUrl + '/read/' + token,",
							"    method: 'GET'",
							"  }, function (err, res) {",
							"    if (err) {",
							"      console.log('FCM poll attempt', attempt, 'error:', err.message || err);",
							"    } else {",
							"      var msgs = res.json() || [];",
							"      received = received.concat(msgs);",
							"      console.log('FCM poll attempt', attempt, 'got', msgs.length, 'msgs (total', received.length + ')');",
							"    }",
							"    var done = received.length > 0 || attempt >= MAX_ATTEMPTS;",
							"    if (done) {",
							"      pm.test('Positive rider received an FCM notification', function () {",
							"        pm.expect(received.length).to.be.above(0);",
							"      });",
							"      pm.test('Notification title mentions days-to-expire', function () {",
							"        var titles = received.map(function (m) { return (m && m.notification && m.notification.title) || ''; });",
							"        console.log('Titles:', titles);",
							"        var expected = 'Pass expiring in ' + n + ' days';",
							"        pm.expect(titles.some(function (t) { return t === expected; })).to.eql(true);",
							"      });",
							"    } else {",
							"      setTimeout(poll, POLL_INTERVAL_MS);",
							"    }",
							"  });",
							"}",
							"poll();"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{mockServerUrl}}/health",
					"host": ["{{mockServerUrl}}"],
					"path": ["health"]
				}
			}
