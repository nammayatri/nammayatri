		{
			"name": "Verify Negative Rider Got No FCM",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('FCM read OK', function () { pm.response.to.have.status(200); });",
							"var msgs = pm.response.json() || [];",
							"console.log('Negative rider FCM count:', msgs.length);",
							"pm.test('Negative rider (has PreBooked pass) received NO PASS_EXPIRY_REMINDER', function () {",
							"  var titles = msgs.map(function (m) { return (m && m.notification && m.notification.title) || ''; });",
							"  pm.expect(titles.some(function (t) { return t.indexOf('Pass expiring in') === 0; })).to.eql(false);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{mock_fcm_url}}/read/{{_neg_device_token}}",
					"host": ["{{mock_fcm_url}}"],
					"path": ["read", "{{_neg_device_token}}"]
				}
			}
		},
		{
			"name": "Restore RiderConfig",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"var prev = pm.collectionVariables.get('_orig_reminder_days');",
							"var setVal = (prev === '' || prev === undefined || prev === null) ? null : parseInt(prev, 10);",
							"var mocId = pm.environment.get('bap_merchant_operating_city_id');",
							"var payload = {",
							"  db_name: 'atlas_dev', db_schema: 'atlas_app', table_name: 'rider_config',",
							"  set: { pass_expiry_reminder_days: setVal },",
							"  touch_updated_at: true,",
							"  where_clause: [{ column_name: 'merchant_operating_city_id', val: mocId, op: '=' }]",
							"};",
							"pm.collectionVariables.set('_restore_payload', JSON.stringify(payload));",
							"console.log('Restoring pass_expiry_reminder_days to:', setVal);"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Restore OK', function () { pm.response.to.have.status(200); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{{_restore_payload}}"
				},
				"url": {
					"raw": "{{mockServerUrl}}/mock/sql/update",
					"host": ["{{mockServerUrl}}"],
					"path": ["mock", "sql", "update"]
				}
			}
		},
		{
			"name": "Cleanup Scheduler State (final)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Final cleanup OK', function () { pm.response.to.have.status(200); });",
							"var r = pm.response.json();",
							"console.log('Removed', r.removedJobs, 'jobs and', r.removedLocks, 'locks');"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\"jobType\": \"{{_job_type}}\", \"target\": \"rider\", \"merchantOperatingCityId\": \"{{bap_merchant_operating_city_id}}\"}"
				},
				"url": {
					"raw": "{{mockServerUrl}}/mock/scheduler/clear",
					"host": ["{{mockServerUrl}}"],
					"path": ["mock", "scheduler", "clear"]
				}
			}
		}
	]
}
