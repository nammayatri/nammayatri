		{
			"name": "Seed Positive Active Pass",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Compute target endDate in city-local time so it matches the handler's todayLocal+N",
							"var n = parseInt(pm.collectionVariables.get('_reminder_days'), 10) || 3;",
							"var tzSec = parseInt(pm.collectionVariables.get('_time_diff_from_utc'), 10) || 0;",
							"var localNow = new Date(Date.now() + tzSec * 1000);",
							"var localTodayMs = Date.UTC(localNow.getUTCFullYear(), localNow.getUTCMonth(), localNow.getUTCDate());",
							"pm.collectionVariables.set('_today_local', new Date(localTodayMs).toISOString().split('T')[0]);",
							"pm.collectionVariables.set('_target_end_date', new Date(localTodayMs + n * 86400000).toISOString().split('T')[0]);",
							"function uuid4(){return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g,function(c){var r=Math.random()*16|0;return (c==='x'?r:(r&0x3|0x8)).toString(16);});}",
							"pm.collectionVariables.set('_pos_pass_id', uuid4());",
							"pm.collectionVariables.set('_neg_active_pass_id', uuid4());",
							"pm.collectionVariables.set('_neg_prebooked_pass_id', uuid4());",
							"pm.collectionVariables.set('_pos_pass_number', String(Math.floor(Math.random()*900000000)+100000000));",
							"pm.collectionVariables.set('_neg_active_pass_number', String(Math.floor(Math.random()*900000000)+100000000));",
							"pm.collectionVariables.set('_neg_prebooked_pass_number', String(Math.floor(Math.random()*900000000)+100000000));",
							"console.log('endDate=' + pm.collectionVariables.get('_target_end_date') + ' tz=' + tzSec + 's');",
							"console.log('positive Active pass:', pm.collectionVariables.get('_pos_pass_id'));",
							"console.log('negative Active pass:', pm.collectionVariables.get('_neg_active_pass_id'));",
							"console.log('negative PreBooked pass:', pm.collectionVariables.get('_neg_prebooked_pass_id'));"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Seed positive Active OK', function () { pm.response.to.have.status(200); });",
							"pm.test('Inserted 1 row', function () { pm.expect(pm.response.json().rowcount).to.eql(1); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\"db_name\":\"atlas_dev\",\"db_schema\":\"atlas_app\",\"table_name\":\"purchased_pass\",\"touch_timestamps\":true,\"on_conflict_do_nothing\":true,\"values\":{\"id\":\"{{_pos_pass_id}}\",\"person_id\":\"{{_pos_person_id}}\",\"merchant_id\":\"{{bap_merchant_id}}\",\"merchant_operating_city_id\":\"{{bap_merchant_operating_city_id}}\",\"pass_type_id\":\"ulla-unlimited-pass-type\",\"pass_code\":\"ULLA1DAY\",\"pass_name\":\"Ulla 1 Day\",\"pass_description\":\"Test seed for PassExpiryReminderMaster\",\"pass_amount\":1.0,\"pass_number\":{{_pos_pass_number}},\"status\":\"Active\",\"start_date\":\"{{_today_local}}\",\"end_date\":\"{{_target_end_date}}\",\"device_id\":\"test-imei-pos\",\"applicable_vehicle_service_tiers\":[\"ORDINARY\"],\"benefit_description\":\"1 day unlimited\",\"device_switch_count\":0,\"verification_validity\":60,\"used_trip_count\":0,\"max_valid_trips\":100,\"max_valid_days\":0}}"
				},
