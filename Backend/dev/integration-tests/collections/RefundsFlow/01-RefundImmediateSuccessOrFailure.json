    {
      "name": "Capture refundRequestId (SQL — after drain)",
      "event": [
        { "listen": "prerequest", "script": { "exec": ["var t = Date.now(); while (Date.now() - t < 20000) {}"] } },
        { "listen": "test", "script": { "exec": [
          "pm.test('B1 refund_request OPEN, txn=10, refunds_id null', function () {",
          "  var d = pm.response.json(); pm.expect(d.count, JSON.stringify(d)).to.be.above(0);",
          "  var r = d.rows[0];",
          "  pm.environment.set('refundRequestId', r.id);",
          "  pm.expect(r.status).to.eql('OPEN');",
          "  pm.expect(Number(r.transaction_amount)).to.eql(10);",
          "  pm.expect(r.refunds_id == null || r.refunds_id === '').to.be.true;",
          "});"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"db_name\":\"atlas_dev\",\"db_schema\":\"atlas_app\",\"table_name\":\"refund_request\",\"select\":[\"id\",\"status\",\"transaction_amount\",\"refunds_id\"],\"where_clause\":[{\"column_name\":\"order_id\",\"val\":\"{{orderId}}\",\"op\":\"=\"},{\"column_name\":\"status\",\"val\":\"OPEN\",\"op\":\"=\"}]}" },
        "url": { "raw": "{{mockServerUrl}}/mock/sql/select", "host": ["{{mockServerUrl}}"], "path": ["mock", "sql", "select"] }
      }
    },
    {
      "name": "Approve Refund — Case 2 deductFromDriver=true (Admin)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('approve -> REFUNDED/SUCCESS', function () {",
        "  pm.expect(pm.response.code, pm.response.text()).to.be.oneOf([200,201]);",
        "  var d = pm.response.json();",
        "  pm.expect(d.status).to.eql('REFUNDED');",
