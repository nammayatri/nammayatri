{
  "info": {
    "name": "01 - Refund Immediate Success Or Failure+Retry(no stripe refundsId re_ case)",
    "description": "Synchronous refund, Stripe answers immediately. (A) Success Case-2 (deductFromDriver=true): raise -> approve -> asserts BAP (OwnerAsset->BuyerAsset) and BPP (OwnerExpense + SellerExpense) legs SETTLED, both Refund invoices and PDFs. (B) Failure then retry: force the Stripe create to error -> approve FAILED + legs VOIDED -> clear override -> retry -> REFUNDED.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// mock-skip on non-Local envs (Rules.md)",
          "var envType = pm.environment.get('envType');",
          "var msu = pm.environment.get('mockServerUrl') || '';",
          "var url = pm.request.url.toString();",
          "if (envType && envType !== 'Local' && msu && url.indexOf(msu) > -1) {",
          "  if (pm.execution && typeof pm.execution.skipRequest === 'function') pm.execution.skipRequest();",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Reset refund state for the ride (clean start)",
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('refund state cleared', function () { pm.expect(pm.response.code, pm.response.text()).to.be.oneOf([200,201]); });"] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"rideId\":\"{{rideId}}\",\"orderId\":\"{{orderId}}\",\"orderShortId\":\"{{orderShortId}}\",\"bppBookingId\":\"{{bppBookingId}}\"}" },
        "url": { "raw": "{{mockServerUrl}}/mock/refunds/clear", "host": ["{{mockServerUrl}}"], "path": ["mock", "refunds", "clear"] }
      }
    },
    {
      "name": "Switch City for BAP (Rider Dashboard)",
      "event": [{ "listen": "test", "script": { "exec": [
        "var d = pm.response.json();",
