      "name": "[Failure] Retry approve -> REFUNDED (recovers)",
      "event": [
        { "listen": "prerequest", "script": { "exec": ["var t = Date.now(); while (Date.now() - t < 4000) {}"] } },
        { "listen": "test", "script": { "exec": [
          "pm.test('retry -> REFUNDED', function () {",
          "  pm.expect(pm.response.code, pm.response.text()).to.be.oneOf([200,201]);",
          "  var d = pm.response.json(); pm.expect(d.status).to.eql('REFUNDED');",
          "});"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "token", "value": "{{bap_dashboard_token}}" }],
        "body": { "mode": "raw", "raw": "{\"approve\":true,\"responseDescription\":\"retry after gateway failure\",\"retryRefunds\":true,\"deductFromDriver\":true}" },
        "url": { "raw": "{{bap_dashboard_url}}/bap/{{bap_short_id}}/{{dashboard_city}}/payment/refundRequest/{{refundRequestId}}/respond", "host": ["{{bap_dashboard_url}}"], "path": ["bap", "{{bap_short_id}}", "{{dashboard_city}}", "payment", "refundRequest", "{{refundRequestId}}", "respond"] }
      }
    },
    {
      "name": "[Failure] Assert the create-error attempt VOIDED its leg (SQL — after drain)",
      "event": [
        { "listen": "prerequest", "script": { "exec": ["var t = Date.now(); while (Date.now() - t < 20000) {}"] } },
        { "listen": "test", "script": { "exec": [
          "// create-error attempt: its provisional leg is VOIDED; the retry recovers via a fresh SETTLED leg",
          "// (documented failure-then-recover ledger behaviour)",
          "pm.test('a VOIDED leg exists from the failed (no-re_) create-error attempt', function () {",
          "  var d = pm.response.json();",
          "  console.log('ride ledger statuses:', (d.rows||[]).map(function(r){return r.status;}).join(','));",
          "  var voided = (d.rows||[]).filter(function(r){return r.status === 'VOIDED';});",
          "  pm.expect(voided.length, 'expected >=1 VOIDED leg from the no-re_ failed refund').to.be.above(0);",
          "});"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"db_name\":\"atlas_dev\",\"db_schema\":\"atlas_app\",\"table_name\":\"finance_ledger_entry\",\"select\":[\"id\",\"status\",\"amount\"],\"where_clause\":[{\"column_name\":\"reference_id\",\"val\":\"{{rideId}}\",\"op\":\"=\"}]}" },
        "url": { "raw": "{{mockServerUrl}}/mock/sql/select", "host": ["{{mockServerUrl}}"], "path": ["mock", "sql", "select"] }
      }
    }
  ]
}
