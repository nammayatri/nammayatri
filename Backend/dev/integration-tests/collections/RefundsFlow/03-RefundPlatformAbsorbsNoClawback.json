    {
      "name": "Assert BPP ledger = SINGLE SellerExpense leg (no driver clawback)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var t = Date.now(); while (Date.now() - t < 20000) {}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "function _mockUrl(){ return (pm.environment.get('mockServerUrl')||'http://localhost:8080').replace(/\\$\\{[^:}]*:?([^}]*)\\}/g,'$1'); }",
              "function _sqlBody(){ return JSON.stringify({db_name:'atlas_dev',db_schema:'atlas_driver_offer_bpp',table_name:'finance_ledger_entry',select:['id','status','amount','reference_type'],where_clause:[{column_name:'reference_id',val:pm.environment.get('bppBookingId'),op:'='}]}); }",
              "function _ok(rows){ return rows.some(function(r){return r.status==='SETTLED';}); }",
              "function _assert(rows){",
              "  var _resp = { count: rows.length, rows: rows };",
              "  console.log('  ↳ expected: single SellerExpense leg = rf1 (gross) =', pm.environment.get('rf1'));",
              "  try { var _rows = (_resp.rows) || []; console.log('  ↳ DB rows:', JSON.stringify(_rows.map(function(x){ return {st:x.status, amt:x.amount, total:x.total_amount, type:(x.reference_type||x.invoice_type||undefined)}; }))); } catch(e) {}",
              "  pm.test('P2 Case-1: one SETTLED commission leg, no DriverShare', function () {",
              "    var d = _resp; pm.expect(d.count, 'BPP ledger empty').to.be.above(0);",
              "    var settled = d.rows.filter(function(r){return r.status === 'SETTLED';});",
              "    pm.expect(settled.length, 'expected >=1 SETTLED leg').to.be.above(0);",
              "    var driverLegs = d.rows.filter(function(r){return String(r.reference_type||'').indexOf('DriverShare') > -1;});",
              "    pm.expect(driverLegs.length, 'Case 1 must NOT post a DriverShare/OwnerExpense leg').to.eql(0);",
              "  });",
              "  ",
              "  // Dynamic amount: Case-1 single leg = full gross refund rf1 (RideRefund), platform absorbs",
              "  var _d2 = _resp; var _rows2 = (_d2 && _d2.rows) || [];",
              "  var _R = Number(pm.environment.get('rf1'));",
              "  var _legs = _rows2.filter(function (r) { return r.status === 'SETTLED' && (r.reference_type || '') === 'RideRefund'; });",
              "  pm.test('Case-1 single RideRefund leg = rf1 (gross)', function () {",
              "      pm.expect(_legs.length).to.be.above(0);",
              "      pm.expect(Number(_legs[0].amount)).to.be.closeTo(_R, 0.011);",
              "  });",
              "}",
              "function _poll(n){ pm.sendRequest({ url:_mockUrl()+'/mock/sql/select', method:'POST', header:{'Content-Type':'application/json'}, body:{mode:'raw', raw:_sqlBody()} }, function(err,res){ var rows=[]; try{ rows=((res&&res.json())||{}).rows||[]; }catch(e){} if(_ok(rows) || n<=0){ _assert(rows); } else { setTimeout(function(){ _poll(n-1); }, 3000); } }); }",
              "var _r0=[]; try{ _r0=(pm.response.json().rows)||[]; }catch(e){} if(_ok(_r0)){ _assert(_r0); } else { _poll(10); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
