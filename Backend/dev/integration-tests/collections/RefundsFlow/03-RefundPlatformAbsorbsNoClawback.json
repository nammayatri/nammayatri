    {
      "name": "Finalize refund env (riderToken alias + sanity gate)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// 01-05 raise refunds as the customer via {{riderToken}}",
              "pm.environment.set('riderToken', pm.environment.get('rider_token'));",
              "var T = Number(pm.environment.get('txn_amount'));",
              "pm.test('sanity: T captured and positive', function () { pm.expect(T).to.be.above(0); });",
              "pm.test('sanity: all refund ids captured', function () {",
              "    ['rideId','orderId','orderShortId','paymentIntentId','bppBookingId'].forEach(function (k) {",
              "        pm.expect(pm.environment.get(k), k).to.be.a('string').and.not.empty;",
              "    });",
              "});",
              "console.log('Refund env ready. T =', T, pm.environment.get('txn_currency'), '| commission =', pm.environment.get('bpp_commission'));",
              "",
              "// Dynamic refund amounts from the captured charged amount T (self-contained: computed here,",
              "// AFTER capture, since T is now produced within THIS run — not carried from a prior collection).",
              "var _Trf = Number(pm.environment.get('txn_amount'));",
              "function _r2rf(x){ return Math.round(x*100)/100; }",
              "if (_Trf > 0) {",
              "  pm.environment.set('rf1', String(_r2rf(_Trf/2)));",
              "  pm.environment.set('rf2', String(_r2rf(_Trf/4)));",
              "  pm.environment.set('rf3', String(_r2rf(_Trf/2)));",
              "  console.log('Refund amounts: rf1='+_r2rf(_Trf/2)+' rf2='+_r2rf(_Trf/4)+' rf3='+_r2rf(_Trf/2)+' (T='+_Trf+')');",
              "}"
            ]
          }
        }
      ],
