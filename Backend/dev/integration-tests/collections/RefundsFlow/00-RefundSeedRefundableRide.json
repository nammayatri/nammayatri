{
  "info": {
    "name": "00 - Refund Seed Refundable Ride",
    "description": "Seeds a refundable Helsinki Stripe ride for the refund scenarios: looks up the real config-sync merchant/op-city IDs, then inserts the BAP (atlas_app) and BPP (atlas_driver_offer_bpp) ride artifacts via /mock/sql/insert. Idempotent; run before 01-05.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// ISO timestamps for the synthetic ride (params are literals; now()-interval is NOT evaluated server-side)",
          "var now = Date.now();",
          "pm.collectionVariables.set('_ts_booking', new Date(now - 3600000).toISOString());",
          "pm.collectionVariables.set('_ts_ride_start', new Date(now - 1800000).toISOString());",
          "pm.collectionVariables.set('_ts_ride_end', new Date(now - 300000).toISOString());",
          "pm.collectionVariables.set('_ts_txn', new Date(now - 1200000).toISOString());",
          "// mock-skip on non-Local envs (Rules.md): every RefundsFlow step is a mock-server call",
          "var envType = pm.environment.get('envType');",
          "var msu = pm.environment.get('mockServerUrl') || '';",
          "var url = pm.request.url.toString();",
          "if (envType && envType !== 'Local' && msu && url.indexOf(msu) > -1) {",
          "  if (pm.execution && typeof pm.execution.skipRequest === 'function') pm.execution.skipRequest();",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Lookup BAP merchant id (config-sync, by short_id)",
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('BAP merchant found', function () { var d = pm.response.json(); pm.expect(d.count, JSON.stringify(d)).to.be.above(0); pm.environment.set('bap_merchant_id', d.rows[0].id); });"] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"db_name\":\"atlas_dev\",\"db_schema\":\"atlas_app\",\"table_name\":\"merchant\",\"select\":[\"id\"],\"where_clause\":[{\"column_name\":\"short_id\",\"val\":\"{{bap_short_id}}\",\"op\":\"=\"}]}" },
        "url": { "raw": "{{mockServerUrl}}/mock/sql/select", "host": ["{{mockServerUrl}}"], "path": ["mock", "sql", "select"] }
      }
    },
