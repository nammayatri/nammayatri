          ],
          "path": [
            "driver",
            "register",
            "validateImage"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"image\": \"{{_test_png}}\",\n  \"imageType\": \"ProfilePhoto\",\n  \"validationStatus\": \"AUTO_APPROVED\",\n  \"workflowTransactionId\": \"{{$guid}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('selfie ok',()=>pm.response.to.have.status(200)); var t=Date.now(); while(Date.now()-t<2500){}"
            ]
          }
        }
      ]
    },
    {
      "name": "G: Status (Aadhaar flipped INVALID)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{token_G}}"
          }
        ],
        "url": {
          "raw": "{{baseURL_namma_P}}/driver/register/status",
          "host": [
            "{{baseURL_namma_P}}"
          ],
          "path": [
            "driver",
            "register",
            "status"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status ok',()=>pm.response.to.have.status(200)); var aad=(pm.response.json().driverDocuments||[]).find(d=>d.documentType==='AadhaarCard')||{}; pm.test('deferred FAIL flips Aadhaar INVALID',()=>pm.expect(['INVALID','FAILED'],'aadhaar '+JSON.stringify(aad)).to.include(aad.verificationStatus));"
            ]
          }
        }
      ]
    },
    {
      "name": "G: Delete override",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{mockServerUrl}}/mock/override",
