{
  "info": {
    "name": "SAP Report Dispatch",
    "description": "Tests SAPReportDispatch scheduler job: seeds past-dated subscription purchases + PG settlement reports + IndirectTaxTransaction, triggers the scheduler, verifies sap_journal_entry rows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "(function () {",
          "  var envType = pm.environment.get('envType') || 'Local';",
          "  if (envType === 'Local') return;",
          "  var raw = (pm.request && pm.request.url && pm.request.url.toString()) || '';",
          "  if (raw.indexOf('mockServerUrl') !== -1) {",
          "    console.log('[skip] mock-only request on envType=' + envType);",
          "    if (pm.execution && typeof pm.execution.skipRequest === 'function') {",
          "      pm.execution.skipRequest();",
          "    }",
          "  }",
          "})();",
          "",
          "// Compute yesterday's date in YYYY-MM-DD format",
          "if (!pm.collectionVariables.get('_yesterday_computed')) {",
          "  var d = new Date();",
          "  d.setDate(d.getDate() - 1);",
          "  var yyyy = d.getFullYear();",
          "  var mm = String(d.getMonth() + 1).padStart(2, '0');",
          "  var dd = String(d.getDate()).padStart(2, '0');",
          "  pm.collectionVariables.set('yesterday', yyyy + '-' + mm + '-' + dd);",
          "  pm.collectionVariables.set('_yesterday_computed', 'true');",
          "  console.log('Yesterday:', pm.collectionVariables.get('yesterday'));",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "variable": [
    { "key": "yesterday", "value": "" },
    { "key": "_yesterday_computed", "value": "" },
    { "key": "_entry_count_before", "value": "0" }
  ],
