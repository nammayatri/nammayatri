    {
      "name": "9. Verify Next Job Scheduled",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Peek OK', function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "var mocId = pm.environment.get('bpp_merchant_operating_city_id');",
              "var pending = (d.jobs || []).filter(function (j) { return j.merchantOperatingCityId === mocId; });",
              "console.log('Pending SAPReportDispatch jobs:', pending.length);",
              "pending.forEach(function (j) { console.log(' - scheduledAt=', j.scheduledAt, 'jobData=', JSON.stringify(j.jobData)); });",
              "pm.test('Next SAPReportDispatch job is scheduled', function () {",
              "  pm.expect(pending.length).to.be.greaterThan(0);",
              "});",
              "var job = pending[0] || {};",
              "var scoreMs = job.scoreMs || 0;",
              "var hoursFromNow = (scoreMs - Date.now()) / 3600000;",
              "console.log('Next run in', hoursFromNow.toFixed(2), 'hours');",
              "pm.test('Next run is in the future', function () { pm.expect(hoursFromNow).to.be.above(0); });",
              "pm.test('Next run <= 25h from now', function () { pm.expect(hoursFromNow).to.be.below(25); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"jobType\": \"SAPReportDispatch\", \"target\": \"driver\"}"
        },
        "url": {
          "raw": "{{mockServerUrl}}/mock/scheduler/peek",
          "host": ["{{mockServerUrl}}"],
          "path": ["mock", "scheduler", "peek"]
        }
      }
    },

