    {
      "name": "8. Wait and Verify SAP Journal Entries",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var MAX_ATTEMPTS = 12;",
              "var POLL_INTERVAL_MS = 5000;",
              "var mockUrl = pm.environment.get('mockServerUrl');",
              "var merchantId = pm.environment.get('bpp_merchant_id');",
              "var attempt = 0;",
              "var foundRows = [];",
              "",
              "function poll() {",
              "  attempt++;",
              "  pm.sendRequest({",
              "    url: mockUrl + '/mock/sql/select',",
              "    method: 'POST',",
              "    header: { 'Content-Type': 'application/json' },",
              "    body: {",
              "      mode: 'raw',",
              "      raw: JSON.stringify({",
              "        db_name: 'atlas_dev',",
              "        db_schema: 'atlas_driver_offer_bpp',",
              "        table_name: 'sap_journal_entry',",
              "        select: ['*'],",
              "        where_clause: [{ column_name: 'merchant_id', val: merchantId, op: '=' }]",
              "      })",
              "    }",
              "  }, function (err, res) {",
              "    if (err) {",
              "      console.log('Poll attempt', attempt, 'error:', err.message || err);",
              "    } else {",
              "      var body = res.json();",
              "      foundRows = body.rows || body;",
              "      console.log('Poll attempt', attempt + '/' + MAX_ATTEMPTS, '— entries:', foundRows.length);",
              "    }",
              "    if (foundRows.length > 0 || attempt >= MAX_ATTEMPTS) {",
              "      pm.test('SAP journal entries created', function () {",
              "        pm.expect(foundRows.length).to.be.greaterThan(0);",
              "      });",
              "      foundRows.forEach(function(r) {",
              "        console.log('  entry:', r.id, 'type:', r.transaction_type, 'status:', r.status, 'batchId:', r.batch_id);",
              "      });",
              "    } else {",
              "      setTimeout(poll, POLL_INTERVAL_MS);",
              "    }",
              "  });",
              "}",
              "poll();"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"db_name\": \"atlas_dev\", \"db_schema\": \"atlas_driver_offer_bpp\", \"table_name\": \"sap_journal_entry\", \"select\": [\"*\"], \"where_clause\": [{\"column_name\": \"merchant_id\", \"val\": \"{{bpp_merchant_id}}\", \"op\": \"=\"}]}"
        },
        "url": {
          "raw": "{{mockServerUrl}}/mock/sql/select",
          "host": ["{{mockServerUrl}}"],
          "path": ["mock", "sql", "select"]
        }
      }
