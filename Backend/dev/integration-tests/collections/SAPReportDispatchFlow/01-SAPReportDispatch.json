              "    if (newEntries.length > 0 || attempt >= MAX_ATTEMPTS) {",
              "      pm.test('New journal entries created for refund run', function () {",
              "        pm.expect(newEntries.length).to.be.greaterThan(0);",
              "      });",
              "      var refundEntries = newEntries.filter(function(r) { return r.transaction_type === 'Refund'; });",
              "      pm.test('Refund entry present', function () {",
              "        pm.expect(refundEntries.length).to.be.greaterThan(0);",
