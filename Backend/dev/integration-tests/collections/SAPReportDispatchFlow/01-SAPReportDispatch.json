          "listen": "test",
          "script": {
            "exec": [
              "var MAX_ATTEMPTS = 12;",
              "var POLL_INTERVAL_MS = 5000;",
              "var mockUrl = pm.environment.get('mockServerUrl');",
              "var merchantId = pm.environment.get('bpp_merchant_id');",
              "var countBefore = parseInt(pm.collectionVariables.get('_entry_count_before') || '0');",
              "var attempt = 0;",
              "var newEntries = [];",
              "",
              "function poll() {",
              "  attempt++;",
              "  pm.sendRequest({",
              "    url: mockUrl + '/mock/sql/select',",
              "    method: 'POST',",
              "    header: { 'Content-Type': 'application/json' },",
              "    body: { mode: 'raw', raw: JSON.stringify({ db_name: 'atlas_dev', db_schema: 'atlas_driver_offer_bpp', table_name: 'sap_journal_entry', select: ['*'], where_clause: [{ column_name: 'merchant_id', val: merchantId, op: '=' }] }) }",
              "  }, function (err, res) {",
              "    if (!err) {",
              "      var rows = res.json().rows || [];",
              "      if (rows.length > countBefore) {",
              "        newEntries = rows.slice(countBefore);",
              "      }",
              "      console.log('Poll', attempt + '/' + MAX_ATTEMPTS, '— total entries:', rows.length, 'new:', rows.length - countBefore);",
