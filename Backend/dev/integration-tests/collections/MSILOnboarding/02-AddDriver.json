{
  "info": {
    "_postman_id": "msil-onboarding-02-add-driver",
    "name": "MSIL Onboarding 02 - Add Driver (fleet joining OTP + docs + operator inspection + bot enable)",
    "description": "Onboards a fleet-associated driver on MSIL_PARTNER/Delhi. Uses the fleet-owner token from 01 to send/verify a joining OTP for a new driver, uploads DL/Aadhaar/PAN/residence/police docs, creates an operator inspection request, has the operator approve it, then bot-enables the driver. Asserts the new flag model (verified/approved/enabled + onboardingAs sync + sticky disabledReasonFlag) at each transition.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('driver_mobile')) {",
          "  const r = Math.floor(Math.random() * 900000000) + 100000000;",
          "  pm.environment.set('driver_mobile', String(r));",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 - Send Joining OTP (fleet-side)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Send joining OTP returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "if (d && d.authId) pm.environment.set('driver_authId', d.authId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{fleet_owner_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"mobileNumber\": \"{{driver_mobile}}\", \"fleetOwnerId\": \"{{fleet_owner_id}}\", \"mobileCountryCode\": \"{{country_code}}\", \"deviceToken\": \"test-driver-msil\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/fleet/sendJoiningOtp?fleetOwnerId={{fleet_owner_id}}",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "fleet", "sendJoiningOtp"],
          "query": [ { "key": "fleetOwnerId", "value": "{{fleet_owner_id}}" } ]
        }
      }
    },
    {
      "name": "02 - Verify Joining OTP — returns APISuccess; driver_id is resolved via driverAssociation search next",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Verify joining OTP returns 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{fleet_owner_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"mobileNumber\": \"{{driver_mobile}}\", \"fleetOwnerId\": \"{{fleet_owner_id}}\", \"otp\": \"{{login_otp}}\", \"mobileCountryCode\": \"{{country_code}}\", \"deviceToken\": \"test-driver-msil\", \"authId\": \"{{driver_authId}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/fleet/verifyJoiningOtp?fleetOwnerId={{fleet_owner_id}}&authId={{driver_authId}}",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "fleet", "verifyJoiningOtp"],
          "query": [
            { "key": "fleetOwnerId", "value": "{{fleet_owner_id}}" },
            { "key": "authId", "value": "{{driver_authId}}" }
          ]
        }
      }
    },
    {
      "name": "03 - Driver Association (search by mobile, resolve driver_id if missing)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Driver association lookup returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "if (!pm.environment.get('driver_id')) {",
              "  const arr = d.drivers || d.list || d || [];",
              "  const first = Array.isArray(arr) && arr.length ? arr[0] : null;",
              "  if (first) {",
              "    pm.environment.set('driver_id', first.driverId || first.id || first.personId || '');",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "token", "value": "{{fleet_owner_token}}" } ],
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/fleet/driverAssociation?mbSearchString={{driver_mobile}}&fleetOwnerId={{fleet_owner_id}}",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "fleet", "driverAssociation"],
          "query": [
            { "key": "mbSearchString", "value": "{{driver_mobile}}" },
            { "key": "fleetOwnerId", "value": "{{fleet_owner_id}}" }
          ]
        }
      }
    },
    {
      "name": "04 - Get All Operation Hubs",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Get all hubs returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "const hubs = d.hubs || d.list || d || [];",
              "const first = Array.isArray(hubs) && hubs.length ? hubs[0] : null;",
              "if (first) pm.environment.set('operation_hub_id', first.id || first.hubId || '');",
              "pm.test('At least one hub configured', () => pm.expect(!!first).to.be.true);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "token", "value": "{{fleet_owner_token}}" } ],
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/operation/getAllHubs",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "operation", "getAllHubs"]
        }
      }
    },
