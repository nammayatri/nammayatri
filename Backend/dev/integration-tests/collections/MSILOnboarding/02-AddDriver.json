        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{ops_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"operationHubRequestId\": \"{{driver_hub_request_id}}\", \"operatorId\": \"{{operator_id}}\", \"status\": \"APPROVED\", \"remarks\": \"\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/operator/respond/hubRequest",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "operator", "respond", "hubRequest"]
        }
      }
    },
    {
      "name": "20 - Ops Update Driver Entry (Inspection Q&A)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Update driver entry returns 200 or 204', () => pm.expect([200,204]).to.include(pm.response.code));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{ops_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"entityId\": \"{{driver_id}}\", \"entityType\": \"DRIVER\", \"newInfo\": [{\"question\": \"Does the driver's physical Driving Licence match the driver and the one uploaded during onboarding?\", \"questionId\": \"d1\", \"answer\": \"Yes\"}]}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/entityInfo/update",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "entityInfo", "update"]
        }
      }
    },
    {
      "name": "21 - Bot Approve Driver (submit/review/request)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const code = pm.response.code;",
              "if (code !== 200) { console.warn('Bot approve not configured — leaving driver in pre-approval state. code:', code); return; }",
              "pm.test('Bot approve driver returns 200', () => pm.expect(code).to.eql(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{bot_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"entityId\": \"{{driver_id}}\", \"entityType\": \"DRIVER\", \"rejectDocumentUpdateReq\": []}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/submit/review/request",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "submit", "review", "request"]
        }
      }
    },
    {
      "name": "22 - Driver Register Status (assert onboardingAs=FLEET_DRIVER + enabled=true + sticky flag null)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register status returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "if (d.onboardingAs !== undefined) {",
              "  pm.test('onboardingAs synced to FLEET_DRIVER (via FDA sync)', () => pm.expect(d.onboardingAs).to.eql('FLEET_DRIVER'));",
              "}",
              "pm.test('disabledReasonFlag stays null (no admin/driver disable)', () => pm.expect(d.disabledReasonFlag || null).to.eql(null));",
              "if (pm.environment.get('bot_token') && pm.environment.get('bot_token') !== pm.environment.get('dashboard_token')) {",
              "  pm.test('Driver enabled after bot approval', () => pm.expect(d.enabled).to.eql(true));",
              "  pm.test('Driver approved after bot approval', () => pm.expect(d.approved).to.eql(true));",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "token", "value": "{{fleet_owner_token}}" } ],
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/onboarding/register/status?driverId={{driver_id}}",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "onboarding", "register", "status"],
          "query": [ { "key": "driverId", "value": "{{driver_id}}" } ]
        }
      }
    }
  ]
}
