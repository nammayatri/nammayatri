{
  "info": {
    "_postman_id": "msil-onboarding-03-add-vehicle",
    "name": "MSIL Onboarding 03 - Add Vehicle (RC + docs + 6-side photos + operator inspection + bot approve)",
    "description": "Adds a vehicle under the onboarded fleet on MSIL_PARTNER/Delhi. Uploads RC, calls fleet/addVehicle, uploads insurance/fitness/PUC/vehicle-photos, marks InspectionHub, creates an ONBOARDING_INSPECTION request, has operator approve + upload car video, then bot-approves the vehicle. Asserts VRC verified/approved flow via the new refactor (forkRecomputeVehicleVerified derives approved from FODVC.isApprovalSupported).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('vehicle_reg_no')) {",
          "  const r = Math.floor(Math.random() * 9000) + 1000;",
          "  pm.environment.set('vehicle_reg_no', 'DL0' + r + 'TEST');",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 - Get All Operation Hubs",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Get all hubs returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "const hubs = d.hubs || d.list || d || [];",
              "const first = Array.isArray(hubs) && hubs.length ? hubs[0] : null;",
              "if (first) pm.environment.set('operation_hub_id', first.id || first.hubId || '');"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "token", "value": "{{fleet_owner_token}}" } ],
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/operation/getAllHubs",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "operation", "getAllHubs"]
        }
      }
    },
    {
      "name": "02 - Upload RC",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Upload RC returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "pm.environment.set('vehicle_rc_image_id', d.imageId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{fleet_owner_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"fleetOwnerId\": \"{{fleet_owner_id}}\", \"imageBase64\": \"{{doc_image_base64}}\", \"imageType\": \"VehicleRegistrationCertificate\", \"rcNumber\": \"{{vehicle_reg_no}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{fleet_owner_id}}/document/upload",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{fleet_owner_id}}", "document", "upload"]
        }
      }
    },
    {
      "name": "03 - Add Vehicle (fleet path)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Add vehicle returns 200 or 201', () => pm.expect([200,201]).to.include(pm.response.code));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{fleet_owner_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"imageId\": \"{{vehicle_rc_image_id}}\", \"operatingCity\": \"{{city}}\", \"multipleRC\": true, \"vehicleCategory\": \"{{vehicle_category}}\", \"driverName\": \"MSILFleetOwner\", \"energyType\": \"\", \"fuelType\": \"\", \"make\": \"{{vehicle_make}}\", \"model\": \"{{vehicle_model}}\", \"colour\": \"White\", \"vehicleClass\": \"{{vehicle_class}}\", \"registrationNo\": \"{{vehicle_reg_no}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{fleet_owner_mobile}}/fleet/addVehicle?mbRole=%22FLEET%22&fleetOwnerId={{fleet_owner_id}}",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{fleet_owner_mobile}}", "fleet", "addVehicle"],
          "query": [
            { "key": "mbRole", "value": "%22FLEET%22" },
            { "key": "fleetOwnerId", "value": "{{fleet_owner_id}}" }
          ]
        }
      }
    },
    {
      "name": "04 - Upload Vehicle Insurance",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [ "pm.test('Upload insurance returns 200', () => pm.response.to.have.status(200));" ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{fleet_owner_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"fleetOwnerId\": \"{{fleet_owner_id}}\", \"imageBase64\": \"{{doc_image_base64}}\", \"imageType\": \"VehicleInsuranceImage\", \"rcNumber\": \"{{vehicle_reg_no}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{fleet_owner_id}}/document/upload",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{fleet_owner_id}}", "document", "upload"]
        }
      }
    },
    {
      "name": "05 - Upload Fitness Certificate",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [ "pm.test('Upload fitness returns 200', () => pm.response.to.have.status(200));" ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{fleet_owner_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"fleetOwnerId\": \"{{fleet_owner_id}}\", \"imageBase64\": \"{{doc_image_base64}}\", \"imageType\": \"VehicleFitnessCertificateImage\", \"rcNumber\": \"{{vehicle_reg_no}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{fleet_owner_id}}/document/upload",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{fleet_owner_id}}", "document", "upload"]
        }
      }
    },
    {
      "name": "06 - Upload PUC Certificate",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [ "pm.test('Upload PUC returns 200', () => pm.response.to.have.status(200));" ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{fleet_owner_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"fleetOwnerId\": \"{{fleet_owner_id}}\", \"imageBase64\": \"{{doc_image_base64}}\", \"imageType\": \"VehiclePUCImage\", \"rcNumber\": \"{{vehicle_reg_no}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{fleet_owner_id}}/document/upload",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{fleet_owner_id}}", "document", "upload"]
        }
      }
    },
    {
      "name": "07 - Upload Vehicle Photos (Front/Back/Left/Right/FrontInterior/BackInterior/Odometer)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const doc = pm.environment.get('doc_image_base64');",
              "const rc = pm.environment.get('vehicle_reg_no');",
              "const foId = pm.environment.get('fleet_owner_id');",
              "const merchant = pm.environment.get('dashboard_merchant_id');",
              "const city = pm.environment.get('dashboard_city');",
              "const base = pm.environment.get('baseURL_BPP_Dashboard_Internal');",
              "const tok = pm.environment.get('fleet_owner_token');",
              "const types = ['VehicleFront','VehicleBack','VehicleLeft','VehicleRight','VehicleFrontInterior','VehicleBackInterior','VehicleInspectionImage'];",
              "const url = `${base}/${merchant}/${city}/driver/${foId}/document/upload`;",
              "async function up(imageType) {",
              "  return new Promise((res) => {",
              "    pm.sendRequest({ url, method: 'POST', header: { 'Content-Type': 'application/json', token: tok }, body: { mode: 'raw', raw: JSON.stringify({ fleetOwnerId: foId, imageBase64: doc, imageType, rcNumber: rc }) } }, (_e, r) => res(r ? r.code : 0));",
              "  });",
              "}",
              "(async () => { for (const t of types) { const code = await up(t); console.log('photo', t, code); } })();"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Vehicle photos batch scheduled (see console for per-side codes)', () => pm.expect(true).to.be.true);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "token", "value": "{{fleet_owner_token}}" } ],
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{fleet_owner_id}}/fleetOwnerInfo",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{fleet_owner_id}}", "fleetOwnerInfo"]
        }
      }
    },
    {
      "name": "08 - Upload InspectionHub Marker",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [ "pm.test('Upload InspectionHub marker returns 200', () => pm.response.to.have.status(200));" ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{fleet_owner_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"fleetOwnerId\": \"{{fleet_owner_id}}\", \"imageBase64\": \"{{doc_image_base64}}\", \"imageType\": \"InspectionHub\", \"rcNumber\": \"{{vehicle_reg_no}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/{{fleet_owner_id}}/document/upload",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "{{fleet_owner_id}}", "document", "upload"]
        }
      }
    },
    {
      "name": "09 - Create Operator Inspection Request (ONBOARDING_INSPECTION)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create hub request returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "if (d.id) pm.environment.set('vehicle_hub_request_id', d.id);",
              "else if (d.requestId) pm.environment.set('vehicle_hub_request_id', d.requestId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{fleet_owner_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"creatorId\": \"{{fleet_owner_id}}\", \"driverId\": \"{{fleet_owner_id}}\", \"operationHubId\": \"{{operation_hub_id}}\", \"registrationNo\": \"{{vehicle_reg_no}}\", \"requestType\": \"ONBOARDING_INSPECTION\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/operator/createRequest",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "operator", "createRequest"]
        }
      }
    },
    {
      "name": "10 - Ops Fetch Pending Vehicle Hub Requests (by rcNumber)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Fetch vehicle hub requests returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "if (!pm.environment.get('vehicle_hub_request_id')) {",
              "  const arr = d.requests || d.list || d || [];",
              "  const first = Array.isArray(arr) && arr.length ? arr[0] : null;",
              "  if (first) pm.environment.set('vehicle_hub_request_id', first.id || first.operationHubRequestId || '');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "token", "value": "{{ops_token}}" } ],
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/operator/fetch/hubRequests?mbLimit=10&mbOffset=0&mbStatus=%22PENDING%22&mbReqType=%22ONBOARDING_INSPECTION%22&mbRegistrationNo={{vehicle_reg_no}}",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "operator", "fetch", "hubRequests"],
          "query": [
            { "key": "mbLimit", "value": "10" },
            { "key": "mbOffset", "value": "0" },
            { "key": "mbStatus", "value": "%22PENDING%22" },
            { "key": "mbReqType", "value": "%22ONBOARDING_INSPECTION%22" },
            { "key": "mbRegistrationNo", "value": "{{vehicle_reg_no}}" }
          ]
        }
      }
    },
    {
      "name": "11 - Ops Get Car Video Upload Link",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Media upload link returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "if (d.mediaFileDocumentId) pm.environment.set('media_file_document_id', d.mediaFileDocumentId);",
              "if (d.uploadUrl) pm.environment.set('media_file_upload_url', d.uploadUrl);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{ops_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"mediaFileDocumentType\": \"VehicleVideo\", \"fileType\": \"Video\", \"reqContentType\": \"video/mp4\", \"rcNumber\": \"{{vehicle_reg_no}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/mediaFileDocument/uploadLink",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "mediaFileDocument", "uploadLink"]
        }
      }
    },
    {
      "name": "12 - Ops Confirm Media Upload",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [ "pm.test('Confirm media upload returns 200 or 204', () => pm.expect([200,204]).to.include(pm.response.code));" ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{ops_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"mediaFileDocumentId\": \"{{media_file_document_id}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/mediaFileDocument/confirm",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "mediaFileDocument", "confirm"]
        }
      }
    },
    {
      "name": "13 - Ops Respond to Vehicle Hub Request (APPROVED)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [ "pm.test('Respond vehicle hub request returns 200', () => pm.response.to.have.status(200));" ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{ops_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"operationHubRequestId\": \"{{vehicle_hub_request_id}}\", \"operatorId\": \"{{operator_id}}\", \"registrationNo\": \"{{vehicle_reg_no}}\", \"status\": \"APPROVED\", \"remarks\": \"\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/operator/respond/hubRequest",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "operator", "respond", "hubRequest"]
        }
      }
    },
    {
      "name": "14 - Lookup VRC UUID by registration number (needed for Update Entry + Bot Approve)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Vehicle info returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "const rc = d.rc || d.vehicleRegistrationCertificate || d.vrc || d;",
              "const vrcId = rc.id || rc.rcId || rc.vehicleRegistrationCertificateId || (d.rc && d.rc.id) || d.id;",
              "pm.expect(vrcId, 'vrc_id extracted from vehicle info').to.be.a('string');",
              "pm.environment.set('vrc_id', vrcId);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "token", "value": "{{fleet_owner_token}}" } ],
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/vehicle/info?vehicleNo={{vehicle_reg_no}}",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "vehicle", "info"],
          "query": [ { "key": "vehicleNo", "value": "{{vehicle_reg_no}}" } ]
        }
      }
    },
    {
      "name": "15 - Ops Update Vehicle Entry (Inspection Q&A)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [ "pm.test('Update vehicle entry returns 200 or 204', () => pm.expect([200,204]).to.include(pm.response.code));" ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{ops_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"entityId\": \"{{vrc_id}}\", \"entityType\": \"RC\", \"newInfo\": [{\"question\": \"Are the exteriors free of major dents/damages, and are headlights, taillights, and mirrors in good condition?\", \"questionId\": \"1\", \"answer\": \"Yes\"}]}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/entityInfo/update",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "entityInfo", "update"]
        }
      }
    },
    {
      "name": "16 - Bot Approve Vehicle (submit/review/request)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const code = pm.response.code;",
              "if (code !== 200) { console.warn('Bot approve not configured — leaving vehicle in pre-approval state. code:', code); return; }",
              "pm.test('Bot approve vehicle returns 200', () => pm.expect(code).to.eql(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "token", "value": "{{bot_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"entityId\": \"{{vrc_id}}\", \"entityType\": \"VEHICLE\", \"rejectDocumentUpdateReq\": []}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/submit/review/request",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "submit", "review", "request"]
        }
      }
    },
    {
      "name": "17 - Get Vehicle Status (assert VRC verified + approved via FODVC.isApprovalSupported derivation)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Get vehicle status returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "if (pm.environment.get('bot_token') && pm.environment.get('bot_token') !== pm.environment.get('dashboard_token')) {",
              "  pm.test('VRC verified after bot approval', () => pm.expect(d.verified === true || (d.rc && d.rc.verified === true)).to.be.true);",
              "  pm.test('VRC approved derived from FODVC.isApprovalSupported (=true when all approval-docs valid)', () => {",
              "    const approved = d.approved !== undefined ? d.approved : (d.rc && d.rc.approved);",
              "    pm.expect(approved).to.eql(true);",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [ { "key": "token", "value": "{{fleet_owner_token}}" } ],
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/vehicle/info?vehicleNo={{vehicle_reg_no}}",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "driver", "vehicle", "info"],
          "query": [ { "key": "vehicleNo", "value": "{{vehicle_reg_no}}" } ]
        }
      }
    }
  ]
}
