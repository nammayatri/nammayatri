    {
      "name": "04 - SQL: Resolve fleet_owner_id (after V2 verify, before profile update)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('SQL select returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "let rows = (d && d.rows) || [];",
              "pm.test('Found fleet owner rows', () => pm.expect(rows.length).to.be.above(0));",
              "if (rows.length) {",
              "  // /fleet/v2/verify/otp persists with unencrypted_mobile_number=NULL (only encrypted form).",
              "  // /fleet/v2/register would set first_name but currently fails on India-doc checks.",
              "  // So we filter by role + pick the row with the latest created_at \u2014 that's the one we just created.",
              "  rows.sort((a, b) => String(b.created_at).localeCompare(String(a.created_at)));",
              "  const latest = rows[0];",
              "  pm.environment.set('fleet_owner_id', latest.id);",
              "  console.log('fleet_owner_id =', latest.id, 'role:', latest.role, 'created:', latest.created_at);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"db_name\": \"atlas_dev\", \"db_schema\": \"atlas_driver_offer_bpp\", \"table_name\": \"person\", \"select\": [\"id\", \"first_name\", \"role\", \"created_at\"], \"where_clause\": [{\"column_name\": \"role\", \"val\": \"FLEET_OWNER\", \"op\": \"=\"}], \"limit\": 50}"
        },
        "url": {
          "raw": "{{mockServerUrl}}/mock/sql/select",
          "host": [
            "{{mockServerUrl}}"
          ],
          "path": [
            "mock",
            "sql",
            "select"
          ]
        },
        "description": "/fleet/v2/verify/otp persists person with unencrypted_mobile_number=NULL and default first_name 'Fleet Owner'. We fetch all FLEET_OWNER rows and pick the one with the latest created_at \u2014 that's the one this collection just created. Brittle if concurrent test runs race, but fine for sequential e2e."
      }
    },
    {
      "name": "05 - Fleet Owner Update (proper Helsinki API)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const code = pm.response.code;",
              "if (code !== 200) console.warn('Update failed:', code, pm.response.text().slice(0, 250));",
              "pm.test('Update returns 200', () => pm.expect(code).to.eql(200));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{fleet_owner_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"firstName\": \"{{fleet_owner_first_name}}\", \"lastName\": \"{{fleet_owner_last_name}}\", \"email\": \"{{fleet_owner_email}}\", \"fleetType\": \"BUSINESS_FLEET\", \"fleetName\": \"{{fleet_owner_first_name}} Fleet\", \"fleetDob\": \"1990-01-01T00:00:00Z\", \"stripeAddress\": {\"line1\": \"123 Mannerheimintie\", \"line2\": null, \"city\": \"Helsinki\", \"state\": \"Uusimaa\", \"postal_code\": \"00100\", \"country\": \"FI\"}, \"stripeIdNumber\": \"012345-6789\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/driver/fleet/driver/{{fleet_owner_id}}/update",
          "host": [
            "{{baseURL_BPP_Dashboard_Internal}}"
          ],
          "path": [
            "{{dashboard_merchant_id}}",
            "{{dashboard_city}}",
            "driver",
            "fleet",
            "driver",
            "{{fleet_owner_id}}",
            "update"
          ]
        },
        "description": "Dashboard UI calls POST /driver/fleet/driver/{id}/update (updateFleetDriverContactDetails) for Helsinki fleet-owner onboarding, NOT /fleet/v2/register. The /update path doesn't require India docs (PAN/Aadhaar/GST) and sets stripeAddress on fleet_owner_information \u2014 which is required by /fleet/register/bankAccount/link downstream (A.02 Stripe). UpdateDriverReq fields: firstName, lastName, email, dob, address, fleetDob, stripeAddress, fleetType, fleetName."
      }
    },
