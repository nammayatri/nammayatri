{
  "info": {
    "_postman_id": "international-onboarding-01-fleet-owner",
    "name": "International Onboarding 01 - Fleet Owner (V2 cross-writing flow + 4 FLEET_BUSINESS docs + JUSPAY_ADMIN approve)",
    "description": "Registers a fleet owner under BRIDGE_FINLAND_PARTNER/Helsinki (representative international/BRIDGE_* deployment) using the V2 OTP-driven flow which cross-writes the person into BOTH atlas_bpp_dashboard.person AND atlas_driver_offer_bpp.person. Uploads the 4 mandatory FLEET_BUSINESS docs (TaxiTransportLicense, FinnishIDResidencePermit, BusinessLicense, TAXDetails), JUSPAY_ADMIN-approves each, and asserts the new refactor's flag model (fleet_owner_information.verified/approved/enabled + disabledReasonFlag) via `fleetOwnerInfo` and SQL backstops. Ported from HelsinkiOnboarding/01-FleetOwnerOnboarding.json; consolidated into the shared 3-flow layout with MSILOnboarding.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('_test_fleet_mobile')) {",
          "  // Mobile uses digits \u2014 fine. Name uses ONLY letters because the dashboard's",
          "  // validateFleetOwner enforces P.name (alphabetic-only) when the merchant has",
          "  // isStrongNameCheckRequired=true (BRIDGE_FINLAND_PARTNER does).",
          "  const r = Math.floor(Math.random() * 900000000) + 100000000;",
          "  const alpha = 'abcdefghijklmnopqrstuvwxyz';",
          "  let nameSuffix = '';",
          "  for (let i = 0; i < 8; i++) nameSuffix += alpha[Math.floor(Math.random() * 26)];",
          "  pm.collectionVariables.set('_test_fleet_mobile', String(r));",
          "  pm.environment.set('fleet_owner_mobile', String(r));",
          "  pm.environment.set('fleet_owner_first_name', 'Helsinki' + nameSuffix.charAt(0).toUpperCase() + nameSuffix.slice(1));",
          "  pm.environment.set('fleet_owner_last_name', 'TestFleet');",
          "  pm.environment.set('fleet_owner_email', 'fleet-' + r + '@helsinki.test');",
          "  console.log('Generated fleet owner: firstName=', pm.environment.get('fleet_owner_first_name'), 'mobile=', r);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
