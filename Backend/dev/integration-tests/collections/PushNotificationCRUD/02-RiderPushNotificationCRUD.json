    {
      "name": "LIST - Verify Created Rider Notification",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
              "var d = pm.response.json();",
              "var key = pm.collectionVariables.get(\"_test_rider_pn_key\");",
              "var created = d.filter(function(n) { return n.key === key; });",
              "pm.test(\"Created notification exists\", function () { pm.expect(created.length).to.be.at.least(1); });",
              "var n = created[0];",
              "pm.test(\"Title matches\", function () { pm.expect(n.title).to.eql(\"Rider Integration Test Notification\"); });",
              "pm.test(\"Body matches\", function () { pm.expect(n.body).to.eql(\"This is a rider-side test notification body\"); });",
              "pm.test(\"shouldTrigger is true\", function () { pm.expect(n.shouldTrigger).to.eql(true); });",
              "pm.test(\"isCritical is false\", function () { pm.expect(n.isCritical).to.eql(false); });",
              "pm.test(\"Channels match\", function () { pm.expect(n.channels).to.eql([\"NCH_FCM\", \"NCH_OVERLAY\"]); });",
              "pm.collectionVariables.set(\"_test_rider_pn_id\", n.id);",
              "console.log(\"Created Rider PN id:\", n.id);"
            ],
            "type": "text/javascript"
          }
