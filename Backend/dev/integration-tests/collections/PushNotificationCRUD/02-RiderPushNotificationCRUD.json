              "    body: \"This is a rider-side test notification body\",",
              "    language: \"ENGLISH\",",
              "    fcmNotificationType: \"TRIGGER_SERVICE\",",
              "    shouldTrigger: true,",
              "    channels: [\"NCH_FCM\", \"NCH_OVERLAY\"],",
