{
  "info": {
    "name": "Wallet Recharge - Topup Earn (test-Zumgy8FTRw)",
    "description": "Recharges the loyalty wallet via /payment/wallet/recharge, overrides the Juspay order-status mock to return CHARGED with a TOPUP earn of 500 points for the configured programId, then triggers the order-status check. Verifies the wallet balance reflects the topup.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-skip mock-server requests when envType is not Local.",
          "// Set envType=Local in Local env files; omit / set to 'Master' otherwise.",
          "(function () {",
          "  var envType = pm.environment.get('envType') || 'Local';",
          "  if (envType === 'Local') return;",
          "  var raw = (pm.request && pm.request.url && pm.request.url.toString()) || '';",
          "  if (raw.indexOf('mockServerUrl') !== -1 || raw.indexOf('mock_fcm_url') !== -1) {",
          "    console.log('[skip] mock-only request on envType=' + envType + ': ' + (pm.info && pm.info.requestName));",
          "    if (pm.execution && typeof pm.execution.skipRequest === 'function') {",
          "      pm.execution.skipRequest();",
          "    }",
          "  }",
          "})();",
          "",
          "if (!pm.collectionVariables.get('_test_rider_number')) {",
          "  var rNum = '8' + Math.floor(100000000 + Math.random() * 899999999);",
          "  pm.collectionVariables.set('_test_rider_number', rNum);",
          "  console.log('Test rider:', rNum);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json();",
              "if (d.authId) pm.environment.set('authId', d.authId);",
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"mobileNumber\": \"{{_test_rider_number}}\",\n    \"mobileCountryCode\": \"+91\",\n    \"merchantId\": \"NAMMA_YATRI\"\n}"
        },
        "url": {
          "raw": "{{baseUrl_app}}/auth",
          "host": [
            "{{baseUrl_app}}"
          ],
          "path": [
            "auth"
          ]
        }
      }
    },
    {
      "name": "Auth Verify",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json();",
              "if (d.token) pm.environment.set('customer_token', d.token);",
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"otp\": \"{{login_otp}}\",\n    \"deviceToken\": \"loyalty-test-device\"\n}"
        },
        "url": {
          "raw": "{{baseUrl_app}}/auth/:authId/verify",
          "host": [
            "{{baseUrl_app}}"
          ],
          "path": [
            "auth",
            ":authId",
            "verify"
          ],
          "variable": [
            {
              "key": "authId",
              "value": "{{authId}}"
            }
          ]
        }
      }
    },
    {
      "name": "Wallet Recharge (Create Order)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json();",
              "console.log('Recharge order:', JSON.stringify(d));",
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Order id present', function () {",
              "    pm.expect(d.order_id || d.orderId || d.id).to.not.be.undefined;",
              "});",
              "var orderId = d.order_id || d.orderId || d.id;",
              "var orderShortId = d.order_id || d.orderShortId || orderId;",
              "pm.environment.set('wallet_order_id', orderId);",
              "pm.environment.set('wallet_order_short_id', orderShortId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{customer_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"pointsAmount\": 500,\n    \"programId\": \"{{loyalty_program_id}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl_app}}/payment/wallet/recharge",
          "host": [
            "{{baseUrl_app}}"
          ],
          "path": [
            "payment",
            "wallet",
            "recharge"
          ]
        }
      }
    },
    {
      "name": "Override Juspay Status (CHARGED + Topup Earn 500)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Pair-id /mock/override registration to cover the alternate id form",
              "pm.sendRequest({",
              "    url: pm.environment.get('mockServerUrl') + '/mock/override',",
              "    method: 'POST',",
              "    header: { 'Content-Type': 'application/json' },",
              "    body: { mode: 'raw', raw: JSON.stringify({\"service\": \"juspay\", \"extract\": \"path.2\", \"value\": pm.environment.get('wallet_order_short_id'), \"response\": {\"status\": \"CHARGED\", \"amount\": 500.0, \"effective_amount\": 500.0, \"currency\": \"INR\", \"payment_method_type\": \"NB\", \"payment_method\": \"JP_HDFC\", \"loyalty_info\": {\"earn_details\": [{\"program_id\": \"{{loyalty_program_id}}\", \"applied\": {\"points\": \"500.00\"}, \"campaigns\": []}]}}, \"match\": \"/orders\"}) }",
              "}, function(){});"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json();",
              "console.log('Mock status set:', JSON.stringify(d));",
              "pm.test('Mock override accepted', function () {",
              "    pm.response.to.have.status(200);",
              "    pm.expect(d.ok).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"service\": \"juspay\", \"extract\": \"path.2\", \"match\": \"/orders\", \"value\": \"{{wallet_order_id}}\", \"response\": {\"status\": \"CHARGED\", \"amount\": 500.0, \"effective_amount\": 500.0, \"currency\": \"INR\", \"payment_method_type\": \"NB\", \"payment_method\": \"JP_HDFC\", \"loyalty_info\": {\"earn_details\": [{\"program_id\": \"{{loyalty_program_id}}\", \"applied\": {\"points\": \"500.00\"}, \"campaigns\": []}]}}}"
        },
        "url": {
          "raw": "{{mockServerUrl}}/mock/override",
          "host": [
            "{{mockServerUrl}}"
          ],
          "path": [
            "mock",
            "override"
          ]
        }
      }
    },
    {
      "name": "Stage Juspay Loyalty Programs Response",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json();",
              "console.log('Loyalty programs staged:', JSON.stringify(d));",
              "pm.test('Loyalty programs override accepted', function () {",
              "    pm.response.to.have.status(200);",
              "    pm.expect(d.ok).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"service\": \"juspay\", \"extract\": \"path.2\", \"match\": \"/orders\", \"value\": \"loyalty\", \"response\": {\"status\": \"OK\", \"programs\": [{\"id\": \"{{loyalty_program_id}}\", \"code\": \"LOYALTYOS7\", \"burn\": {\"options\": []}, \"earn\": {\"status\": \"ELIGIBLE\", \"applicable\": {\"label\": \"Earn points\", \"points\": \"0.00\"}}, \"campaigns\": [], \"membership\": {\"enroll_on\": \"AUTO\", \"enrolled_date\": \"2026-04-16T11:42:19Z\", \"status\": \"ACTIVE\"}, \"topup\": {\"status\": \"ELIGIBLE\"}, \"ui_label\": {\"asset\": {\"code\": \"POINTS\", \"name\": \"Points\"}, \"description\": \"Earn and redeem points at 1:1 ratio\", \"title\": \"Loyalty Points Program\", \"tnc\": \"Points are valid for 12 months from date of credit\", \"tnc_url\": \"https://example.com/tnc\"}, \"wallet\": {\"available_points\": \"500.00\", \"lifetime_earned\": \"500.00\", \"lifetime_redeemed\": \"0.00\", \"pockets\": [{\"label\": \"TOPUP Points\", \"available_points\": \"500.00\", \"lifetime_earned\": \"500.00\", \"lifetime_redeemed\": \"0.00\"}]}}]}}"
        },
        "url": {
          "raw": "{{mockServerUrl}}/mock/override",
          "host": [
            "{{mockServerUrl}}"
          ],
          "path": [
            "mock",
            "override"
          ]
        }
      }
    },
    {
      "name": "Get Payment Order Status (triggers loyalty processing)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const start = Date.now();",
              "while (Date.now() - start < 1500) { /* settle override */ }"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json();",
              "console.log('Order status:', d.status, 'orderId:', d.orderId);",
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Status is CHARGED', function () { pm.expect(d.status).to.eql('CHARGED'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{customer_token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl_app}}/payment/:orderId/status",
          "host": [
            "{{baseUrl_app}}"
          ],
          "path": [
            "payment",
            ":orderId",
            "status"
          ],
          "variable": [
            {
              "key": "orderId",
              "value": "{{wallet_order_id}}"
            }
          ]
        }
      }
    }
  ]
}
