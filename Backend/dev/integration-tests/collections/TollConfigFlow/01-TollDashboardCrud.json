            "type": "text/javascript",
            "exec": [
              "pm.test('Delete polygon toll status 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete CSV toll",
      "request": {
        "method": "GET",
        "header": [{ "key": "token", "value": "{{dashboard_token}}" }],
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/merchant/config/toll/list?limit=200&offset=0",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "merchant", "config", "toll", "list"],
          "query": [
            { "key": "limit", "value": "200" },
            { "key": "offset", "value": "0" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var tolls = pm.response.json();",
              "var name = pm.environment.get('test_toll_csv_name');",
              "var found = tolls.find(function (t) { return t.name === name; });",
              "pm.test('CSV toll created', function () { pm.expect(found).to.not.be.undefined; });",
              "if (found) pm.environment.set('test_toll_csv_id', found.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete CSV toll (execute)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "token", "value": "{{dashboard_token}}" }],
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/merchant/toll/{{test_toll_csv_id}}/delete",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "merchant", "toll", "{{test_toll_csv_id}}", "delete"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Delete CSV toll status 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "_test_toll_suffix", "value": "" }
  ]
}
