{
  "info": {
    "_postman_id": "fleet-operator-metrics-flow",
    "name": "Fleet Operator Metrics - Dashboard Analytics & Vehicle Stats",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Tests fleet dashboard analytics and vehicle list stats with multiple drivers and vehicles per fleet owner. Seeds 3 driver summary rows in fleet_operator_daily_stats and 3 vehicle rows in fleet_rc_daily_stats, then verifies that the API returns correctly aggregated earnings, rides, and per-vehicle stats."
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('_test_fleet_mobile')) {",
          "  var r = Math.floor(Math.random() * 900000000) + 100000000;",
          "  pm.collectionVariables.set('_test_fleet_mobile', String(r));",
          "  pm.environment.set('fleet_owner_mobile', String(r));",
          "",
          "  pm.collectionVariables.set('_test_driver1', 'drv1-' + r);",
          "  pm.collectionVariables.set('_test_driver2', 'drv2-' + r);",
          "  pm.collectionVariables.set('_test_driver3', 'drv3-' + r);",
          "",
          "  pm.collectionVariables.set('_test_rc1', 'rc1-' + r);",
          "  pm.collectionVariables.set('_test_rc2', 'rc2-' + r);",
          "  pm.collectionVariables.set('_test_rc3', 'rc3-' + r);",
          "",
          "  var today = new Date();",
          "  var d1 = new Date(today); d1.setDate(today.getDate() - 3);",
          "  var d2 = new Date(today); d2.setDate(today.getDate() - 2);",
          "  var d3 = new Date(today); d3.setDate(today.getDate() - 1);",
          "  var fromDate = new Date(today); fromDate.setDate(today.getDate() - 7);",
          "  pm.collectionVariables.set('_test_date1', d1.toISOString().split('T')[0]);",
          "  pm.collectionVariables.set('_test_date2', d2.toISOString().split('T')[0]);",
          "  pm.collectionVariables.set('_test_date3', d3.toISOString().split('T')[0]);",
          "  pm.collectionVariables.set('_test_from_date', fromDate.toISOString().split('T')[0]);",
          "  pm.collectionVariables.set('_test_to_date', today.toISOString().split('T')[0]);",
          "",
          "  console.log('Generated: mobile=' + r);",
          "  console.log('Drivers: ' + pm.collectionVariables.get('_test_driver1') + ', ' + pm.collectionVariables.get('_test_driver2') + ', ' + pm.collectionVariables.get('_test_driver3'));",
          "  console.log('Vehicles: ' + pm.collectionVariables.get('_test_rc1') + ', ' + pm.collectionVariables.get('_test_rc2') + ', ' + pm.collectionVariables.get('_test_rc3'));",
          "}",
          "",
          "var envType = pm.environment.get('envType') || 'Local';",
          "var url = pm.request.url.toString();",
          "if (envType !== 'Local' && (url.indexOf(pm.environment.get('mockServerUrl')) !== -1)) {",
          "  postman.setNextRequest(null); return;",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00a - SQL: Enable fleet operator dashboard analytics (before BPP caches config)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.body.raw = JSON.stringify({",
              "  db_name: 'atlas_dev', db_schema: 'atlas_driver_offer_bpp',",
              "  table_name: 'transporter_config',",
              "  set: { analytics_config: JSON.stringify({ enableFleetOperatorDashboardAnalytics: true, weekStartMode: 3, earningsWindowSize: 7, maxOnlineDurationDays: 10, useDbForEarningAndMetrics: true, allowCacheDriverFlowStatus: false, onlineDurationCalculateFrom: null }) },",
              "  where_clause: [{ column_name: 'merchant_operating_city_id', val: pm.environment.get('merchant_operating_city_id') || 'f067bccf-5b34-fb51-a5a3-9d6fa6baac26', op: '=' }]",
              "});"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Enable analytics config', () => pm.response.to.have.status(200));"],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{}" },
        "url": {
          "raw": "{{mockServerUrl}}/mock/sql/update",
          "host": ["{{mockServerUrl}}"],
          "path": ["mock", "sql", "update"]
        }
      }
    },
    {
      "name": "00b - SQL: Disable transporter_config from KV cache (local only)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var body = {",
              "  db_name: 'atlas_dev',",
              "  db_schema: 'atlas_driver_offer_bpp',",
              "  table_name: 'system_configs',",
              "  select: ['id', 'config_value'],",
              "  where_clause: [{ column_name: 'id', val: 'kv_configs', op: '=' }]",
              "};",
              "pm.request.body.raw = JSON.stringify(body);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Read system_configs', () => pm.response.to.have.status(200));",
              "var d = pm.response.json();",
              "if (d.rows && d.rows.length > 0) {",
              "  var cfg = d.rows[0].config_value;",
              "  if (typeof cfg === 'string') cfg = JSON.parse(cfg);",
              "  var disabled = cfg.disableForKV || [];",
              "  if (disabled.indexOf('transporter_config') === -1) {",
              "    disabled.push('transporter_config');",
              "    cfg.disableForKV = disabled;",
              "    pm.collectionVariables.set('_kv_config_needs_update', JSON.stringify(cfg));",
              "  } else {",
              "    pm.collectionVariables.set('_kv_config_needs_update', '');",
              "  }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{}" },
        "url": {
          "raw": "{{mockServerUrl}}/mock/sql/select",
          "host": ["{{mockServerUrl}}"],
          "path": ["mock", "sql", "select"]
        }
      }
    },
    {
      "name": "00c - SQL: Update system_configs to disable transporter_config KV (local only)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var newCfg = pm.collectionVariables.get('_kv_config_needs_update');",
              "if (!newCfg) { pm.collectionVariables.set('_skip_00c', 'true'); return; }",
              "pm.collectionVariables.set('_skip_00c', '');",
              "pm.request.body.raw = JSON.stringify({",
              "  db_name: 'atlas_dev', db_schema: 'atlas_driver_offer_bpp',",
              "  table_name: 'system_configs',",
              "  set: { config_value: newCfg },",
              "  where_clause: [{ column_name: 'id', val: 'kv_configs', op: '=' }]",
              "});"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var skipped = pm.collectionVariables.get('_skip_00c');",
              "if (skipped) {",
              "  pm.test('transporter_config already disabled in KV (no update needed)', () => true);",
              "} else {",
              "  pm.test('Update system_configs', () => pm.response.to.have.status(200));",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{}" },
        "url": {
          "raw": "{{mockServerUrl}}/mock/sql/update",
          "host": ["{{mockServerUrl}}"],
          "path": ["mock", "sql", "update"]
        }
      }
    },
    {
      "name": "01 - Fleet Owner Login OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login OTP returns 200', () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"mobileNumber\": \"{{fleet_owner_mobile}}\", \"mobileCountryCode\": \"{{country_code}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/fleet/v2/login/otp",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "fleet", "v2", "login", "otp"]
        }
      }
    },
    {
      "name": "02 - Fleet Owner Verify OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Verify OTP returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "pm.expect(d.authToken, 'authToken').to.be.a('string');",
              "pm.environment.set('fleet_owner_token', d.authToken);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"mobileNumber\": \"{{fleet_owner_mobile}}\", \"mobileCountryCode\": \"{{country_code}}\", \"otp\": \"{{login_otp}}\"}"
        },
        "url": {
          "raw": "{{baseURL_BPP_Dashboard_Internal}}/{{dashboard_merchant_id}}/{{dashboard_city}}/fleet/v2/verify/otp",
          "host": ["{{baseURL_BPP_Dashboard_Internal}}"],
          "path": ["{{dashboard_merchant_id}}", "{{dashboard_city}}", "fleet", "v2", "verify", "otp"]
        }
      }
    },
    {
      "name": "03 - SQL: Resolve fleet_owner_id",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('SQL select returns 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json();",
              "let rows = (d && d.rows) || [];",
              "pm.test('Found fleet owner rows', () => pm.expect(rows.length).to.be.above(0));",
              "if (rows.length) {",
              "  rows.sort((a, b) => String(b.created_at).localeCompare(String(a.created_at)));",
              "  pm.environment.set('fleet_owner_id', rows[0].id);",
              "  pm.collectionVariables.set('_test_fo_id', rows[0].id);",
              "  console.log('fleet_owner_id =', rows[0].id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"db_name\": \"atlas_dev\", \"db_schema\": \"atlas_driver_offer_bpp\", \"table_name\": \"person\", \"select\": [\"id\", \"role\", \"created_at\"], \"where_clause\": [{\"column_name\": \"role\", \"val\": \"FLEET_OWNER\", \"op\": \"=\"}], \"limit\": 50}"
        },
        "url": {
          "raw": "{{mockServerUrl}}/mock/sql/select",
          "host": ["{{mockServerUrl}}"],
          "path": ["mock", "sql", "select"]
        }
      }
    },
