              "  if (d.listItem && d.listItem.length === 3) {",
              "    var rc1Id = pm.collectionVariables.get('_test_rc1');",
              "    var rc2Id = pm.collectionVariables.get('_test_rc2');",
              "    var rc3Id = pm.collectionVariables.get('_test_rc3');",
              "",
              "    var v1 = d.listItem.find(i => i.rcId === rc1Id);",
              "    var v2 = d.listItem.find(i => i.rcId === rc2Id);",
              "    var v3 = d.listItem.find(i => i.rcId === rc3Id);",
              "",
              "    if (v1) {",
              "      pm.test('rc1: completedRides = 12', () => pm.expect(v1.completedRides).to.eql(12));",
              "      pm.test('rc1: totalEarnings = 6000', () => pm.expect(v1.totalEarnings).to.eql(6000));",
              "      pm.test('rc1: rideDistance = 48000', () => pm.expect(v1.rideDistance).to.eql(48000));",
              "      pm.test('rc1: rideDuration = 9000', () => pm.expect(v1.rideDuration).to.eql(9000));",
              "    }",
              "",
              "    if (v2) {",
              "      pm.test('rc2: completedRides = 7', () => pm.expect(v2.completedRides).to.eql(7));",
              "      pm.test('rc2: totalEarnings = 3500', () => pm.expect(v2.totalEarnings).to.eql(3500));",
              "      pm.test('rc2: rideDistance = 28000', () => pm.expect(v2.rideDistance).to.eql(28000));",
              "      pm.test('rc2: rideDuration = 5400', () => pm.expect(v2.rideDuration).to.eql(5400));",
              "    }",
              "",
              "    if (v3) {",
              "      pm.test('rc3: completedRides = 2', () => pm.expect(v3.completedRides).to.eql(2));",
              "      pm.test('rc3: totalEarnings = 1000', () => pm.expect(v3.totalEarnings).to.eql(1000));",
              "      pm.test('rc3: rideDistance = 8000', () => pm.expect(v3.rideDistance).to.eql(8000));",
              "      pm.test('rc3: rideDuration = 1500', () => pm.expect(v3.rideDuration).to.eql(1500));",
              "    }",
              "",
              "    pm.test('vehicles ordered by rides desc', () => {",
              "      var rides = d.listItem.map(i => i.completedRides);",
              "      for (var i = 1; i < rides.length; i++) {",
              "        pm.expect(rides[i]).to.be.at.most(rides[i-1]);",
              "      }",
              "    });",
              "  }",
