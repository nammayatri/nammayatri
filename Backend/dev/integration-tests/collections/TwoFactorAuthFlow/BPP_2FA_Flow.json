          }
        ],
        "url": {
          "raw": "{{dashboard_base_url}}/user/logout",
          "host": [
            "{{dashboard_base_url}}"
          ],
          "path": [
            "user",
            "logout"
          ]
        }
      },
      "response": []
    }
  ]
}