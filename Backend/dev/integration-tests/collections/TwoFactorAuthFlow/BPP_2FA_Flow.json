    {
      "name": "BPP - Switch Merchant And City",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Compute TOTP in case 2FA was already enabled from a previous run.",
              "var secret = pm.environment.get('bpp_2fa_secret');",
              "if (secret) {",
              "    function sha1(b) {",
              "        function r(n,s){return (n<<s)|(n>>>(32-s));}",
              "        var ml=b.length,w=[],i,j;",
              "        for(i=0;i<ml;i++) w[i>>2]=(w[i>>2]||0)|((b[i]&255)<<(24-(i%4)*8));",
              "        w[ml>>2]=(w[ml>>2]||0)|(128<<(24-(ml%4)*8));",
              "        w[((ml+8>>6)+1)*16-1]=ml*8;",
              "        var H=[0x67452301,0xEFCDAB89,0x98BADCFE,0x10325476,0xC3D2E1F0];",
              "        for(var B=0;B<w.length;B+=16){",
              "            var W=w.slice(B,B+16);",
              "            while(W.length<80)W.push(r((W[W.length-3]||0)^(W[W.length-8]||0)^(W[W.length-14]||0)^(W[W.length-16]||0),1));",
              "            var a=H[0],bb=H[1],c=H[2],d=H[3],e=H[4],f,k,t;",
              "            for(j=0;j<80;j++){",
              "                if(j<20){f=(bb&c)|(~bb&d);k=0x5A827999;}",
              "                else if(j<40){f=bb^c^d;k=0x6ED9EBA1;}",
              "                else if(j<60){f=(bb&c)|(bb&d)|(c&d);k=0x8F1BBCDC;}",
              "                else{f=bb^c^d;k=0xCA62C1D6;}",
              "                t=(r(a,5)+f+e+k+(W[j]||0))>>>0;e=d;d=c;c=r(bb,30);bb=a;a=t;",
              "            }",
              "            H[0]=(H[0]+a)>>>0;H[1]=(H[1]+bb)>>>0;H[2]=(H[2]+c)>>>0;H[3]=(H[3]+d)>>>0;H[4]=(H[4]+e)>>>0;",
              "        }",
              "        var out=[];for(i=0;i<5;i++)for(j=3;j>=0;j--)out.push((H[i]>>(j*8))&255);",
              "        return out;",
              "    }",
              "    function hmac(key,msg){",
              "        var ip=[],op=[],i;",
              "        for(i=0;i<64;i++){ip[i]=(key[i]||0)^0x36;op[i]=(key[i]||0)^0x5c;}",
              "        return sha1(op.concat(sha1(ip.concat(msg))));",
              "    }",
              "    function b32d(s){",
              "        var a='ABCDEFGHIJKLMNOPQRSTUVWXYZ234567',bits=0,val=0,out=[],i;",
              "        s=s.toUpperCase().replace(/=+$/,'');",
              "        for(i=0;i<s.length;i++){val=(val<<5)|a.indexOf(s[i]);bits+=5;if(bits>=8){out.push((val>>>(bits-8))&255);bits-=8;}}",
              "        return out;",
              "    }",
              "    var step=30, ts=Math.floor(Date.now()/1000/step);",
              "    var cnt=[0,0,0,0,0,0,0,0], i;",
              "    for(i=7;i>=0;i--){cnt[i]=ts&255;ts=Math.floor(ts/256);}",
              "    var h=hmac(b32d(secret),cnt), off=h[19]&15;",
              "    var otp=((h[off]&127)<<24|(h[off+1]&255)<<16|(h[off+2]&255)<<8|(h[off+3]&255))%1000000;",
              "    var s=''+otp; while(s.length<6) s='0'+s;",
              "    pm.environment.set('switch_otp', s);",
              "    console.log('BPP switch TOTP:', s);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json();",
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "if (d.is2faMandatory === false) {",
              "    console.log('BPP: 2FA is not mandatory for this merchant — enable is2faMandatory first to run this flow.');",
              "    pm.test('Enable 2FA mandatory on merchant before running this flow', function () {",
              "        throw new Error(d.message);",
              "    });",
              "} else if (d.is2faEnabled === true && d.authToken) {",
              "    pm.environment.set('bpp_dashboard_token', d.authToken);",
              "    console.log('BPP: 2FA already enabled — TOTP matched, token stored. Setup steps will re-run to refresh secret.');",
              "    pm.test('2FA already enabled — TOTP matched', function () { pm.expect(d.is2faEnabled).to.eql(true); });",
              "} else if (d.is2faEnabled === true) {",
              "    console.log('BPP: 2FA enabled but TOTP missing/wrong (e.g. after page refresh) — re-running setup to refresh secret.');",
              "    pm.test('2FA enabled — re-running setup to refresh secret', function () { pm.expect(d.is2faEnabled).to.eql(true); });",
              "} else {",
              "    console.log('BPP: 2FA mandatory and not yet enabled — proceeding to Initiate/Verify steps.');",
              "    pm.test(d.message, function () { pm.expect(d.is2faEnabled).to.eql(false); });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{bpp_dashboard_token}}"
