    {
      "name": "BPP - Initiate 2FA Setup",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var d = pm.response.json();",
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('requestId present', function () { pm.expect(d.requestId).to.be.a('string'); });",
              "pm.environment.set('bpp_2fa_request_id', d.requestId);"
