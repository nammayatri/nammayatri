        "body": {
          "mode": "raw",
          "raw": "{\n    \"merchantId\": \"{{bpp_short_id}}\",\n    \"city\": \"{{city}}\",\n    \"otp\": \"{{switch_otp}}\"\n}"
        },
        "url": {
