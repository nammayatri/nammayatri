{
	"info": {
		"name": "Online Ride Booking (Stripe Payment)",
		"description": "End-to-end ride with Stripe online payment: search \u2192 payment setup \u2192 assign \u2192 start \u2192 end \u2192 payment capture",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"exec": [
					"if (!pm.collectionVariables.get('_test_driver_number')) {",
					"    // Finnish mobile: 04X XXXXXXX (10 digits starting with 04)",
					"    var dNum = '04' + Math.floor(10000000 + Math.random() * 89999999);",
					"    var rNum = '04' + Math.floor(10000000 + Math.random() * 89999999);",
					"    // Finnish plate: ABC123 (no hyphen \u2014 API requires ^[0-9A-Z]*$)",
					"    var regNo = String.fromCharCode(65+Math.floor(Math.random()*26)) + String.fromCharCode(65+Math.floor(Math.random()*26)) + String.fromCharCode(65+Math.floor(Math.random()*26)) + String(Math.floor(100+Math.random()*899));",
					"    pm.collectionVariables.set('_test_driver_number', dNum);",
					"    pm.collectionVariables.set('_test_rider_number', rNum);",
					"    pm.collectionVariables.set('_test_reg_no', regNo);",
					"    console.log('Test driver:', dNum, 'rider:', rNum, 'reg:', regNo);",
					"}"
				],
				"type": "text/javascript"
			}
		}
	],
	"item": [
		{
			"name": "Switch City for Setup (Dashboard)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var d = pm.response.json();",
							"pm.environment.set('dashboard_token', d.authToken);",
							"pm.test('Status 200', function () { pm.response.to.have.status(200); });"
						],
