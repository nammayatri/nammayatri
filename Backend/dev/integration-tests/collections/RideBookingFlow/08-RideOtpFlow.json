		{
			"name": "Ride Search (Special Zone Pickup)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": ["setTimeout(function(){}, 2000);"],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"var d = pm.response.json();",
							"pm.environment.set('searchId', d.searchId);",
							"console.log('Search ID:', d.searchId);",
							"pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
							"// Wait for async beckn search + quote generation",
							"const _delay = 8000; const _start = Date.now(); while (Date.now() - _start < _delay) {}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{"key": "Content-Type", "value": "application/json"},
					{"key": "token", "value": "{{rider_token}}"}
				],
				"body": {
					"mode": "raw",
					"raw": "{\"fareProductType\": \"ONE_WAY\", \"contents\": {\"origin\": {\"address\": {\"area\": \"Special Zone Pickup\", \"areaCode\": \"000000\", \"city\": \"{{city}}\", \"country\": \"India\", \"state\": \"{{state}}\"}, \"gps\": {\"lat\": {{sz_origin_lat}}, \"lon\": {{sz_origin_lon}}}}, \"destination\": {\"address\": {\"area\": \"Test Destination\", \"areaCode\": \"000000\", \"city\": \"{{city}}\", \"country\": \"India\", \"state\": \"{{state}}\"}, \"gps\": {\"lat\": {{dest_lat}}, \"lon\": {{dest_lon}}}}}}"
				},
				"url": {
					"raw": "{{baseUrl_app}}/rideSearch",
					"host": ["{{baseUrl_app}}"],
					"path": ["rideSearch"]
				}
			}
		},
		{
			"name": "Get Search Results (Expect Quotes)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": ["setTimeout(function(){}, 3000);"],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"var d = pm.response.json();",
							"pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
							"",
							"// RideOTP flow returns quotes (not estimates)",
							"// Pick the quote matching the driver's vehicle variant",
							"var quotes = d.quotes || [];",
							"var wantVariant = pm.environment.get('vehicle_variant') || 'SEDAN';",
							"var szQuote = null;",
							"for (var i = 0; i < quotes.length; i++) {",
							"    var inner = quotes[i].onDemandCab || quotes[i].onRentalCab || quotes[i].onMeterRide;",
							"    if (!inner) continue;",
							"    // Match by vehicleVariant or by serviceTierName containing the variant",
							"    if (inner.vehicleVariant === wantVariant) {",
							"        szQuote = inner;",
							"        break;",
							"    }",
							"}",
							"// Fallback: use first quote if no variant match",
							"if (!szQuote && quotes.length > 0) {",
							"    szQuote = quotes[0].onDemandCab || quotes[0].onRentalCab || quotes[0].onMeterRide;",
							"}",
							"if (szQuote) {",
							"    pm.environment.set('sz_quoteId', szQuote.id);",
							"    console.log('Selected Quote:', szQuote.id, 'variant:', szQuote.vehicleVariant, 'fare:', szQuote.estimatedTotalFare, '(wanted:', wantVariant + ')');",
							"    console.log('Available quotes:', quotes.map(function(q) { var i = q.onDemandCab || q.onRentalCab; return i ? i.vehicleVariant + '=' + i.estimatedTotalFare : '?'; }).join(', '));",
							"}",
							"pm.test('Has quotes for special zone', function () {",
							"    pm.expect(pm.environment.get('sz_quoteId')).to.be.a('string').that.is.not.empty;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [{"key": "token", "value": "{{rider_token}}"}],
				"url": {
					"raw": "{{baseUrl_app}}/rideSearch/{{searchId}}/results",
					"host": ["{{baseUrl_app}}"],
					"path": ["rideSearch", "{{searchId}}", "results"]
				}
			}
		},
