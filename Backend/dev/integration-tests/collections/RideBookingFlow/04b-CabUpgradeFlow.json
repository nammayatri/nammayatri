        },
        "url": {
          "raw": "{{baseUrl_app}}/rideSearch",
          "host": [
            "{{baseUrl_app}}"
          ],
          "path": [
            "rideSearch"
          ]
        }
      }
    },
    {
      "name": "Get Search Results",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "setTimeout(function(){}, 5000);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json();",
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Has estimates', function () { pm.expect(d, 'response body').to.be.an('object'); pm.expect(d.estimates, 'estimates field').to.be.an('array'); pm.expect(d.estimates.length, 'estimate count').to.be.above(0); });",
              "// Pick the lowest-priority tier the seeded Sedan driver can actually serve.",
              "// In Bangalore this is ECO (sub-COMFY, both have vehicleVariant=SEDAN);",
              "// HATCHBACK/TAXI require non-Sedan vehicles so the BPP would not assign a",
              "// Sedan driver to them. In other cities, extend lowerTiers as needed.",
              "var lowerTiers = ['HATCHBACK', 'ECO'];",
              "var est = null;",
              "for (var i = 0; i < lowerTiers.length && !est; i++) {",
              "    est = d.estimates.find(function (e) { return e.serviceTierType === lowerTiers[i] && e.vehicleVariant === 'SEDAN'; });",
              "}",
              "pm.test('Has a Sedan-servable lower tier (HATCHBACK or ECO) to force an upgrade', function () {",
              "    pm.expect(est, 'a Sedan-servable lower tier in estimates').to.be.an('object');",
              "});",
              "if (est) {",
              "    pm.environment.set('estimateId', est.id);",
              "    pm.environment.set('booked_service_tier_type', est.serviceTierType);",
              "    pm.environment.set('booked_service_tier_name', est.serviceTierName || est.serviceTierType);",
              "    console.log('Booking lower tier:', est.serviceTierType, est.serviceTierName, 'fare:', est.estimatedFare);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{rider_token}}"
          }
        ],
