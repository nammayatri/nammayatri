    {
      "name": "Get Booking (Rider)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Wait for booking to be created after driver acceptance",
              "const delay = pm.environment.get('booking_wait_ms') || 5000;",
              "const start = Date.now();",
              "while (Date.now() - start < delay) { /* busy wait */ }"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json();",
              "if (d.list && d.list.length > 0) {",
              "    var booking = d.list[0];",
              "    pm.environment.set('customer_bookingId', booking.id);",
              "    var otp = booking.rideOtp;",
              "    if (!otp && booking.rideList && booking.rideList.length > 0) {",
              "        otp = booking.rideList[0].rideOtp;",
              "    }",
              "    pm.environment.set('ride_otp', otp);",
              "    console.log('Booking:', booking.id, 'OTP:', otp, 'Status:', booking.status);",
              "}",
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Booking returned an assigned ride', function () {",
              "    pm.expect(d.list, 'list').to.be.an('array');",
              "    pm.expect(d.list.length, 'list length').to.be.above(0);",
              "    pm.expect(d.list[0].rideList, 'rideList').to.be.an('array');",
              "    pm.expect(d.list[0].rideList.length, 'rideList length').to.be.above(0);",
              "});",
              "// --- Upgrade signal checks ---",
              "var ride = d.list && d.list[0] && d.list[0].rideList && d.list[0].rideList[0];",
              "var bookedTier = pm.environment.get('booked_service_tier_type');",
              "pm.test('Booking serviceTier stays the booked (billed) tier', function () {",
              "    pm.expect(d.list[0].vehicleServiceTierType, 'booking serviceTier').to.equal(bookedTier);",
              "});",
              "pm.test('rideList[0].isTierUpgrade is true (within-family upgrade detected)', function () {",
              "    pm.expect(ride, 'ride entity').to.be.an('object');",
              "    pm.expect(ride.isTierUpgrade, 'isTierUpgrade flag').to.equal(true);",
              "});",
              "pm.test('rideList[0].assignedServiceTierName is set and is not the booked tier name', function () {",
              "    pm.expect(ride.assignedServiceTierName, 'assignedServiceTierName').to.be.a('string').and.not.empty;",
              "    pm.expect(ride.assignedServiceTierName.toUpperCase(), 'assigned != booked').to.not.equal(String(bookedTier).toUpperCase());",
              "});"
            ],
            "type": "text/javascript"
          }
        }
