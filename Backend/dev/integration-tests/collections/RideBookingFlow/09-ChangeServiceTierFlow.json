    {
      "name": "Get Change Service Tier Quotes",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const s = Date.now(); while (Date.now() - s < 2000) {}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json();",
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "",
              "// Should return quotes with higher fare than current booking",
              "var quotes = d.quotes || [];",
              "var upgradeQuote = null;",
              "var initialFare = parseFloat(pm.environment.get('initial_fare'));",
              "console.log('Current booking fare:', initialFare, 'variant:', pm.environment.get('initial_variant'));",
              "console.log('Available upgrade quotes:', quotes.length);",
              "",
              "for (var i = 0; i < quotes.length; i++) {",
              "    var inner = quotes[i].onDemandCab || quotes[i].onRentalCab || quotes[i].onMeterRide;",
              "    if (!inner) continue;",
              "    console.log('  -', inner.vehicleVariant, '$' + inner.estimatedTotalFare, 'id:', inner.id);",
              "    if (!upgradeQuote || inner.estimatedTotalFare < upgradeQuote.estimatedTotalFare) {",
              "        upgradeQuote = inner;",
              "    }",
              "}",
              "",
              "if (upgradeQuote) {",
              "    pm.environment.set('upgrade_quoteId', upgradeQuote.id);",
              "    pm.environment.set('upgrade_variant', upgradeQuote.vehicleVariant);",
              "    pm.environment.set('upgrade_fare', upgradeQuote.estimatedTotalFare);",
              "    console.log('Selected upgrade:', upgradeQuote.vehicleVariant, '$' + upgradeQuote.estimatedTotalFare);",
              "}",
              "pm.test('Has upgrade quotes with higher fare', function () {",
              "    pm.expect(quotes.length).to.be.above(0);",
              "});",
              "pm.test('Upgrade fare is higher than current', function () {",
              "    pm.expect(upgradeQuote.estimatedTotalFare).to.be.above(initialFare);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
