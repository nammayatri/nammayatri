    {
      "name": "Get Search Results (Pick cheapest quote)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "setTimeout(function(){}, 3000);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json();",
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var quotes = d.quotes || [];",
              "// Pick the cheapest quote so we can upgrade later",
              "var cheapest = null;",
              "var allQuotes = [];",
              "for (var i = 0; i < quotes.length; i++) {",
              "    var inner = quotes[i].onDemandCab || quotes[i].onRentalCab || quotes[i].onMeterRide;",
              "    if (!inner) continue;",
              "    allQuotes.push({id: inner.id, variant: inner.vehicleVariant, fare: inner.estimatedTotalFare});",
              "    if (!cheapest || inner.estimatedTotalFare < cheapest.estimatedTotalFare) {",
              "        cheapest = inner;",
              "    }",
              "}",
              "if (cheapest) {",
              "    pm.environment.set('sz_quoteId', cheapest.id);",
              "    pm.environment.set('initial_fare', cheapest.estimatedTotalFare);",
              "    pm.environment.set('initial_variant', cheapest.vehicleVariant);",
              "    console.log('Selected cheapest quote:', cheapest.id, cheapest.vehicleVariant, '$' + cheapest.estimatedTotalFare);",
              "    console.log('All quotes:', JSON.stringify(allQuotes));",
              "}",
              "pm.test('Has quotes', function () { pm.expect(quotes.length).to.be.above(0); });",
              "pm.test('Has multiple tiers for upgrade', function () { pm.expect(allQuotes.length).to.be.above(1); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{rider_token}}"
          }
        ],
