    {
      "name": "Get Booking (Extract OTP)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json();",
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "if (d.list && d.list.length > 0) {",
              "    var booking = d.list[0];",
              "    pm.environment.set('customer_bookingId', booking.id);",
              "    var szOtp = null;",
              "    if (booking.bookingDetails && booking.bookingDetails.contents && booking.bookingDetails.contents.otpCode) {",
              "        szOtp = booking.bookingDetails.contents.otpCode;",
              "    }",
              "    pm.environment.set('sz_otp', szOtp || '');",
              "    console.log('Booking:', booking.id, 'Status:', booking.status, 'OTP:', szOtp, 'Tier:', booking.vehicleServiceTierType);",
              "}",
              "pm.test('Has OTP', function () { pm.expect(pm.environment.get('sz_otp')).to.be.a('string').that.is.not.empty; });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{rider_token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl_app}}/rideBooking/list?limit=1&onlyActive=true&offset=0",
          "host": [
            "{{baseUrl_app}}"
          ],
          "path": [
            "rideBooking",
            "list"
          ],
          "query": [
            {
              "key": "limit",
              "value": "1"
            },
            {
              "key": "onlyActive",
              "value": "true"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      }
    },
    {
      "name": "Driver OTP Ride Start",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json(); pm.test('Status 200', function () { pm.response.to.have.status(200); }); if (d.id) { pm.environment.set('driver_ride_id', d.id); } console.log('Ride started with OTP after tier change!');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{driver_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"specialZoneOtpCode\": \"{{sz_otp}}\", \"point\": {\"lat\": {{sz_origin_lat}}, \"lon\": {{sz_origin_lon}}}}"
        },
        "url": {
          "raw": "{{baseURL_namma_P}}/driver/otpRide/start",
          "host": [
            "{{baseURL_namma_P}}"
          ],
          "path": [
            "driver",
            "otpRide",
            "start"
          ]
        }
      }
    },
    {
      "name": "End Ride",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const s = Date.now(); while (Date.now() - s < 1000) {}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); }); console.log('Ride ended!');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "token",
            "value": "{{driver_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"point\": {\"lat\": {{dest_lat}}, \"lon\": {{dest_lon}}}}"
        },
        "url": {
          "raw": "{{baseURL_namma_P}}/driver/ride/{{driver_ride_id}}/end",
          "host": [
            "{{baseURL_namma_P}}"
          ],
          "path": [
            "driver",
            "ride",
            "{{driver_ride_id}}",
            "end"
          ]
        }
      }
    },
    {
      "name": "Verify Booking Completed",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const s = Date.now(); while (Date.now() - s < 3000) {}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var d = pm.response.json();",
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Booking COMPLETED', function () { pm.expect(d.bookingStatus).to.equal('COMPLETED'); });",
              "pm.test('Ride COMPLETED', function () { pm.expect(d.rideStatus).to.equal('COMPLETED'); });",
              "console.log('Change Service Tier flow completed! Booking:', d.bookingStatus, 'Ride:', d.rideStatus);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "token",
            "value": "{{rider_token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl_app}}/rideBooking/v2/{{customer_bookingId}}",
          "host": [
            "{{baseUrl_app}}"
          ],
          "path": [
            "rideBooking",
            "v2",
            "{{customer_bookingId}}"
          ]
        }
      }
    }
  ]
}
