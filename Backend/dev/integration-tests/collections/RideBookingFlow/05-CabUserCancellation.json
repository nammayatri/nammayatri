							"    console.log('Estimate:', est.id, est.vehicleServiceTierType, est.estimatedFare);",
							"}",
							"pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
							"pm.test('Has estimates', function () { pm.expect(d.estimates).to.be.an('array').that.is.not.empty; });"
